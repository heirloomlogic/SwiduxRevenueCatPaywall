{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"schemaVersion":{"minor":3,"major":0,"patch":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui"]}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"],"abstract":[{"type":"text","text":"The matching API reference for the views described here lives in the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" documentation."}]},{"title":"How-to Guides","generated":true,"anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"abstract":[{"type":"text","text":"Attach the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" and "},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"type":"text","text":" view modifiers from "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" to a root view, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"roleHeading":"Article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Present the UI","role":"article"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" ships three view modifiers that wrap RevenueCatUI’s surfaces with platform-aware presentation. Each is bound to ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":": presentation flags drive visibility, and the bindings dispatch matching paywall actions back through the store on dismissal. There is no local sheet state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For platform behavior details (iOS "},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":" vs macOS sheet sizing, App Store deep link on macOS), see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","isActive":true},{"type":"text","text":"."}]},{"text":"Before you start","anchor":"Before-you-start","level":2,"type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This guide assumes:","type":"text"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have completed "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":". The plugin is registered and "},{"type":"codeVoice","code":"observeCustomerInfo"},{"type":"text","text":" runs on launch."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Your app target depends on the "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" product:"}],"type":"paragraph"}]}],"type":"unorderedList"},{"code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Step-1-Attach-both-sheets-to-a-root-view","text":"Step 1: Attach both sheets to a root view","type":"heading"},{"inlineContent":[{"text":"The simplest wiring uses the ","type":"text"},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"text":" modifier — one call, both sheets, both dismissals:","type":"text"}],"type":"paragraph"},{"code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"The closure receives a ","type":"text"},{"code":"PaywallAction","type":"codeVoice"},{"text":" (","type":"text"},{"code":".dismiss","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":") and lifts it into your root action. Place the modifier on the topmost view that should host both sheets."}],"type":"paragraph"},{"type":"heading","level":2,"anchor":"Step-2-Trigger-the-paywall-from-a-feature","text":"Step 2: Trigger the paywall from a feature"},{"type":"paragraph","inlineContent":[{"text":"Dispatch ","type":"text"},{"code":".request(reason:)","type":"codeVoice"},{"text":" with a short identifier describing why you’re asking. ","type":"text"},{"code":"PaywallState.requestedReason","type":"codeVoice"},{"text":" stores the value so the sheet (or analytics) can tailor its copy:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Export PDF\") {","    store.send(.paywall(.request(reason: \"export-pdf\")))","}"]},{"type":"paragraph","inlineContent":[{"text":"The plugin sets ","type":"text"},{"code":"PaywallState.isPresented = true","type":"codeVoice"},{"text":". The ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" modifier observes the change and presents ","type":"text"},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"text":".","type":"text"}]},{"level":2,"type":"heading","text":"Step 3: Trigger the customer center","anchor":"Step-3-Trigger-the-customer-center"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Existing subscribers manage their subscription through the customer center. Surface a button that dispatches "},{"type":"codeVoice","code":".presentCustomerCenter"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifier presents "},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"},{"type":"text","text":" on iOS. On macOS it opens the system App Store subscriptions URL and immediately fires "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" (RevenueCatUI does not ship a customer center on macOS — see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"type":"text","text":")."}]},{"level":2,"type":"heading","text":"Step 4: Manual wiring (optional)","anchor":"Step-4-Manual-wiring-optional"},{"type":"paragraph","inlineContent":[{"text":"If you need only one sheet, or you want to interleave other modifiers between them, attach the primitive modifiers directly. Each takes a real ","type":"text"},{"code":"Binding<Bool>","type":"codeVoice"},{"text":"; build it with a ","type":"text"},{"code":"set:","type":"codeVoice"},{"text":" that dispatches the matching dismiss action when SwiftUI clears the flag:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["ContentView()","    .revenueCatPaywall(","        isPresented: Binding(","            get: { store.paywall.isPresented },","            set: { if !$0 { store.send(.paywall(.dismiss)) } }","        )","    )","    .revenueCatCustomerCenter(","        isPresented: Binding(","            get: { store.paywall.isCustomerCenterPresented },","            set: { if !$0 { store.send(.paywall(.dismissCustomerCenter)) } }","        )","    )"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The convenience modifier "},{"type":"codeVoice","code":"revenueCatPaywall(state:send:)"},{"type":"text","text":" is exactly equivalent to this wiring."}]},{"type":"heading","level":2,"text":"Step 5: Restore from inside the paywall","anchor":"Step-5-Restore-from-inside-the-paywall"},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevenueCatUI’s "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" provides its own restore button by default. If you need an additional restore affordance elsewhere (a Settings row, for example), dispatch "},{"type":"codeVoice","code":".restorePurchases"},{"type":"text","text":":"}]},{"type":"codeListing","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"syntax":"swift"},{"type":"heading","level":2,"text":"What happens on dismiss","anchor":"What-happens-on-dismiss"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the paywall, the plugin’s "},{"code":".dismiss","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"PaywallState.isPresented","type":"codeVoice"},{"type":"text","text":" and "},{"code":"requestedReason","type":"codeVoice"},{"type":"text","text":", then dispatches "},{"code":".refreshCustomerInfo","type":"codeVoice"},{"type":"text","text":" so the gate is reconciled — the user may have purchased while the sheet was open."}]},{"type":"paragraph","inlineContent":[{"text":"When the user dismisses the customer center, the plugin’s ","type":"text"},{"code":".dismissCustomerCenter","type":"codeVoice"},{"text":" action clears ","type":"text"},{"code":"isCustomerCenterPresented","type":"codeVoice"},{"text":". No refresh is dispatched, since opening the customer center does not change entitlement state by itself; the live ","type":"text"},{"code":"customerInfoStream","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"Step 5","type":"codeVoice"},{"text":" of ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference"},{"text":" picks up any subscription change RevenueCat reports asynchronously.","type":"text"}]}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"type":"topic","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"title":"How to Preview and Test"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","kind":"article","role":"article","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","kind":"symbol","title":"SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"title":"How to Implement the Service","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","abstract":[{"type":"text","text":"Wire "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/PlatformBehavior":{"url":"\/documentation\/swiduxrevenuecatpaywall\/platformbehavior","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","abstract":[{"type":"text","text":"Why the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifiers present differently on iOS and macOS, and what is hard-coded."}],"kind":"article","role":"article","type":"topic","title":"Platform Behavior"}}}