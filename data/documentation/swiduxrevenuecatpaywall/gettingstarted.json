{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"title":"Getting Started with SwiduxRevenueCatPaywall","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"},"kind":"article","hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/gettingstarted"]}],"sections":[],"abstract":[{"type":"text","text":"Add the package, configure RevenueCat, register the paywall plugin, and present the bundled sheets."}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide walks through the four steps to integrate "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" into a Swidux app: add the package, configure RevenueCat, register the plugin, and attach the UI. It is the shortest path from a wired Swidux app to a working paywall. For deeper coverage of any step, follow the linked how-tos."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This package assumes you already use Swidux. If you don’t, work through Swidux’s own getting-started guide first."}]},{"type":"heading","text":"Add the Package","anchor":"Add-the-Package","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Xcode:","type":"text"}]},{"type":"text","text":" File > Add Package Dependencies, paste "},{"code":"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":". Add the products you need:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":" — the ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" implementation and mock.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" — adds the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers (depends on RevenueCatUI).","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Package.swift:","type":"text"}]}]},{"type":"codeListing","code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", from: \"1.0.0\"),"],"syntax":"swift"},{"type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift"},{"type":"heading","text":"Configure the paywall at launch","anchor":"Configure-the-paywall-at-launch","level":2},{"type":"paragraph","inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" calls into "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":" under the hood. Configure the paywall before constructing the store:"}]},{"type":"codeListing","code":["\/\/ MyApp.swift","import SwiduxRevenueCatPaywall","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        RevenueCatPaywall.configure(apiKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass "},{"code":"appUserID","type":"codeVoice"},{"type":"text","text":", "},{"code":"userDefaults","type":"codeVoice"},{"type":"text","text":" (for app-group sharing with widgets), "},{"code":"logLevel","type":"codeVoice"},{"type":"text","text":", "},{"code":"entitlementVerification","type":"codeVoice"},{"type":"text","text":" (signed entitlement verification), or "},{"code":"purchasesAreCompletedBy","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"storeKitVersion","type":"codeVoice"},{"type":"text","text":" (app-completed purchases) if you need them — see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"Register the paywall plugin","anchor":"Register-the-paywall-plugin","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" to "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":" in your "},{"code":"Store.configured()","type":"codeVoice"},{"type":"text","text":" factory:"}]},{"type":"codeListing","code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:"}]},{"type":"codeListing","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Gate features by reading "},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"type":"text","text":". See "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"type":"text","text":" for the full plugin lifecycle."}]},{"type":"heading","text":"Attach the UI","anchor":"Attach-the-UI","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Attach the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" modifier to a root view, driven by paywall state:"}]},{"type":"codeListing","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Trigger the paywall from a gated feature with "},{"code":".paywall(.request(reason:))","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true},{"type":"text","text":" for manual wiring with the primitive modifiers, customer-center triggering, and dismiss semantics."}]},{"type":"heading","text":"Next Steps","anchor":"Next-Steps","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference"},{"text":" — Detailed walkthrough of the service lifecycle and error handling.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","type":"reference"},{"text":" — Add a lifetime entitlement alongside the subscription.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"reference"},{"text":" — Drive entitlement state from previews and tests.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","type":"reference"},{"text":" — Wire the bundled view modifiers.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","type":"reference"},{"text":" — Why iOS and macOS behave differently.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","type":"reference"},{"text":" — How RevenueCat entitlements map to ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"te