{"schemaVersion":{"minor":3,"major":0,"patch":0},"metadata":{"role":"article","title":"Platform Behavior","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"kind":"article","identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/platformbehavior"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"text":"Why the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" modifiers present differently on iOS and macOS, and what is hard-coded.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"title":"Related Documentation","abstract":[{"text":"The ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" documentation provides the matching API reference for the modifiers described here.","type":"text"}],"anchor":"Related-Documentation"},{"title":"Explanation","anchor":"Explanation","generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"The bundled UI is intentionally opinionated. Each modifier picks the platform-appropriate presentation so consumers don’t have to repeat the conditional compilation themselves, and so the dispatch flow stays symmetric across platforms — the same ","type":"text"},{"code":".paywall(.dismiss)","type":"codeVoice"},{"text":" action fires from a ","type":"text"},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":" on iOS and from a sheet on macOS."}],"type":"paragraph"},{"inlineContent":[{"text":"This article explains the reasoning behind those choices and what is fixed versus configurable.","type":"text"}],"type":"paragraph"},{"anchor":"revenueCatPaywall","type":"heading","text":"revenueCatPaywall","level":2},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Platform"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Presentation"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Reason"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fullScreenCover"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"A subscription paywall is a primary moment, not an interrupt. "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" keeps the UI immersive, prevents accidental gesture-dismiss, and matches App Store conventions."}]}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"macOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"sheet","type":"codeVoice"},{"type":"text","text":" with "},{"code":"frame(minWidth: 400, minHeight: 600)","type":"codeVoice"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Mac sheets do not expand to fill the parent window. Without an explicit minimum size the paywall would render too small to legibly show plan options. The 400×600 minimum is roughly the size RevenueCatUI’s templates assume."}]}]]]},{"inlineContent":[{"type":"text","text":"Because neither presentation offers a system dismissal affordance ("},{"code":"fullScreenCover","type":"codeVoice"},{"text":" has no swipe-to-dismiss; Mac sheets have no default close control), the modifiers show ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":"’s close button by default. Pass "},{"type":"codeVoice","code":"displayCloseButton: false"},{"type":"text","text":" only for a hard paywall the user must purchase through — and make sure some other path out of that screen exists."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The minimum frame is hard-coded; it is not exposed as a parameter. If your paywall layout needs more room on macOS, wrap the modified view in a parent that imposes a larger frame, or use "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"text":" directly inside a custom ","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":" modifier.","type":"text"}]},{"type":"heading","text":"revenueCatCustomerCenter","level":2,"anchor":"revenueCatCustomerCenter"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Presentation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Reason","type":"text"}]}]],[[{"inlineContent":[{"inlineContent":[{"type":"text","text":"iOS"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"sheet"},{"type":"text","text":" with "},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RevenueCatUI ships a customer center on iOS only. A non-fullscreen ","type":"text"},{"code":"sheet","type":"codeVoice"},{"type":"text","text":" is appropriate because customer-center actions are administrative, not part of a purchase flow."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"macOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Opens "},{"type":"codeVoice","code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions"},{"type":"text","text":" and immediately fires "},{"type":"codeVoice","code":"onDismiss"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"RevenueCatUI does not ship a customer center on macOS, and the system has no equivalent in-app surface. The App Store subscription management page is what users expect on the Mac, so the sheet hands off to it and clears its own presentation state immediately."}],"type":"paragraph"}]]]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The macOS branch clears the binding and fires "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" synchronously after "},{"type":"codeVoice","code":"NSWorkspace.shared.open"},{"text":" so ","type":"text"},{"code":"PaywallState.isCustomerCenterPresented","type":"codeVoice"},{"text":" does not get stuck ","type":"text"},{"code":"true","type":"codeVoice"},{"text":". The user returns from App Store to find the app’s UI in its idle state. If nothing on the system handles the ","type":"text"},{"code":"itms-apps","type":"codeVoice"},{"type":"text","text":" scheme, the hand-off falls back to the "},{"code":"https:\/\/apps.apple.com\/account\/subscriptions","type":"codeVoice"},{"type":"text","text":" web URL in the default browser."}]},{"type":"heading","text":"Why no platform-override hooks","level":2,"anchor":"Why-no-platform-override-hooks"},{"inlineContent":[{"type":"text","text":"Both modifiers are deliberately parameter-light: an "},{"code":"isPresented: Binding<Bool>","type":"codeVoice"},{"type":"text","text":", an optional "},{"code":"onDismiss: () -> Void","type":"codeVoice"},{"type":"text","text":", and — on the paywall only — a "},{"type":"codeVoice","code":"displayCloseButton:"},{"type":"text","text":" flag. There is no "},{"type":"codeVoice","code":"paywallStyle:"},{"type":"text","text":" or "},{"type":"codeVoice","code":"presentationKind:"},{"type":"text","text":" parameter."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reasoning: any consumer that needs to deviate from the chosen presentation already has the underlying RevenueCatUI types ("},{"code":"PaywallView","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"text":") and SwiftUI’s full presentation surface (","type":"text"},{"type":"codeVoice","code":"sheet"},{"type":"text","text":", "},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":", "},{"type":"codeVoice","code":"popover"},{"type":"text","text":", custom containers). The bundled modifiers exist to handle the 95% case in one line — when the 5% case applies, drop down to RevenueCatUI directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This package does not try to be the complete paywall-UI library. It is the "},{"inlineContent":[{"type":"text","text":"integration layer"}],"type":"emphasis"},{"text":" that makes the common case trivial.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"What is configurable","level":2,"anchor":"What-is-configurable"},{"inlineContent":[{"text":"The configurable surface lives in ","type":"text"},{"code":"RevenueCatUI","type":"codeVoice"},{"text":" and on the paywall plugin:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Paywall content, copy, and template"}]},{"type":"text","text":" — configured in the RevenueCat dashboard. "},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"type":"text","text":" renders whichever offering and template the dashboard returns."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Customer-center labels, sections, and actions"}],"type":"strong"},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"text":" renders whichever configuration the dashboard returns.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Close button"}]},{"type":"text","text":" — "},{"type":"codeVoice","code":"displayCloseButton:"},{"type":"text","text":" on the paywall modifiers. Defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":"; pass "},{"type":"codeVoice","code":"false"},{"type":"text","text":" for a hard paywall."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Presentation triggering"}]},{"type":"text","text":" — driven by the plugin via "},{"type":"codeVoice","code":"PaywallState.isPresented"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isCustomerCenterPresented"},{"type":"text","text":". Your code chooses "},{"type":"emphasis","inlineContent":[{"type":"text","text":"when"}]},{"type":"text","text":" to set them via "},{"type":"codeVoice","code":".request(reason:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":".presentCustomerCenter"},{"type":"text","text":" actions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dismiss behavior"}]},{"type":"text","text":" — your "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" closures dispatch the matching paywall actions. Replace them if you need analytics hooks or cleanup beyond the default flow."}]}]}]}]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","title":"How to Present the UI","abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","kind":"symbol","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}]}}}