{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","metadata":{"roleHeading":"Article","title":"Mock Service Reference","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article"},"abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" — a controllable ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":".","type":"text"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/mockservicereference"]}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" tracks a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"current"}]},{"text":" entitlement snapshot the way the real service reflects RevenueCat’s state: ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)"},{"text":" updates it and pushes it through the stream, and ","type":"text"},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"text":" return it. ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()","type":"reference","isActive":true},{"type":"text","text":" tears the stream down, and the "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/customerInfoError","isActive":true},{"text":" \/ ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/restoreError","isActive":true},{"text":" properties inject failures for testing error paths.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This mock differs from "},{"code":"MockPaywallService","type":"codeVoice"},{"type":"text","text":" in SwiduxPaywall: that mock’s stream finishes after the initial yield, which is fine for static previews but cannot model purchase, refund, or family-share updates as a sequence. This mock keeps the stream live until you tear it down."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For preview and test patterns built on this type, see "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"reference","isActive":true},{"text":".","type":"text"}]},{"anchor":"Library-target","type":"heading","level":2,"text":"Library target"},{"items":[{"content":[{"inlineContent":[{"text":"Product: ","type":"text"},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"paragraph"}]}],"type":"unorderedList"},{"text":"Types","anchor":"Types","type":"heading","level":2},{"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallService","text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService``","type":"heading","level":3},{"syntax":"swift","code":["public final class MockRevenueCatPaywallService: PaywallService, @unchecked Sendable {","    public init(isPro: Bool = false, hasPermanentLicense: Bool = false)","","    public var customerInfoError: Error?","    public var restoreError: Error?","","    public func customerInfo() async throws -> EntitlementSnapshot","    public func customerInfoStream() -> AsyncStream<EntitlementSnapshot>","    public func restorePurchases() async throws -> EntitlementSnapshot","","    public func send(_ snapshot: EntitlementSnapshot)","    public func finish()","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reference type. Internal state is guarded by an "},{"code":"NSLock","type":"codeVoice"},{"type":"text","text":"; "},{"code":"@unchecked Sendable","type":"codeVoice"},{"text":" because the protected mutable state lives behind that lock.","type":"text"}]},{"level":4,"anchor":"Initializer","text":"Initializer","type":"heading"},{"syntax":"swift","code":["public init(isPro: Bool = false, hasPermanentLicense: Bool = false)"],"type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"isPro","type":"codeVoice"},{"type":"text","text":" — Initial value for "},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"hasPermanentLicense"},{"text":" — Initial value for ","type":"text"},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The values supplied here become the starting "},{"type":"emphasis","inlineContent":[{"type":"text","text":"current"}]},{"text":" snapshot — what ","type":"text"},{"code":"customerInfo()","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"restorePurchases()","type":"codeVoice"},{"type":"text","text":" return and what "},{"code":"customerInfoStream()","type":"codeVoice"},{"type":"text","text":" yields first, until "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)"},{"text":" replaces it.","type":"text"}]},{"level":4,"type":"heading","text":"`customerInfoError` \/ `restoreError`","anchor":"customerInfoError--restoreError"},{"type":"paragraph","inlineContent":[{"text":"Optional errors thrown by ","type":"text"},{"code":"customerInfo()","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"restorePurchases()","type":"codeVoice"},{"text":" respectively while set (","type":"text"},{"code":"nil","type":"codeVoice"},{"type":"text","text":", the default, means success). Set them to drive the plugin’s "},{"type":"codeVoice","code":".refreshFailed"},{"type":"text","text":" path, retry affordances, or "},{"type":"codeVoice","code":"ResilientPaywallService"},{"text":"’s last-known-good fallback; clear them to restore success.","type":"text"}]},{"text":"`customerInfo() async throws -> EntitlementSnapshot`","type":"heading","anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the current snapshot — the init-time state, or the latest value passed to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)"},{"type":"text","text":". This matches the real service: the plugin’s dismiss-triggered refresh sees the same state the stream delivered, so a simulated purchase does not regress to free on refresh. Throws "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/customerInfoError"},{"type":"text","text":" instead when it is set."}]},{"text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","type":"heading","anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yields the current snapshot, then every value passed to "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":". The stream stays open until "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()","isActive":true},{"type":"text","text":" is called."}]},{"style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"text":"Each call to this method replaces the active continuation and finishes the previous stream, so an earlier subscriber’s ","type":"text"},{"code":"for await","type":"codeVoice"},{"text":" loop terminates instead of hanging. Only the most recent subscriber receives subsequent ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","type":"reference"},{"text":" updates.","type":"text"}]}],"name":"Note"},{"type":"heading","level":4,"text":"`restorePurchases() async throws -> EntitlementSnapshot`","anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the current snapshot, exactly like "},{"type":"codeVoice","code":"customerInfo()"},{"text":". Throws ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/restoreError","type":"reference"},{"text":" instead when it is set.","type":"text"}]},{"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicesend","text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)``","level":4,"type":"heading"},{"code":["public func send(_ snapshot: EntitlementSnapshot)"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Makes the snapshot current and pushes it to the active stream subscriber. If no stream is active, the snapshot is still recorded — only the stream delivery is skipped."}],"type":"paragraph"},{"inlineContent":[{"text":"Use this to simulate purchase, expiration, or family-share updates during a test.","type":"text"}],"type":"paragraph"},{"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()``","level":4,"type":"heading","anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicefinish"},{"syntax":"swift","code":["public func finish()"],"type":"codeListing"},{"inlineContent":[{"text":"Finishes the active entitlement stream. Iterators terminate cleanly. Subsequent calls to ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":" still update the current snapshot but are no longer delivered to a stream."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this in test teardown or when a preview is done observing entitlement transitions."}]},{"type":"heading","text":"Lifecycle example","anchor":"Lifecycle-example","level":2},{"type":"codeListing","syntax":"swift","code":["let mock = MockRevenueCatPaywallService(isPro: false)","let stream = mock.customerInfoStream()","","var iterator = stream.makeAsyncIterator()","let initial = await iterator.next()  \/\/ EntitlementSnapshot(isPro: false, ...)","","mock.send(EntitlementSnapshot(isPro: true))","let updated = await iterator.next()  \/\/ EntitlementSnapshot(isPro: true, ...)","","mock.finish()","let terminal = await iterator.next()  \/\/ nil — stream finished","","let refreshed = try await mock.customerInfo()  \/\/ EntitlementSnapshot(isPro: true, ...) — send(_:) updated it"]}]}],"se