":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"title":"How to Present the UI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","kind":"article","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"kind":"symbol","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","title":"SwiduxRevenueCatPaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":". Implements "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" against "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","title":"Service Reference","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","kind":"article","abstract":[{"text":"API reference for ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" — the RevenueCat-backed ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer that the paywall plugin consumes.","type":"text"}],"role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"kind":"article","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"type":"text","text":" translates to Swidux’s "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"role":"article"}}}