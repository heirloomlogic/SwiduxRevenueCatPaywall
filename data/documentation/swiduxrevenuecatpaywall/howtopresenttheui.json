{"schemaVersion":{"patch":0,"major":0,"minor":3},"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Present the UI","roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"abstract":[{"type":"text","text":"Attach the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"],"abstract":[{"type":"text","text":"The matching API reference for the views described here lives in the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" documentation."}],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"generated":true,"title":"How-to Guides","anchor":"How-to-Guides"}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" ships three view modifiers that wrap RevenueCatUI’s surfaces with platform-aware presentation. Each is bound to "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":": presentation flags drive visibility, and the bindings dispatch matching paywall actions back through the store on dismissal. There is no local sheet state."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For platform behavior details (iOS "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" vs macOS sheet sizing, App Store deep link on macOS), see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Before you start","anchor":"Before-you-start"},{"inlineContent":[{"type":"text","text":"This guide assumes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"You have completed ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true,"type":"reference"},{"text":". The plugin is registered and ","type":"text"},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" runs on launch.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your app target depends on the ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" product:","type":"text"}]}]}]},{"syntax":"swift","type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"]},{"level":2,"type":"heading","text":"Step 1: Attach both sheets to a root view","anchor":"Step-1-Attach-both-sheets-to-a-root-view"},{"inlineContent":[{"type":"text","text":"The simplest wiring uses the "},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"type":"text","text":" modifier — one call, both sheets, both dismissals:"}],"type":"paragraph"},{"code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The closure receives a "},{"type":"codeVoice","code":"PaywallAction"},{"type":"text","text":" ("},{"type":"codeVoice","code":".dismiss"},{"type":"text","text":" or "},{"type":"codeVoice","code":".dismissCustomerCenter"},{"text":") and lifts it into your root action. Place the modifier on the topmost view that should host both sheets.","type":"text"}],"type":"paragraph"},{"text":"Step 2: Trigger the paywall from a feature","type":"heading","anchor":"Step-2-Trigger-the-paywall-from-a-feature","level":2},{"type":"paragraph","inlineContent":[{"text":"Dispatch ","type":"text"},{"code":".request(reason:)","type":"codeVoice"},{"text":" with a short identifier describing why you’re asking. ","type":"text"},{"code":"PaywallState.requestedReason","type":"codeVoice"},{"text":" stores the value so the sheet (or analytics) can tailor its copy:","type":"text"}]},{"code":["Button(\"Export PDF\") {","    store.send(.paywall(.request(reason: \"export-pdf\")))","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"The plugin sets "},{"code":"PaywallState.isPresented = true","type":"codeVoice"},{"type":"text","text":". The "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" modifier observes the change and presents "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Step 3: Trigger the customer center","anchor":"Step-3-Trigger-the-customer-center","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Existing subscribers manage their subscription through the customer center. Surface a button that dispatches "},{"code":".presentCustomerCenter","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" modifier presents ","type":"text"},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"text":" on iOS. On macOS it opens the system App Store subscriptions URL and immediately fires ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" (RevenueCatUI does not ship a customer center on macOS — see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"text":").","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-4-Manual-wiring-optional","type":"heading","text":"Step 4: Manual wiring (optional)"},{"inlineContent":[{"text":"If you need only one sheet, or you want to interleave other modifiers between them, attach the primitive modifiers directly. Each takes a real ","type":"text"},{"code":"Binding<Bool>","type":"codeVoice"},{"type":"text","text":"; build it with a "},{"code":"set:","type":"codeVoice"},{"type":"text","text":" that dispatches the matching dismiss action when SwiftUI clears the flag:"}],"type":"paragraph"},{"code":["ContentView()","    .revenueCatPaywall(","        isPresented: Binding(","            get: { store.paywall.isPresented },","            set: { if !$0 { store.send(.paywall(.dismiss)) } }","        )","    )","    .revenueCatCustomerCenter(","        isPresented: Binding(","            get: { store.paywall.isCustomerCenterPresented },","            set: { if !$0 { store.send(.paywall(.dismissCustomerCenter)) } }","        )","    )"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The convenience modifier "},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"type":"text","text":" is exactly equivalent to this wiring."}],"type":"paragraph"},{"text":"Step 5: Restore from inside the paywall","anchor":"Step-5-Restore-from-inside-the-paywall","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"RevenueCatUI’s "},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" provides its own restore button by default. If you need an additional restore affordance elsewhere (a Settings row, for example), dispatch "},{"code":".restorePurchases","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"type":"codeListing"},{"text":"What happens on dismiss","anchor":"What-happens-on-dismiss","level":2,"type":"heading"},{"inlineContent":[{"text":"When the user dismisses the paywall, the plugin’s ","type":"text"},{"code":".dismiss","type":"codeVoice"},{"text":" action clears ","type":"text"},{"code":"PaywallState.isPresented","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"requestedReason","type":"codeVoice"},{"text":", then dispatches ","type":"text"},{"code":".refreshCustomerInfo","type":"codeVoice"},{"text":" so the gate is reconciled — the user may have purchased while the sheet was open.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When the user dismisses the customer center, the plugin’s "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":". No refresh is dispatched, since opening the customer center does not change entitlement state by itself; the live "},{"code":"customerInfoStream","type":"codeVoice"},{"type":"text","text":" from "},{"code":"Step 5","type":"codeVoice"},{"text":" of ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"text":" picks up any subscription change RevenueCat reports asynchronously.","type":"text"}],"type":"paragraph"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"kind":"article","references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","title":"How to Add a Permanent License","role":"article","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"type":"topic","title":"How to Preview and Test","role":"article","abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — no RevenueCat SDK call required.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"type":"topic","title":"SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","kind":"symbol","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","abstract":[{"type":"text","text":"Wire "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"topic","title":"How to Implement the Service","kind":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/PlatformBehavior":{"url":"\/documentation\/swiduxrevenuecatpaywall\/platformbehavior","role":"article","abstract":[{"type":"text","text":"Why the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifiers present differently on iOS and macOS, and what is hard-coded."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","type":"topic","title":"Platform Behavior","kind":"article"}}}