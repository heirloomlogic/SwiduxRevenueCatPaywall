tion. This shape is what makes the macOS sheet machinery present reliably."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For step-by-step wiring, see "},{"inlineContent":[{"type":"text","text":"How to Present the UI"}],"type":"emphasis"},{"type":"text","text":" in the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"},{"type":"text","text":" documentation. For the rationale behind platform-specific behavior, see "},{"inlineContent":[{"type":"text","text":"Platform Behavior"}],"type":"emphasis"},{"type":"text","text":" in the same catalog."}]},{"anchor":"Library-target","level":2,"text":"Library target","type":"heading"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Product: ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywallUI","type":"codeVoice"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UI product depends on "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"RevenueCatUI"},{"type":"text","text":", both pulled in transitively. Apps that don’t ship paywall UI in the same target (for example, a tests-only target) can depend on the lower-level "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"},{"type":"text","text":" product alone."}]},{"anchor":"Modifiers","level":2,"text":"Modifiers","type":"heading"},{"anchor":"revenueCatPaywallisPresentedonDismiss","level":3,"text":"`revenueCatPaywall(isPresented:onDismiss:)`","type":"heading"},{"code":["extension View {","    public func revenueCatPaywall(","        isPresented: