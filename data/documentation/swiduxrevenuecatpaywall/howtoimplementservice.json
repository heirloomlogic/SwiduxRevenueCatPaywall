{"metadata":{"roleHeading":"Article","title":"How to Implement the Service","role":"article","modules":[{"name":"SwiduxRevenueCatPaywall"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"text":"This guide takes you from a wired Swidux app with a paywall slice to a live RevenueCat-backed entitlement pipeline. It covers SDK configuration, plugin registration, observation lifecycle, and refresh\/restore flows.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For the API-level reference of the service, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","isActive":true},{"text":". For the entitlement mapping rules, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","isActive":true},{"text":". For the upstream plugin contract — actions, state shape, dispatch semantics — see Swidux’s ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"Add a Paywall"}]},{"text":" and ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiduxPaywall Reference"}]},{"text":"; this guide does not repeat that material.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Before you start","level":2,"anchor":"Before-you-start"},{"inlineContent":[{"text":"This guide assumes:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You have a wired Swidux app — ","type":"text"},{"type":"codeVoice","code":"AppState"},{"text":", ","type":"text"},{"type":"codeVoice","code":"AppAction"},{"text":", ","type":"text"},{"type":"codeVoice","code":"AppReducer"},{"text":", ","type":"text"},{"type":"codeVoice","code":"AppStore"},{"text":" exist, and the store is in the SwiftUI environment.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your ","type":"text"},{"type":"codeVoice","code":"AppState"},{"text":" already has a ","type":"text"},{"type":"codeVoice","code":"paywall: PaywallState"},{"text":" slice and your ","type":"text"},{"type":"codeVoice","code":"AppAction"},{"text":" has a ","type":"text"},{"type":"codeVoice","code":".paywall(PaywallAction)"},{"text":" case. If not, follow Swidux’s ","type":"text"},{"inlineContent":[{"type":"text","text":"Add a Paywall"}],"type":"emphasis"},{"text":" guide first.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You have a RevenueCat project, an API key, and at least one entitlement identifier configured in the RevenueCat dashboard.","type":"text"}]}]}],"type":"unorderedList"},{"type":"heading","text":"Step 1: Add the dependencies","level":2,"anchor":"Step-1-Add-the-dependencies"},{"inlineContent":[{"text":"Add both Swift packages to your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}],"type":"paragraph"},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/Swidux\", branch: \"main\"),","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),","],"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"Add the products you need to your app target:","type":"text"}],"type":"paragraph"},{"code":[".target(","    name: \"MyApp\",","    dependencies: [","        .product(name: \"Swidux\", package: \"Swidux\"),","        .product(name: \"SwiduxPaywall\", package: \"Swidux\"),","        .product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),","        .product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),","    ]",")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" is optional — drop it if you don’t need the bundled sheets.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 2: Configure RevenueCat at launch","level":2,"anchor":"Step-2-Configure-RevenueCat-at-launch"},{"inlineContent":[{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" calls into ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":". Configure the SDK before constructing the store:","type":"text"}],"type":"paragraph"},{"code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"type":"codeListing","syntax":"swift"},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":" traps if used unconfigured. Configure it before anything that constructs "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":", including SwiftUI previews — guard preview-only code with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" instead."}]}],"type":"aside","style":"important","name":"Important"},{"type":"heading","text":"Step 3: Construct the service","level":2,"anchor":"Step-3-Construct-the-service"},{"inlineContent":[{"text":"Create the service with the entitlement identifier you set up in the RevenueCat dashboard:","type":"text"}],"type":"paragraph"},{"code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(entitlementID: \"pro\")"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"If your app sells a separate lifetime SKU alongside a subscription, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","isActive":true},{"text":" for the dual-entitlement form.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 4: Register the paywall plugin","level":2,"anchor":"Step-4-Register-the-paywall-plugin"},{"inlineContent":[{"text":"Pass the service to ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":" when wiring the store:","type":"text"}],"type":"paragraph"},{"code":["\/\/ AppStore.swift","import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The plugin owns reducing for ","type":"text"},{"type":"codeVoice","code":".paywall"},{"text":" actions; your root reducer should fall through with ","type":"text"},{"type":"codeVoice","code":"return nil"},{"text":" for that case.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 5: Observe customer info on launch","level":2,"anchor":"Step-5-Observe-customer-info-on-launch"},{"inlineContent":[{"text":"Start the entitlement stream once, on the root view:","type":"text"}],"type":"paragraph"},{"code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"codeVoice","code":"observeCustomerInfo"},{"text":" returns a long-lived effect that consumes ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.customerInfoStream()"},{"text":". Every snapshot the service yields flows through ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" and updates ","type":"text"},{"type":"codeVoice","code":"store.paywall.isPro"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"hasPermanentLicense"},{"text":". The effect lives for the duration of the stream, so the store stays in sync with RevenueCat without polling.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 6: Gate features","level":2,"anchor":"Step-6-Gate-features"},{"inlineContent":[{"text":"Read ","type":"text"},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"text":" before running gated work. If it’s ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", dispatch ","type":"text"},{"type":"codeVoice","code":".request(reason:)"},{"text":" instead:","type":"text"}],"type":"paragraph"},{"code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"codeVoice","code":"isGateSatisfied"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" when the user holds an active pro subscription ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"or"}]},{"text":" a permanent license — feature code does not need to know which.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 7: Wire the UI","level":2,"anchor":"Step-7-Wire-the-UI"},{"inlineContent":[{"text":"To present ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":" and the customer center, attach the bundled sheets to a root view. See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 8: Restore purchases","level":2,"anchor":"Step-8-Restore-purchases"},{"inlineContent":[{"text":"Add a restore button to your paywall UI. Reflect ","type":"text"},{"type":"codeVoice","code":"store.paywall.isLoading"},{"text":" to disable it while the call is in flight:","type":"text"}],"type":"paragraph"},{"code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The plugin calls ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.restorePurchases()"},{"text":", which forwards to ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.restorePurchases()"},{"text":". On success the resulting snapshot flows through ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" and updates the gate. On failure, ","type":"text"},{"type":"codeVoice","code":"store.paywall.error"},{"text":" is set.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 9: Handle errors","level":2,"anchor":"Step-9-Handle-errors"},{"inlineContent":[{"text":"The service throws whatever ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":" throws — ","type":"text"},{"type":"codeVoice","code":"ErrorCode.networkError"},{"text":", ","type":"text"},{"type":"codeVoice","code":".offlineConnectionError"},{"text":", configuration errors, etc. The plugin catches the error and dispatches ","type":"text"},{"type":"codeVoice","code":".refreshFailed(message)"},{"text":". Read ","type":"text"},{"type":"codeVoice","code":"store.paywall.error"},{"text":" from your paywall view to surface a retry affordance:","type":"text"}],"type":"paragraph"},{"code":["if let error = store.paywall.error {","    Text(error)","        .foregroundStyle(.red)","    Button(\"Retry\") {","        store.send(.paywall(.refreshCustomerInfo))","    }","}"],"type":"codeListing","syntax":"swift"}],"kind":"content"}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice"]}],"kind":"article","abstract":[{"type":"text","text":"Wire "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" into the "},{"code":"SwiduxPaywall","type":"codeVoice"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"title":"Related Documentation"},{"anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"generated":true,"title":"How-to Guides"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"sections":[],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","title":"How to Preview and Test","kind":"article","abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"role":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","kind":"symbol","title":"SwiduxRevenueCatPaywall","abstract":[{"type":"text","text":"RevenueCat adapter for Swidux’s "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":". Implements "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" against "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","kind":"article","abstract":[{"type":"text","text":"How RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":" translates to Swidux’s "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","text":"."}],"role":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","title":"How to Present the UI","kind":"article","abstract":[{"type":"text","text":"Attach the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"role":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","kind":"article","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","kind":"article","title":"Service Reference","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" — the RevenueCat-backed "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that the paywall plugin consumes."}],"type":"topic"}}}