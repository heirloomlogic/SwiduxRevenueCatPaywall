{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[[]]},"topicSections":[{"anchor":"Quickstart","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"],"title":"Quickstart"},{"anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"title":"How-to Guides"},{"anchor":"Reference","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"],"title":"Reference"},{"anchor":"Explanation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"title":"Explanation"},{"anchor":"Service-Layer","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService"],"title":"Service Layer"},{"anchor":"Testing","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"title":"Testing"}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" is the adapter between RevenueCat’s SDK and Swidux’s purchase-agnostic paywall plugin. The plugin owns paywall state (presentation flags, current entitlement, async progress); this package translates RevenueCat’s "},{"code":"CustomerInfo","type":"codeVoice"},{"type":"text","text":" into the "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"type":"text","text":" the plugin expects, and surfaces the live "},{"code":"customerInfoStream","type":"codeVoice"},{"type":"text","text":" so entitlement changes propagate without polling."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Two products ship together:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"}]},{"text":" — ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" (the live ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer) and ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" (a controllable preview \/ test conformer).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"}]},{"text":" — ","type":"text"},{"code":"revenueCatPaywall(isPresented:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter(isPresented:)","type":"codeVoice"},{"text":", drop-in SwiftUI view modifiers that wrap RevenueCatUI with platform-aware presentation, plus a ","type":"text"},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"text":" convenience that composes both.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The flow:"}]},{"code":["View → store.send(.paywall(.request(reason:)))","  → PaywallPlugin sets isPresented = true","  → revenueCatPaywall observes the change, presents RevenueCatUI.PaywallView","  → user purchases → Purchases.shared.customerInfoStream yields a new CustomerInfo","  → RevenueCatPaywallService maps it to EntitlementSnapshot","  → PaywallPlugin reduces .customerInfoUpdated, sets isPro = true","  → store.paywall.isGateSatisfied flips, gated UI unlocks"],"type":"codeListing","syntax":null},{"inlineContent":[{"text":"The plugin and the adapter stay decoupled: the plugin doesn’t know about RevenueCat, and the adapter doesn’t know about your action tree.","type":"text"}],"type":"paragraph"}]}],"kind":"symbol","sections":[],"abstract":[{"type":"text","text":"RevenueCat adapter for Swidux’s "},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":". Implements "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" against "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}],"metadata":{"symbolKind":"module","modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"SwiduxRevenueCatPaywall","externalID":"SwiduxRevenueCatPaywall","roleHeading":"Framework","role":"collection"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","kind":"article","abstract":[{"type":"text","text":"How RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":" translates to Swidux’s "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","