ice"},{"type":"text","text":" because the protected mutable state lives behind that lock."}]},{"type":"heading","text":"Initializer","anchor":"Initializer","level":4},{"type":"codeListing","syntax":"swift","code":["public init(isPro: Bool = false, hasPermanentLicense: Bool = false)"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"isPro"},{"type":"text","text":" — Initial value for "},{"type":"codeVoice","code":"EntitlementSnapshot.isPro"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"hasPermanentLicense"},{"type":"text","text":" — Initial value for "},{"type":"codeVoice","code":"EntitlementSnapshot.hasPermanentLicense"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The values supplied here become the initial snapshot returned by "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":" and the first value yielded by "},{"type":"codeVoice","code":"customerInfoStream()"},{"type":"text","text":"."}]},{"type":"heading","text":"`customerInfo() async throws -> EntitlementSnapshot`","anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the snapshot supplied at init. Updates pushed via "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":" do "},{"inlineContent":[{"type":"text","text":"not"}],"type":"strong"},{"type":"text","text":" change the value returned here. Use this method when a test needs a one-shot fetch independent of the stream."}]},{"type":"heading","text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yields the initial snapshot, then every value passed to "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":". The stream stays open until "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()","isActive":true},{"type":"text","text":" is called."}]},{"type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Each call to this method replaces the active continuation. Only the most recent subscriber receives subsequent "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":" updates. Request the stream once per test or preview."}],"type":"paragraph"}],"name":"Note"},{"type":"heading","text":"`restorePurchases() async throws -> EntitlementSnapshot`","anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot","level":4},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the snapshot supplied at init. Independent of the stream."}]},{"type":"heading","text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)``","anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicesend","level":4},{"type":"codeListing","syntax":"swift","code":["public func send(_ snapshot: EntitlementSnapshot)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pushes a snapshot to the active stream subscriber. No-op if no stream has been requested yet, or if the active stream has been finished."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this to simulate purchase, expiration, or family-share updates during a test."}]},{"type":"heading","text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()``","anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicefinish","level":4},{"type":"codeListing","syntax":"swift","code":["public func finish()"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finishes the active entitlement stream. Iterators terminate cleanly. Subsequent calls to "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":" are no-ops."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this in test teardown or when a preview is done observing entitlement transitions."}]},{"type":"heading","text":"Lifecycle example","anchor":"Lifecycle-example","level":2},{"type":"codeListing","syntax":"swift","code":["let mock = MockRevenueCatPaywallService(isPro: false)","let stream = mock.customerInfoStream()","","var iterator = stream.makeAsyncIterator()","let initial = await iterator.next()  \/\/ EntitlementSnapshot(isPro: false, ...)","","mock.send(EntitlementSnapshot(isPro: true))","let updated = await iterator.next()  \/\/ EntitlementSnapshot(isPro: true, ...)","","mock.finish()","let terminal = await iterator.next()  \/\/ nil — stream finished"]}],"kind":"content"}],"sections":[],"kind":"article","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — a controllable "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer for previews and tests that does not touch "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":"."}],"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"Mock Service Reference","roleHeading":"Article","role":"article"},"va