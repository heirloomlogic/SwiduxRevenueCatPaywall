{"primaryContentSections":[{"content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide walks through the four steps to integrate "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"},{"type":"text","text":" into a Swidux app: add the package, configure RevenueCat, register the plugin, and attach the UI. It is the shortest path from a wired Swidux app to a working paywall. For deeper coverage of any step, follow the linked how-tos."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This package assumes you already use Swidux. If you don’t, work through Swidux’s own getting-started guide first."}]},{"level":2,"text":"Add the Package","type":"heading","anchor":"Add-the-Package"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Xcode:"}]},{"text":" File > Add Package Dependencies, paste ","type":"text"},{"code":"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":". Add the products you need:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":" — the ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" implementation and mock.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" — adds the ","type":"text"},{"code":"PaywallSheet","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterSheet","type":"codeVoice"},{"text":" views (depends on RevenueCatUI).","type":"text"}]}]}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Package.swift:"}]}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),"]},{"type":"codeListing","syntax":"swift","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"]},{"level":2,"text":"Configure RevenueCat at launch","type":"heading","anchor":"Configure-RevenueCat-at-launch"},{"inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" calls into ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":". Configure the SDK before constructing the store:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"]},{"level":2,"text":"Register the paywall plugin","type":"heading","anchor":"Register-the-paywall-plugin"},{"inlineContent":[{"text":"Pass ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":" in your "},{"type":"codeVoice","code":"Store.configured()"},{"type":"text","text":" factory:"}],"type":"paragraph"},{"code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:"}],"type":"paragraph"},{"code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"text":"Gate features by reading ","type":"text"},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"text":". See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"text":" for the full plugin lifecycle.","type":"text"}],"type":"paragraph"},{"text":"Attach the UI","anchor":"Attach-the-UI","type":"heading","level":2},{"inlineContent":[{"type":"text","text":"Add "},{"code":"PaywallSheet","type":"codeVoice"},{"type":"text","text":" and "},{"code":"CustomerCenterSheet","type":"codeVoice"},{"type":"text","text":" to a root view, driven by paywall state:"}],"type":"paragraph"},{"code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Trigger the paywall from a gated feature with "},{"code":".paywall(.request(reason:))","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},{"type":"text","text":" for manual wiring, customer-center triggering, and dismiss semantics."}],"type":"paragraph"},{"text":"Next Steps","anchor":"Next-Steps","type":"heading","level":2},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"text":" — Detailed walkthrough of the service lifecycle and error handling.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","type":"reference","isActive":true},{"type":"text","text":" — Add a lifetime entitlement alongside the subscription."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"reference","isActive":true},{"type":"text","text":" — Drive entitlement state from previews and tests."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","type":"reference","isActive":true},{"type":"text","text":" — Wire the bundled sheets and modifier."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","type":"reference","isActive":true},{"type":"text","text":" — Why iOS and macOS behave differently."}]}]},{"content":[{"type":"paragraph