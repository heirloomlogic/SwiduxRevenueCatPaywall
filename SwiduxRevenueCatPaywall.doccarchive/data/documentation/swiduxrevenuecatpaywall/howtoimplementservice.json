{"primaryContentSections":[{"content":[{"level":2,"text":"Overview","type":"heading","anchor":"Overview"},{"inlineContent":[{"type":"text","text":"This guide takes you from a wired Swidux app with a paywall slice to a live RevenueCat-backed entitlement pipeline. It covers SDK configuration, plugin registration, observation lifecycle, and refresh\/restore flows."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For the API-level reference of the service, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference"},{"type":"text","text":". For the entitlement mapping rules, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"},{"type":"text","text":". For the upstream plugin contract — actions, state shape, dispatch semantics — see Swidux’s "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Add a Paywall"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiduxPaywall Reference"}]},{"type":"text","text":"; this guide does not repeat that material."}],"type":"paragraph"},{"level":2,"text":"Before you start","type":"heading","anchor":"Before-you-start"},{"inlineContent":[{"type":"text","text":"This guide assumes:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"You have a wired Swidux app — "},{"type":"codeVoice","code":"AppState"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppAction"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppReducer"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppStore"},{"type":"text","text":" exist, and the store is in the SwiftUI environment."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Your "},{"type":"codeVoice","code":"AppState"},{"type":"text","text":" already has a "},{"type":"codeVoice","code":"paywall: PaywallState"},{"type":"text","text":" slice and your "},{"type":"codeVoice","code":"AppAction"},{"type":"text","text":" has a "},{"type":"codeVoice","code":".paywall(PaywallAction)"},{"type":"text","text":" case. If not, follow Swidux’s "},{"type":"emphasis","inlineContent":[{"text":"Add a Paywall","type":"text"}]},{"type":"text","text":" guide first."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You have a RevenueCat project, an API key, and at least one entitlement identifier configured in the RevenueCat dashboard."}],"type":"paragraph"}]}]},{"anchor":"Step-1-Add-the-dependencies","type":"heading","text":"Step 1: Add the dependencies","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add both Swift packages to your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/Swidux\", branch: \"main\"),","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),","],"]},{"type":"paragraph","inlineContent":[{"text":"Add the products you need to your app target:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[".target(","    name: \"MyApp\",","    dependencies: [","        .product(name: \"Swidux\", package: \"Swidux\"),","        .product(name: \"SwiduxPaywall\", package: \"Swidux\"),","        .product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),","        .product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),","    ]",")"]},{"inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" is optional — drop it if you don’t need the bundled sheets.","type":"text"}],"type":"paragraph"},{"text":"Step 2: Configure RevenueCat at launch","anchor":"Step-2-Configure-RevenueCat-at-launch","type":"heading","level":2},{"inlineContent":[{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" calls into "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":". Configure the SDK before constructing the store:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"]},{"style":"important","content":[{"inlineContent":[{"text":"","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":" traps if used unconfigured. Configure it before anything that constructs ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":", including SwiftUI previews — guard preview-only code with ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" instead.","type":"text"}],"type":"paragraph"}],"type":"aside","name":"Important"},{"text":"Step 3: Construct the service","anchor":"Step-3-Construct-the-service","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Create the service with the entitlement identifier you set up in the RevenueCat dashboard:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(entitlementID: \"pro\")"]},{"type":"paragraph","inlineContent":[{"text":"If your app sells a separate lifetime SKU alongside a subscription, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","isActive":true,"type":"reference"},{"text":" for the dual-entitlement form.","type":"text"}]},{"text":"Step 4: Register the paywall plugin","anchor":"Step-4-Register-the-paywall-plugin","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Pass the service to ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":" when wiring the store:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ AppStore.swift","import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The plugin owns reducing for ","type":"text"},{"code":".paywall","type":"codeVoice"},{"text":" actions; your root reducer should fall through with ","type":"text"},{"code":"return nil","type":"codeVoice"},{"text":" for that case.","type":"text"}]},{"text":"Step 5: Observe customer info on launch","anchor":"Step-5-Observe-customer-info-on-launch","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Start the entitlement stream once, on the root view:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"]},{"type":"paragraph","inlineContent":[{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" returns a long-lived effect that consumes ","type":"text"},{"code":"RevenueCatPaywallService.customerInfoStream()","type":"codeVoice"},{"text":". Every snapshot the service yields flows through ","type":"text"},{"code":".customerInfoUpdated","type":"codeVoice"},{"text":" and updates ","type":"text"},{"code":"store.paywall.isPro","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"hasPermanentLicense","type":"codeVoice"},{"text":". The effect lives for the duration of the stream, so the store stays in sync with RevenueCat without polling.","type":"text"}]},{"text":"Step 6: Gate features","anchor":"Step-6-Gate-features","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Read ","type":"text"},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"text":" before running gated work. If it’s ","type":"text"},{"code":"false","type":"codeVoice"},{"text":", dispatch ","type":"text"},{"code":".request(reason:)","type":"codeVoice"},{"text":" instead:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isGateSatisfied"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" when the user holds an active pro subscription ","type":"text"},{"type":"strong","inlineContent":[{"type":"text","text":"or"}]},{"text":" a permanent license — feature code does not need to know which.","type":"text"}]},{"text":"Step 7: Wire the UI","anchor":"Step-7-Wire-the-UI","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"To present ","type":"text"},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"text":" and the customer center, attach the bundled sheets to a root view. See ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","type":"reference"},{"text":".","type":"text"}]},{"text":"Step 8: Restore purchases","anchor":"Step-8-Restore-purchases","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Add a restore button to your paywall UI. Reflect ","type":"text"},{"type":"codeVoice","code":"store.paywall.isLoading"},{"text":" to disable it while the call is in flight:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"]},{"type":"paragraph","inlineContent":[{"text":"The plugin calls ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.restorePurchases()"},{"text":", which forwards to ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.restorePurchases()"},{"text":". On success the resulting snapshot flows through ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" and updates the gate. On failure, ","type":"text"},{"type":"codeVoice","code":"store.paywall.error"},{"text":" is set.","type":"text"}]},{"text":"Step 9: Handle errors","anchor":"Step-9-Handle-errors","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The service throws whatever "},{"type":"codeVoice","code":"Purchases.shared"},{"text":" throws — ","type":"text"},{"type":"codeVoice","code":"ErrorCode.networkError"},{"text":", ","type":"text"},{"type":"codeVoice","code":".offlineConnectionError"},{"text":", configuration errors, etc. The plugin catches the error and dispatches ","type":"text"},{"code":".refreshFailed(message)","type":"codeVoice"},{"type":"text","text":". Read "},{"code":"store.paywall.error","type":"codeVoice"},{"type":"text","text":" from your paywall view to surface a retry affordance:"}]},{"type":"codeListing","syntax":"swift","code":["if let error = store.paywall.error {","    Text(error)","        .foregroundStyle(.red)","    Button(\"Retry\") {","        store.send(.paywall(.refreshCustomerInfo))","    }","}"]}],"kind":"content"}],"kind":"article","identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","interfaceLanguage":"swift"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice"]}],"abstract":[{"text":"Wire ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" into the ","type":"text"},{"type":"codeVoice","code":"SwiduxPaywall"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article","title":"How to Implement the Service"},"schemaVersion":{"patch":0,"minor":3,"major":0},"seeAlsoSections":[{"anchor":"Related-Documentation","title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"]},{"anchor":"How-to-Guides","generated":true,"title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"role":"article","kind":"article","abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"role":"article","kind":"article","abstract":[{"text":"Attach ","type":"text"},{"code":"PaywallSheet","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterSheet","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","title":"How to Present the UI","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"topic","title":"How to Preview and Test","kind":"article","role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"title":"SwiduxRevenueCatPaywall","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" for drop-in ","type":"text"},{"type":"codeVoice","code":"PaywallView"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}],"kind":"symbol","role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"title":"Service Reference","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","abstract":[{"text":"API reference for ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" — the RevenueCat-backed ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer that the paywall plugin consumes.","type":"text"}],"kind":"article","role":"article"}}}