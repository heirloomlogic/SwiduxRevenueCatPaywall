{"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" is a "},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer that tracks a ","type":"text"},{"inlineContent":[{"type":"text","text":"current"}],"type":"emphasis"},{"text":" snapshot the way the real service reflects RevenueCat’s state: ","type":"text"},{"code":"send(_:)","type":"codeVoice"},{"text":" updates it and pushes it through the stream, ","type":"text"},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":" return it, and "},{"type":"codeVoice","code":"finish()"},{"text":" tears the stream down. Plug it into the same ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":" you use in production. Drive entitlement transitions from your test or preview body.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the API reference, see ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","isActive":true},{"text":".","type":"text"}]},{"anchor":"Why-a-different-mock-from-SwiduxPaywalls","type":"heading","text":"Why a different mock from SwiduxPaywall’s","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiduxPaywall"},{"text":" ships its own ","type":"text"},{"type":"codeVoice","code":"MockPaywallService"},{"text":" whose stream finishes after the initial yield. That works for static “Pro” and “Free” previews but cannot model purchase, refund, or family-share transitions as a sequence. ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" keeps the stream open until you call ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":", which lets a single test verify the store reacts correctly to an ","type":"text"},{"inlineContent":[{"type":"text","text":"order"}],"type":"emphasis"},{"type":"text","text":" of snapshots."}]},{"type":"paragraph","inlineContent":[{"text":"When you only need a static state (one snapshot, one render pass), either mock works. When you need a sequence, use this one.","type":"text"}]},{"anchor":"Step-1-Make-the-service-injectable","type":"heading","text":"Step 1: Make the service injectable","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Plumb the service through your "},{"type":"codeVoice","code":"Store.configured()"},{"type":"text","text":" factory so previews and tests can override it:"}]},{"code":["extension Store where State == AppState, Action == AppAction {","    static func configured(","        paywallService: any PaywallService = RevenueCatPaywallService(entitlementID: \"pro\")","    ) -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: paywallService","            )","        )","        return Store(initialState: AppState(), reducer: AppReducer().reduce, plugins: plugins)","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The default keeps the live RevenueCat path for app launch. Previews and tests pass an override."}],"type":"paragraph"},{"anchor":"Step-2-Static-previews-pick-a-state","text":"Step 2: Static previews — pick a state","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Use the configured-state form when one snapshot is enough:"}],"type":"paragraph"},{"code":["#Preview(\"Free\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService()","    )","    return ContentView().environment(store)","}","","#Preview(\"Pro\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(isPro: true)","    )","    return ContentView().environment(store)","}","","#Preview(\"Lifetime\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(hasPermanentLicense: true)","    )","    return ContentView().environment(store)","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Each preview gets its own store; the mock’s initial snapshot flows through "},{"code":".observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" and updates the gate before the first render."}],"type":"paragraph"},{"anchor":"Step-3-Driving-transitions-in-a-test","text":"Step 3: Driving transitions in a test","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"When the test cares about a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"sequence"}]},{"type":"text","text":" of states — for example, the gate flipping from "},{"code":"false","type":"codeVoice"},{"type":"text","text":" to "},{"code":"true","type":"codeVoice"},{"type":"text","text":" after a purchase — use the streaming form:"}],"type":"paragraph"},{"code":["@Test(\"Store updates when entitlement transitions to pro\")","func storeReactsToProPurchase() async {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    store.send(.paywall(.observeCustomerInfo))","    await Task.yield()","    #expect(store.paywall.isPro == false)","","    mock.send(EntitlementSnapshot(isPro: true))","    await Task.yield()","    #expect(store.paywall.isPro)","","    mock.finish()","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Each "},{"code":"send(_:)","type":"codeVoice"},{"type":"text","text":" makes the snapshot current and pushes it through the active stream subscriber, which in this case is the plugin’s "},{"code":"observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" effect. The store’s reducer applies "},{"code":".customerInfoUpdated","type":"codeVoice"},{"type":"text","text":", the observer tree fires for changed properties, and the assertion sees the new value. Because "},{"code":"customerInfo()","type":"codeVoice"},{"type":"text","text":" also returns the sent snapshot, the refresh the plugin dispatches when the paywall is dismissed sees the purchased state too — the gate never regresses to the init-time value mid-test."}],"type":"paragraph"},{"content":[{"inlineContent":[{"type":"text","text":""},{"code":"customerInfoStream()","type":"codeVoice"},{"type":"text","text":" replaces its continuation on every call. If your test requests the stream more than once (rare — "},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" is dispatched once), the previous stream finishes — its ","type":"text"},{"type":"codeVoice","code":"for await"},{"text":" loop terminates instead of hanging — and only the most recent subscriber receives ","type":"text"},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" updates."}],"type":"paragraph"}],"type":"aside","name":"Note","style":"note"},{"type":"heading","anchor":"Step-4-Driving-transitions-in-a-preview","text":"Step 4: Driving transitions in a preview","level":2},{"inlineContent":[{"type":"text","text":"Previews can drive transitions too — useful for verifying paywall sheet copy across states without running the app:"}],"type":"paragraph"},{"code":["#Preview(\"Purchase flow\") {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    return ContentView()","        .environment(store)","        .task {","            store.send(.paywall(.observeCustomerInfo))","            try? await Task.sleep(for: .seconds(2))","            mock.send(EntitlementSnapshot(isPro: true))","        }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"text":"The preview starts in the free state, runs the gated UI for two seconds, then transitions to pro — letting you eyeball both copy paths in one preview pane.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Step 5: Simulating failures","anchor":"Step-5-Simulating-failures","type":"heading"},{"inlineContent":[{"text":"Set ","type":"text"},{"code":"customerInfoError","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"restoreError","type":"codeVoice"},{"text":" to make the corresponding call throw — the plugin dispatches ","type":"text"},{"code":".refreshFailed","type":"codeVoice"},{"text":", sets ","type":"text"},{"code":"store.paywall.error","type":"codeVoice"},{"text":", and your retry UI becomes testable:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Test(\"Refresh failure surfaces an error the UI can retry from\")","func refreshFailureSurfacesError() async {","    struct Offline: Error {}","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    mock.customerInfoError = Offline()","    store.send(.paywall(.refreshCustomerInfo))","    await Task.yield()","    #expect(store.paywall.error != nil)","","    mock.customerInfoError = nil","    store.send(.paywall(.refreshCustomerInfo))","    await Task.yield()","    #expect(store.paywall.error == nil)","}"]},{"inlineContent":[{"text":"The same hooks exercise ","type":"text"},{"code":"ResilientPaywallService","type":"codeVoice"},{"text":"’s last-known-good fallback: wrap the mock, make ","type":"text"},{"code":"customerInfo()","type":"codeVoice"},{"text":" throw, and assert the cached entitlement holds.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Step 6: Tear the stream down","anchor":"Step-6-Tear-the-stream-down","type":"heading"},{"inlineContent":[{"type":"text","text":"Call "},{"code":"finish()","type":"codeVoice"},{"type":"text","text":" at the end of a test to terminate the stream cleanly:"}],"type":"paragraph"},{"code":["mock.finish()"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"This causes any pending "},{"type":"codeVoice","code":"for await … in stream"},{"type":"text","text":" to exit. Without it, the consuming "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" may stay alive until the test runner reaps it. Tests that own the mock for their full duration can skip this — Swift Testing tears down the task tree when the test exits — but it’s a clean habit."}],"type":"paragraph"}]}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"],"traits":[{"interfaceLanguage":"swift"}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"kind":"article","seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"anchor":"Related-Documentation"},{"title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"generated":true,"anchor":"How-to-Guides"}],"metadata":{"role":"article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Preview and Test","roleHeading":"Article"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Drive entitlement state from SwiftUI previews and tests with ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" — no RevenueCat SDK call required.","type":"text"}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","kind":"symbol","url":"\/documentation\/swiduxrevenuecatpaywall","title":"SwiduxRevenueCatPaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":". Implements "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" against "},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"type":"codeVoice","code":"PaywallView"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockServiceReference":{"url":"\/documentation\/swiduxrevenuecatpaywall\/mockservicereference","title":"Mock Service Reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","kind":"article","type":"topic","abstract":[{"text":"API reference for ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" — a controllable ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":".","type":"text"}],"role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"type":"topic","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","abstract":[{"text":"Wire ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" into the ","type":"text"},{"type":"codeVoice","code":"SwiduxPaywall"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"title":"How to Implement the Service"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"type":"topic","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","abstract":[{"text":"Attach the ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"text":" view modifiers from ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" to a root view, driven by ","type":"text"},{"type":"codeVoice","code":"PaywallState"},{"text":".","type":"text"}],"title":"How to Present the UI"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockRevenueCatPaywallService":{"navigatorTitle":[{"kind":"identifier","text":"MockRevenueCatPaywallService"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MockRevenueCatPaywallService"}],"role":"symbol","abstract":[{"type":"codeVoice","code":"PaywallService"},{"text":" conformer for previews and tests with a controllable entitlement stream.","type":"text"}],"type":"topic","kind":"symbol","title":"MockRevenueCatPaywallService","url":"\/documentation\/swiduxrevenuecatpaywall\/mockrevenuecatpaywallservice"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"title":"How to Add a Permanent License"}}}