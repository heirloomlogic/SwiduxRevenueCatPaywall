xt":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","role":"article","type":"topic","title":"Entitlement Mapping"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"title":"Service Reference","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","kind":"article","role":"article","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" — the RevenueCat-backed "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that the paywall plugin consumes."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","type":"topic"}}}