/SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" for drop-in ","type":"text"},{"type":"codeVoice","code":"PaywallView"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}],"kind":"symbol","role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License","type":"topic"}}}