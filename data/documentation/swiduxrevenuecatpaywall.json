{"topicSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"],"title":"Quickstart","anchor":"Quickstart"},{"title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"anchor":"How-to-Guides"},{"title":"Reference","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"],"anchor":"Reference"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"title":"Explanation","anchor":"Explanation"},{"title":"Service Layer","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService"],"anchor":"Service-Layer"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"title":"Testing","anchor":"Testing"}],"kind":"symbol","hierarchy":{"paths":[[]]},"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"externalID":"SwiduxRevenueCatPaywall","title":"SwiduxRevenueCatPaywall","symbolKind":"module","roleHeading":"Framework","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"collection"},"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","interfaceLanguage":"swift"},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"},{"type":"text","text":" is the adapter between RevenueCat’s SDK and Swidux’s purchase-agnostic paywall plugin. The plugin owns paywall state (presentation flags, current entitlement, async progress); this package translates RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","text":" the plugin expects, and surfaces the live "},{"type":"codeVoice","code":"customerInfoStream"},{"type":"text","text":" so entitlement changes propagate without polling."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Two products ship together:"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}]},{"type":"text","text":" — "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" (the live "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer) and "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" (a controllable preview \/ test conformer)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"}]},{"type":"text","text":" — "},{"type":"codeVoice","code":"revenueCatPaywall(isPresented:)"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter(isPresented:)","type":"codeVoice"},{"text":", drop-in SwiftUI view modifiers that wrap RevenueCatUI with platform-aware presentation, plus a ","type":"text"},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"text":" convenience that composes both.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"The flow:"}],"type":"paragraph"},{"type":"codeListing","syntax":null,"code":["View → store.send(.paywall(.request(reason:)))","  → PaywallPlugin sets isPresented = true","  → revenueCatPaywall observes the change, presents RevenueCatUI.PaywallView","  → user purchases → Purchases.shared.customerInfoStream yields a new CustomerInfo","  → RevenueCatPaywallService maps it to EntitlementSnapshot","  → PaywallPlugin reduces .customerInfoUpdated, sets isPro = true","  → store.paywall.isGateSatisfied flips, gated UI unlocks"]},{"inlineContent":[{"type":"text","text":"The plugin and the adapter stay decoupled: the plugin doesn’t know about RevenueCat, and the adapter doesn’t know about your action tree."}],"type":"paragraph"}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"abstract":[{"type":"text","text":"RevenueCat adapter for Swidux’s "},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" against "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/UIComponentsReference":{"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/uicomponentsreference","abstract":[{"text":"API reference for the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers — the SwiftUI surface of ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":".","type":"text"}],"title":"UI Components Reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference","role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/RevenueCatPaywallService":{"kind":"symbol","type":"topic","fragments":[{"kind":"keyword","text":"struct"},{"kind":"text","text":" "},{"kind":"identifier","text":"RevenueCatPaywallService"}],"url":"\/documentation\/swiduxrevenuecatpaywall\/revenuecatpaywallservice","abstract":[{"code":"PaywallService","type":"codeVoice"},{"text":" conformer backed by RevenueCat’s ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":".","type":"text"}],"title":"RevenueCatPaywallService","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService","role":"symbol","navigatorTitle":[{"kind":"identifier","text":"RevenueCatPaywallService"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"abstract":[{"text":"Wire ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" into the ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","title":"How to Implement the Service"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/GettingStarted":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted","title":"Getting Started with SwiduxRevenueCatPaywall","abstract":[{"text":"Add the package, configure RevenueCat, register the paywall plugin, and present the bundled sheets.","type":"text"}],"url":"\/documentation\/swiduxrevenuecatpaywall