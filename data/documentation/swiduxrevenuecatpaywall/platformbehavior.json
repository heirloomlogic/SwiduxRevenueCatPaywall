{"schemaVersion":{"major":0,"patch":0,"minor":3},"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article","title":"Platform Behavior"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"abstract":[{"text":"Why the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" modifiers present differently on iOS and macOS, and what is hard-coded.","type":"text"}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"abstract":[{"text":"The ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" documentation provides the matching API reference for the modifiers described here.","type":"text"}],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"generated":true,"title":"Explanation","anchor":"Explanation"}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","level":2,"type":"heading"},{"inlineContent":[{"text":"The bundled UI is intentionally opinionated. Each modifier picks the platform-appropriate presentation so consumers don’t have to repeat the conditional compilation themselves, and so the dispatch flow stays symmetric across platforms — the same ","type":"text"},{"type":"codeVoice","code":".paywall(.dismiss)"},{"text":" action fires from a ","type":"text"},{"type":"codeVoice","code":"fullScreenCover"},{"text":" on iOS and from a sheet on macOS.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This article explains the reasoning behind those choices and what is fixed versus configurable.","type":"text"}],"type":"paragraph"},{"text":"revenueCatPaywall","anchor":"revenueCatPaywall","level":2,"type":"heading"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Presentation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"fullScreenCover","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A subscription paywall is a primary moment, not an interrupt. "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" keeps the UI immersive, prevents accidental gesture-dismiss, and matches App Store conventions."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"macOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"sheet","type":"codeVoice"},{"type":"text","text":" with "},{"code":"frame(minWidth: 400, minHeight: 600)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac sheets do not expand to fill the parent window. Without an explicit minimum size the paywall would render too small to legibly show plan options. The 400×600 minimum is roughly the size RevenueCatUI’s templates assume."}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"text":"The minimum frame is hard-coded; it is not exposed as a parameter. If your paywall layout needs more room on macOS, wrap the modified view in a parent that imposes a larger frame, or use ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":" directly inside a custom ","type":"text"},{"type":"codeVoice","code":"sheet"},{"text":" modifier.","type":"text"}],"type":"paragraph"},{"text":"revenueCatCustomerCenter","anchor":"revenueCatCustomerCenter","level":2,"type":"heading"},{"rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Presentation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"sheet","type":"codeVoice"},{"type":"text","text":" with "},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"RevenueCatUI ships a customer center on iOS only. A non-fullscreen "},{"code":"sheet","type":"codeVoice"},{"type":"text","text":" is appropriate because customer-center actions are administrative, not part of a purchase flow."}],"type":"paragraph"}]],[[{"inlineContent":[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"strong"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Opens "},{"code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions","type":"codeVoice"},{"type":"text","text":" and immediately fires "},{"code":"onDismiss","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RevenueCatUI does not ship a customer center on macOS, and the system has no equivalent in-app surface. The App Store subscription management page is what users expect on the Mac, so the sheet hands off to it and clears its own presentation state immediately.","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"inlineContent":[{"type":"text","text":"The macOS branch clears the binding and fires "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" synchronously after "},{"code":"NSWorkspace.shared.open","type":"codeVoice"},{"text":" so ","type":"text"},{"code":"PaywallState.isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":" does not get stuck "},{"code":"true","type":"codeVoice"},{"type":"text","text":". The user returns from App Store to find the app’s UI in its idle state."}],"type":"paragraph"},{"text":"Why no platform-override hooks","anchor":"Why-no-platform-override-hooks","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Both modifiers are deliberately parameter-light: an "},{"type":"codeVoice","code":"isPresented: Binding<Bool>"},{"type":"text","text":" and an optional "},{"type":"codeVoice","code":"onDismiss: () -> Void"},{"type":"text","text":". There is no "},{"type":"codeVoice","code":"paywallStyle:"},{"type":"text","text":" or "},{"code":"presentationKind:","type":"codeVoice"},{"type":"text","text":" parameter."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reasoning: any consumer that needs to deviate from the chosen presentation already has the underlying RevenueCatUI types ("},{"code":"PaywallView","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":") and SwiftUI’s full presentation surface (","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":", ","type":"text"},{"type":"codeVoice","code":"fullScreenCover"},{"text":", ","type":"text"},{"type":"codeVoice","code":"popover"},{"type":"text","text":", custom containers). The bundled modifiers exist to handle the 95% case in one line — when the 5% case applies, drop down to RevenueCatUI directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This package does not try to be the complete paywall-UI library. It is the "},{"inlineContent":[{"type":"text","text":"integration layer"}],"type":"emphasis"},{"type":"text","text":" that makes the common case trivial."}],"type":"paragraph"},{"text":"What is configurable","anchor":"What-is-configurable","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The configurable surface lives in "},{"code":"RevenueCatUI","type":"codeVoice"},{"text":" and on the paywall plugin:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"inlineContent":[{"text":"Paywall content, copy, and template","type":"text"}],"type":"strong"},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"text":" renders whichever offering and template the dashboard returns.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Customer-center labels, sections, and actions"}]},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"text":" renders whichever configuration the dashboard returns.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Presentation triggering"}]},{"text":" — driven by the plugin via ","type":"text"},{"code":"PaywallState.isPresented","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"isCustomerCenterPresented","type":"codeVoice"},{"text":". Your code chooses ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"when"}]},{"text":" to set them via ","type":"text"},{"code":".request(reason:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":".presentCustomerCenter","type":"codeVoice"},{"text":" actions.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Dismiss behavior"}]},{"text":" — your ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" closures dispatch the matching paywall actions. Replace them if you need analytics hooks or cleanup beyond the default flow.","type":"text"}],"type":"paragraph"}]}]}]}],"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/platformbehavior"]}],"sections":[],"kind":"article","references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"type":"topic","title":"SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","kind":"symbol","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"Entitlement Mapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"How to Present the UI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","role":"article"}}}