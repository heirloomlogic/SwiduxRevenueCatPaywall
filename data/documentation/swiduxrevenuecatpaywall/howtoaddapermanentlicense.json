{"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"]},{"title":"How-to Guides","anchor":"How-to-Guides","generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"text":"Many apps offer two ways to buy: a recurring pro subscription and a one-time lifetime purchase. RevenueCat models both as entitlements; ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" checks each independently and surfaces them as the two flags on ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"isPro"},{"type":"text","text":" — active subscription."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"hasPermanentLicense"},{"type":"text","text":" — active lifetime entitlement."}],"type":"paragraph"}]}]},{"inlineContent":[{"text":"The paywall plugin’s ","type":"text"},{"code":"isGateSatisfied","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"isPro || hasPermanentLicense","type":"codeVoice"},{"text":", so feature code keeps a single check while UI can branch on the underlying flags when it needs to.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For the entitlement-mapping rules and edge cases, see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"Before-you-start","type":"heading","text":"Before you start","level":2},{"inlineContent":[{"text":"This guide assumes:","type":"text"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"You have completed "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"You have configured "},{"type":"strong","inlineContent":[{"type":"text","text":"two"}]},{"type":"text","text":" entitlements in the RevenueCat dashboard — typically "},{"type":"codeVoice","code":"pro"},{"type":"text","text":" for the subscription and "},{"type":"codeVoice","code":"lifetime"},{"type":"text","text":" for the one-time purchase. The identifiers are arbitrary; only the strings need to match what you pass into the service."}],"type":"paragraph"}]}]},{"anchor":"Step-1-Pass-the-second-identifier","type":"heading","text":"Step 1: Pass the second identifier","level":2},{"inlineContent":[{"text":"Replace the single-entitlement init with the two-arg form:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(","    entitlementID: \"pro\",","    permanentLicenseEntitlementID: \"lifetime\"",")"],"syntax":"swift"},{"inlineContent":[{"text":"Both entitlements are now checked on every ","type":"text"},{"code":"customerInfo()","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"customerInfoStream()"},{"type":"text","text":" yield, and "},{"type":"codeVoice","code":"restorePurchases()"},{"text":" call. The active state of ","type":"text"},{"code":"pro","type":"codeVoice"},{"text":" flows into ","type":"text"},{"type":"codeVoice","code":"EntitlementSnapshot.isPro"},{"type":"text","text":"; the active state of "},{"code":"lifetime","type":"codeVoice"},{"type":"text","text":" flows into "},{"code":"hasPermanentLicense","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The two flags are independent. A user with both active gets both flags set; a user with only one active gets only that flag set."}],"type":"paragraph"},{"anchor":"Step-2-Wire-the-service-into-the-plugin","type":"heading","text":"Step 2: Wire the service into the plugin","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as the single-entitlement case — the plugin doesn’t need to know about the second identifier:"}]},{"code":["plugins.register(","    PaywallPlugin<AppState, AppAction>(","        state: \\.paywall,","        action: AppAction.paywall,","        extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","        service: RevenueCatPaywallService(","            entitlementID: \"pro\",","            permanentLicenseEntitlementID: \"lifetime\"","        )","    )",")"],"type":"codeListing","syntax":"swift"},{"type":"heading","anchor":"Step-3-Decide-whether-feature-code-needs-to-branch","level":2,"text":"Step 3: Decide whether feature code needs to branch"},{"type":"paragraph","inlineContent":[{"text":"For most gated features, keep using ","type":"text"},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if store.paywall.isGateSatisfied { … }"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This stays correct whether the user has a subscription or a lifetime license, and works identically in apps that don’t sell a lifetime SKU."}]},{"anchor":"Step-4-Branch-in-UI-when-copy-must-differ","level":2,"text":"Step 4: Branch in UI when copy must differ","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If the paywall sheet should be hidden for lifetime customers (so they’re not pestered to subscribe), or if the customer-center entry should be relabeled, branch on the underlying flag:"}]},{"code":["if store.paywall.hasPermanentLicense {","    Text(\"Lifetime member — thank you!\")","} else if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","} else {","    Button(\"Upgrade\") {","        store.send(.paywall(.request(reason: \"upgrade-prompt\")))","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Lifetime users typically have nothing to manage in App Store \/ Settings. Hiding the customer-center button for them avoids dead-end taps.","type":"text"}]},{"anchor":"When-to-skip-the-second-identifier","type":"heading","text":"When to skip the second identifier","level":2},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"type":"codeVoice","code":"nil"},{"type":"text","text":" (or omit the parameter) if your app has no lifetime SKU:"}]},{"code":["RevenueCatPaywallService(entitlementID: \"pro\")"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"hasPermanentLicense"},{"type":"text","text":" then stays "},{"type":"codeVoice","code":"false"},{"type":"text","text":" regardless of any entitlements RevenueCat reports — even if the dashboard accidentally has a "},{"type":"codeVoice","code":"lifetime"},{"text":" entitlement that the service is not configured to check. See the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Lifetime entitlement is ignored when no permanent-license ID is configured","type":"text"}]},{"type":"text","text":" test case for the precise behavior."}]}],"kind":"content"}],"sections":[],"kind":"article","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"metadata":{"title":"How to Add a Permanent License","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","kind":"article","title":"Service Reference","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" — the RevenueCat-backed "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that the paywall plugin consumes."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","kind":"article","abstract":[{"type":"text","text":"How RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":" translates to Swidux’s "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","text":"."}],"role":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"i