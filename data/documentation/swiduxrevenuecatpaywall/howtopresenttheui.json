{"abstract":[{"type":"text","text":"Attach the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" ships three view modifiers that wrap RevenueCatUI’s surfaces with platform-aware presentation. Each is bound to "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":": presentation flags drive visibility, and the bindings dispatch matching paywall actions back through the store on dismissal. There is no local sheet state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For platform behavior details (iOS "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" vs macOS sheet sizing, App Store deep link on macOS), see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","isActive":true},{"type":"text","text":"."}]},{"type":"heading","text":"Before you start","anchor":"Before-you-start","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide assumes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"You have completed ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference"},{"text":". The plugin is registered and ","type":"text"},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" runs on launch.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Your app target depends on the ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" product:","type":"text"}]}]}]},{"type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift"},{"type":"heading","text":"Step 1: Attach both sheets to a root view","anchor":"Step-1-Attach-both-sheets-to-a-root-view","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest wiring uses the "},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"type":"text","text":" modifier — one call, both sheets, both dismissals:"}]},{"type":"codeListing","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The closure receives a "},{"code":"PaywallAction","type":"codeVoice"},{"type":"text","text":" ("},{"code":".dismiss","type":"codeVoice"},{"type":"text","text":" or "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":") and lifts it into your root action. Place the modifier on the topmost view that should host both sheets."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both paywall modifiers also accept "},{"code":"displayCloseButton:","type":"codeVoice"},{"type":"text","text":" (default "},{"code":"true","type":"codeVoice"},{"type":"text","text":"). The default presentation has no other way out — see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","isActive":true},{"type":"text","text":" before turning it off."}]},{"type":"heading","text":"Step 2: Trigger the paywall from a feature","anchor":"Step-2-Trigger-the-paywall-from-a-feature","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dispatch "},{"code":".request(reason:)","type":"codeVoice"},{"type":"text","text":" with a short identifier describing why you’re asking. "},{"code":"PaywallState.requestedReason","type":"codeVoice"},{"type":"text","text":" stores the value so the sheet (or analytics) can tailor its copy:"}]},{"type":"codeListing","code":["Button(\"Export PDF\") {","    store.send(.paywall(.request(reason: \"export-pdf\")))","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin sets "},{"code":"PaywallState.isPresented = true","type":"codeVoice"},{"type":"text","text":". The "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" modifier observes the change and presents "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"heading","text":"Step 3: Trigger the customer center","anchor":"Step-3-Trigger-the-customer-center","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Existing subscribers manage their subscription through the customer center. Surface a button that dispatches "},{"code":".presentCustomerCenter","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":["if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"type":"text","text":" modifier presents "},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"type":"text","text":" on iOS. On macOS it opens the system App Store subscriptions URL and immediately fires "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" (RevenueCatUI does not ship a customer center on macOS — see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","isActive":true},{"type":"text","text":")."}]},{"type":"heading","text":"Step 4: Manual wiring (optional)","anchor":"Step-4-Manual-wiring-optional","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need only one sheet, or you want to interleave other modifiers between them, attach the primitive modifiers directly. Each takes a real "},{"code":"Binding<Bool>","type":"codeVoice"},{"type":"text","text":"; build it with a "},{"code":"set:","type":"codeVoice"},{"type":"text","text":" that dispatches the matching dismiss action when SwiftUI clears the flag:"}]},{"type":"codeListing","code":["ContentView()","    .revenueCatPaywall(","        isPresented: Binding(","            get: { store.paywall.isPresented },","            set: { if !$0 { store.send(.paywall(.dismiss)) } }","        )","    )","    .revenueCatCustomerCenter(","        isPresented: Binding(","            get: { store.paywall.isCustomerCenterPresented },","            set: { if !$0 { store.send(.paywall(.dismissCustomerCenter)) } }","        )","    )"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The convenience modifier "},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"type":"text","text":" is exactly equivalent to this wiring."}]},{"type":"heading","text":"Step 5: Restore from inside the paywall","anchor":"Step-5-Restore-from-inside-the-paywall","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevenueCatUI’s "},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" provides its own restore button by default. If you need an additional restore affordance elsewhere (a Settings row, for example), dispatch "},{"code":".restorePurchases","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"syntax":"swift"},{"type":"heading","text":"What happens on dismiss","anchor":"What-happens-on-dismiss","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the paywall, the plugin’s "},{"code":".dismiss","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"PaywallState.isPresented","type":"codeVoice"},{"type":"text","text":" and "},{"code":"requestedReason","type":"codeVoice"},{"type":"text","text":", then dispatches "},{"code":".refreshCustomerInfo","type":"codeVoice"},{"type":"text","text":" so the gate is reconciled — the user may have purchased while the sheet was open."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the customer center, the plugin’s "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":". No refresh is dispatched, since opening the customer center does not change entitlement state by itself; the live "},{"code":"customerInfoStream","type":"codeVoice"},{"type":"text","text":" from "},{"code":"Step 5","type":"codeVoice"},{"type":"text","text":" of "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"type":"text","text":" picks up any subscription change RevenueCat reports asynchronously."}]}]}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","abstract":[{"type":"text","text":"The matching API reference for the views described here lives in the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" documentation."}],"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"]},{"title":"How-to Guides","anchor":"How-to-Guides","generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"kind":"article","variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"metadata":{"title":"How to Present the UI","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article"},"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","title":"How to Implement the Service","abstract":[{"text":"Wire ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" into the ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","kind":"symbol","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","title":"How to Preview and Test","abstract":[{"text":"Drive entitlement state from SwiftUI previews and tests with ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — no RevenueCat SDK call required.","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/PlatformBehavior":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/platformbehavior","title":"Platform Behavior","abstract":[{"type":"text","text":"Why the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifiers present differently on iOS and macOS, and what is hard-coded."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}]}}}