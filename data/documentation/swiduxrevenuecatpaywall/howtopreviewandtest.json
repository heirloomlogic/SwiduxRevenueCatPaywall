{"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"anchor":"Related-Documentation"},{"generated":true,"title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"anchor":"How-to-Guides"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"},"abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" — no RevenueCat SDK call required."}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" is a ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer that returns a configured snapshot from ","type":"text"},{"type":"codeVoice","code":"customerInfo()"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"restorePurchases()"},{"text":" and exposes a streaming continuation through ","type":"text"},{"type":"codeVoice","code":"send(_:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":". Plug it into the same ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":" you use in production. Drive entitlement transitions from your test or preview body.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the API reference, see ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference"},{"text":".","type":"text"}]},{"type":"heading","text":"Why a different mock from SwiduxPaywall’s","level":2,"anchor":"Why-a-different-mock-from-SwiduxPaywalls"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" ships its own "},{"code":"MockPaywallService","type":"codeVoice"},{"type":"text","text":" whose stream finishes after the initial yield. That works for static “Pro” and “Free” previews but cannot model purchase, refund, or family-share transitions as a sequence. "},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" keeps the stream open until you call "},{"code":"finish()","type":"codeVoice"},{"type":"text","text":", which lets a single test verify the store reacts correctly to an "},{"type":"emphasis","inlineContent":[{"type":"text","text":"order"}]},{"type":"text","text":" of snapshots."}]},{"inlineContent":[{"type":"text","text":"When you only need a static state (one snapshot, one render pass), either mock works. When you need a sequence, use this one."}],"type":"paragraph"},{"text":"Step 1: Make the service injectable","level":2,"anchor":"Step-1-Make-the-service-injectable","type":"heading"},{"inlineContent":[{"type":"text","text":"Plumb the service through your "},{"type":"codeVoice","code":"Store.configured()"},{"type":"text","text":" factory so previews and tests can override it:"}],"type":"paragraph"},{"syntax":"swift","code":["extension Store where State == AppState, Action == AppAction {","    static func configured(","        paywallService: any PaywallService = RevenueCatPaywallService(entitlementID: \"pro\")","    ) -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: paywallService","            )","        )","        return Store(initialState: AppState(), reducer: AppReducer().reduce, plugins: plugins)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"The default keeps the live RevenueCat path for app launch. Previews and tests pass an override.","type":"text"}],"type":"paragraph"},{"text":"Step 2: Static previews — pick a state","level":2,"anchor":"Step-2-Static-previews-pick-a-state","type":"heading"},{"inlineContent":[{"text":"Use the configured-state form when one snapshot is enough:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["#Preview(\"Free\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService()","    )","    return ContentView().environment(store)","}","","#Preview(\"Pro\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(isPro: true)","    )","    return ContentView().environment(store)","}","","#Preview(\"Lifetime\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(hasPermanentLicense: true)","    )","    return ContentView().environment(store)","}"],"type":"codeListing"},{"inlineContent":[{"text":"Each preview gets its own store; the mock’s initial snapshot flows through ","type":"text"},{"code":".observeCustomerInfo","type":"codeVoice"},{"text":" and updates the gate before the first render.","type":"text"}],"type":"paragraph"},{"text":"Step 3: Driving transitions in a test","level":2,"anchor":"Step-3-Driving-transitions-in-a-test","type":"heading"},{"inlineContent":[{"text":"When the test cares about a ","type":"text"},{"inlineContent":[{"text":"sequence","type":"text"}],"type":"emphasis"},{"text":" of states — for example, the gate flipping from ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" after a purchase — use the streaming form:"}],"type":"paragraph"},{"syntax":"swift","code":["@Test(\"Store updates when entitlement transitions to pro\")","func storeReactsToProPurchase() async {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    store.send(.paywall(.observeCustomerInfo))","    await Task.yield()","    #expect(store.paywall.isPro == false)","","    mock.send(EntitlementSnapshot(isPro: true))","    await Task.yield()","    #expect(store.paywall.isPro)","","    mock.finish()","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" pushes a snapshot through the active stream subscriber, which in this case is the plugin’s "},{"type":"codeVoice","code":"observeCustomerInfo"},{"type":"text","text":" effect. The store’s reducer applies "},{"type":"codeVoice","code":".customerInfoUpdated"},{"type":"text","text":", the observer tree fires for changed properties, and the assertion sees the new value."}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":""},{"code":"customerInfoStream()","type":"codeVoice"},{"type":"text","text":" replaces its continuation on every call. If your test requests the stream more than once (rare — "},{"code":"observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" is dispatched once), only the most recent subscriber receives "},{"code":"send(_:)","type":"codeVoice"},{"type":"text","text":" updates."}],"type":"paragraph"}],"type":"aside","style":"note"},{"text":"Step 4: Driving transitions in a preview","level":2,"anchor":"Step-4-Driving-transitions-in-a-preview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Previews can drive transitions too — useful for verifying paywall sheet copy across states without running the app:"}]},{"syntax":"swift","code":["#Preview(\"Purchase flow\") {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    return ContentView()","        .environment(store)","        .task {","            store.send(.paywall(.observeCustomerInfo))","            try? await Task.sleep(for: .seconds(2))","            mock.send(EntitlementSnapshot(isPro: true))","        }","}"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"text":"The preview starts in the free state, runs the gated UI for two seconds, then transitions to pro — letting you eyeball both copy paths in one preview pane.","type":"text"}]},{"text":"Step 5: Tear the stream down","level":2,"anchor":"Step-5-Tear-the-stream-down","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":" at the end of a test to terminate the stream cleanly:"}]},{"syntax":"swift","code":["mock.finish()"],"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This causes any pending "},{"type":"codeVoice","code":"for await … in stream"},{"type":"text","text":" to exit. Without it, the consuming "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" may stay alive until the test runner reaps it. Tests that own the mock for their full duration can skip this — Swift Testing tears down the task tree when the test exits — but it’s a clean habit."}]}]}],"metadata":{"roleHeading":"Article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Preview and Test","role":"article"},"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockServiceReference":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","abstract":[{"text":"API reference for ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — a controllable ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":".","type":"text"}],"title":"Mock Service Reference","url":"\/documentation\/swiduxrevenuecatpaywall\/mockservicereference","role":"article","kind":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","kind":"article","role":"article","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","kind":"symbol","title":"SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"type":"text","text":" presentation."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"title":"How to Implement the Service","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","abstract":[{"type":"text","text":"Wire "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"title":"How to Present the UI","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","abstract":[{"text":"Attach the ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"text":" view modifiers from ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockRevenueCatPaywallService":{"fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MockRevenueCatPaywallService","kind":"identifier"}],"url":"\/documentation\/swiduxrevenuecatpaywall\/mockrevenuecatpaywallservice","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService","abstract":[{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer for previews and tests with a controllable entitlement stream."}],"kind":"symbol","role":"symbol","type":"topic","title":"MockRevenueCatPaywallService","navigatorTitle":[{"text":"MockRevenueCatPaywallService","kind":"identifier"}]}}}