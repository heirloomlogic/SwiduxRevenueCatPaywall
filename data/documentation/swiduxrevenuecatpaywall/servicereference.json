urchases"},{"type":"text","text":" action wraps this call and dispatches "},{"type":"codeVoice","code":".customerInfoUpdated"},{"type":"text","text":" on success or "},{"type":"codeVoice","code":".refreshFailed"},{"type":"text","text":" on error."}]},{"level":2,"type":"heading","anchor":"Entitlement-mapping","text":"Entitlement mapping"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For every "},{"type":"codeVoice","code":"CustomerInfo"},{"type":"text","text":" the service receives:"}]},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Configuration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"isPro","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" active","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"(next column)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" inactive or missing","type":"text"}]}],[{"inlineContent":[{"type":"codeVoice","code":"false"}],"type":"paragraph"}],[{"inlineContent":[{"text":"(next column)","type":"text"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID == nil"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"—"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID"},{"type":"text","text":" active"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"—"}]}],[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID"},{"type":"text","text":" 