{"kind":"article","metadata":{"title":"Getting Started with SwiduxRevenueCatPaywall","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"text":"Add the package, configure RevenueCat, register the paywall plugin, and present the bundled sheets.","type":"text"}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"text":"Overview","type":"heading","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide walks through the four steps to integrate "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" into a Swidux app: add the package, configure RevenueCat, register the plugin, and attach the UI. It is the shortest path from a wired Swidux app to a working paywall. For deeper coverage of any step, follow the linked how-tos."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This package assumes you already use Swidux. If you don’t, work through Swidux’s own getting-started guide first."}]},{"text":"Add the Package","type":"heading","anchor":"Add-the-Package","level":2},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Xcode:"}]},{"text":" File > Add Package Dependencies, paste ","type":"text"},{"type":"codeVoice","code":"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall"},{"text":". Add the products you need:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" — the "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" implementation and mock."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" — adds the "},{"code":"PaywallSheet","type":"codeVoice"},{"type":"text","text":" and "},{"code":"CustomerCenterSheet","type":"codeVoice"},{"type":"text","text":" views (depends on RevenueCatUI)."}],"type":"paragraph"}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Package.swift:"}]}]},{"code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),"],"type":"codeListing","syntax":"swift"},{"code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"type":"codeListing","syntax":"swift"},{"text":"Configure RevenueCat at launch","type":"heading","level":2,"anchor":"Configure-RevenueCat-at-launch"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" calls into ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":". Configure the SDK before constructing the store:","type":"text"}]},{"code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"type":"codeListing","syntax":"swift"},{"text":"Register the paywall plugin","type":"heading","level":2,"anchor":"Register-the-paywall-plugin"},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":" in your ","type":"text"},{"type":"codeVoice","code":"Store.configured()"},{"text":" factory:","type":"text"}]},{"code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:","type":"text"}]},{"code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Gate features by reading ","type":"text"},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"text":". See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"text":" for the full plugin lifecycle.","type":"text"}]},{"text":"Attach the UI","type":"heading","level":2,"anchor":"Attach-the-UI"},{"type":"paragraph","inlineContent":[{"text":"Add ","type":"text"},{"type":"codeVoice","code":"PaywallSheet"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterSheet"},{"text":" to a root view, driven by paywall state:","type":"text"}]},{"code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Trigger the paywall from a gated feature with ","type":"text"},{"type":"codeVoice","code":".paywall(.request(reason:))"},{"text":":","type":"text"}]},{"code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"See ","type":"text"},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true},{"text":" for manual wiring, customer-center triggering, and dismiss semantics.","type":"text"}]},{"text":"Next Steps","type":"heading","level":2,"anchor":"Next-Steps"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":" — Detailed walkthrough of the service lifecycle and error handling."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense"},{"type":"text","text":" — Add a lifetime entitlement alongside the subscription."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"},{"type":"text","text":" — Drive entitleme