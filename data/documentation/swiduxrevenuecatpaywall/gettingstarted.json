","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":" in your "},{"type":"codeVoice","code":"Store.configured()"},{"type":"text","text":" factory:"}]},{"type":"codeListing","syntax":"swift","code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:"}]},{"type":"codeListing","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Gate features by reading "},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"type":"text","text":". See "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":" for the full plugin lifecycle."}],"type":"paragraph"},{"level":2,"anchor":"Attach-the-UI","text":"Attach the UI","type":"heading"},{"inlineContent":[{"type":"text","text":"Attach the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":