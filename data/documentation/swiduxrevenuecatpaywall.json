{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","interfaceLanguage":"swift"},"topicSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"],"title":"Quickstart","anchor":"Quickstart"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"title":"How-to Guides","anchor":"How-to-Guides"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"],"title":"Reference","anchor":"Reference"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"title":"Explanation","anchor":"Explanation"},{"identifiers":["