{"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"This guide walks through the four steps to integrate ","type":"text"},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":" into a Swidux app: add the package, configure RevenueCat, register the plugin, and attach the UI. It is the shortest path from a wired Swidux app to a working paywall. For deeper coverage of any step, follow the linked how-tos.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This package assumes you already use Swidux. If you don’t, work through Swidux’s own getting-started guide first."}]},{"level":2,"anchor":"Add-the-Package","text":"Add the Package","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Xcode:","type":"text"}]},{"text":" File > Add Package Dependencies, paste ","type":"text"},{"code":"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":". Add the products you need:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" — the "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" implementation and mock."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" — adds the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers (depends on RevenueCatUI).","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Package.swift:","type":"text"}],"type":"strong"}]},{"type":"codeListing","syntax":"swift","code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),"]},{"syntax":"swift","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"type":"codeListing"},{"type":"heading","level":2,"text":"Configure the paywall at launch","anchor":"Configure-the-paywall-at-launch"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" calls into ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":" under the hood. Configure the paywall before constructing the store:","type":"text"}]},{"type":"codeListing","code":["\/\/ MyApp.swift","import SwiduxRevenueCatPaywall","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        RevenueCatPaywall.configure(apiKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Pass "},{"code":"appUserID","type":"codeVoice"},{"type":"text","text":", "},{"type":"codeVoice","code":"userDefaults"},{"type":"text","text":" (for app-group sharing with widgets), or "},{"code":"logLevel","type":"codeVoice"},{"type":"text","text":" if you need them — see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:)","isActive":true},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"text":"Register the paywall plugin","type":"heading","anchor":"Register-the-paywall-plugin"},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" to ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":" in your ","type":"text"},{"code":"Store.configured()","type":"codeVoice"},{"type":"text","text":" factory:"}]},{"code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Gate features by reading ","type":"text"},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"type":"text","text":". See "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":" for the full plugin lifecycle."}]},{"level":2,"text":"Attach the UI","type":"heading","anchor":"Attach-the-UI"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Attach the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" modifier to a root view, driven by paywall state:"}]},{"type":"codeListing","syntax":"swift","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Trigger the paywall from a gated feature with ","type":"text"},{"type":"codeVoice","code":".paywall(.request(reason:))"},{"text":":","type":"text"}]},{"type":"codeListing","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"See "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true,"type":"reference"},{"text":" for manual wiring with the primitive modifiers, customer-center triggering, and dismiss semantics.","type":"text"}],"type":"paragraph"},{"level":2,"text":"Next Steps","anchor":"Next-Steps","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true,"type":"reference"},{"text":" — Detailed walkthrough of the service lifecycle and error handling.","type":"text"}]}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense"},{"type":"text","text":" — Add a lifetime entitlement alongside the subscription."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","isActive":true},{"text":" — Drive entitlement s