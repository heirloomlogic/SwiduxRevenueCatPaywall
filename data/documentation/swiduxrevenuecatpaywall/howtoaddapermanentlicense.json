dapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","title":"SwiduxRevenueCatPaywall"}}}