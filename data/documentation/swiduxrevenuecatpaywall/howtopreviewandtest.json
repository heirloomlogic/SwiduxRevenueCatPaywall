{"kind":"article","seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"]},{"generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"anchor":"How-to-Guides","title":"How-to Guides"}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"schemaVersion":{"patch":0,"minor":3,"major":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"},"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article","title":"How to Preview and Test"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" is a "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that returns a configured snapshot from "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":" and exposes a streaming continuation through "},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":". Plug it into the same "},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":" you use in production. Drive entitlement transitions from your test or preview body."}]},{"inlineContent":[{"type":"text","text":"For the API reference, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Why-a-different-mock-from-SwiduxPaywalls","text":"Why a different mock from SwiduxPaywall’s","type":"heading"},{"inlineContent":[{"type":"codeVoice","code":"SwiduxPaywall"},{"text":" ships its own ","type":"text"},{"type":"codeVoice","code":"MockPaywallService"},{"text":" whose stream finishes after the initial yield. That works for static “Pro” and “Free” previews but cannot model purchase, refund, or family-share transitions as a sequence. ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" keeps the stream open until you call ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":", which lets a single test verify the store reacts correctly to an ","type":"text"},{"type":"emphasis","inlineContent":[{"type":"text","text":"order"}]},{"text":" of snapshots.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When you only need a static state (one snapshot, one render pass), either mock works. When you need a sequence, use this one.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-1-Make-the-service-injectable","text":"Step 1: Make the service injectable","type":"heading"},{"inlineContent":[{"text":"Plumb the service through your ","type":"text"},{"type":"codeVoice","code":"Store.configured()"},{"text":" factory so previews and tests can override it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension Store where State == AppState, Action == AppAction {","    static func configured(","        paywallService: any PaywallService = RevenueCatPaywallService(entitlementID: \"pro\")","    ) -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: paywallService","            )","        )","        return Store(initialState: AppState(), reducer: AppReducer().reduce, plugins: plugins)","    }","}"]},{"inlineContent":[{"text":"The default keeps the live RevenueCat path for app launch. Previews and tests pass an override.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-2-Static-previews-pick-a-state","text":"Step 2: Static previews — pick a state","type":"heading"},{"inlineContent":[{"text":"Use the configured-state form when one snapshot is enough:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["#Preview(\"Free\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService()","    )","    return ContentView().environment(store)","}","","#Preview(\"Pro\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(isPro: true)","    )","    return ContentView().environment(store)","}","","#Preview(\"Lifetime\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(hasPermanentLicense: true)","    )","    return ContentView().environment(store)","}"]},{"inlineContent":[{"text":"Each preview gets its own store; the mock’s initial snapshot flows through ","type":"text"},{"type":"codeVoice","code":".observeCustomerInfo"},{"text":" and updates the gate before the first render.","type":"text"}],"type":"paragraph"},{"level":2,"anchor":"Step-3-Driving-transitions-in-a-test","text":"Step 3: Driving transitions in a test","type":"heading"},{"inlineContent":[{"type":"text","text":"When the test cares about a "},{"type":"emphasis","inlineContent":[{"text":"sequence","type":"text"}]},{"type":"text","text":" of states — for example, the gate flipping from "},{"type":"codeVoice","code":"false"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" after a purchase — use the streaming form:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Test(\"Store updates when entitlement transitions to pro\")","func storeReactsToProPurchase() async {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    store.send(.paywall(.observeCustomerInfo))","    await Task.yield()","    #expect(store.paywall.isPro == false)","","    mock.send(EntitlementSnapshot(isPro: true))","    await Task.yield()","    #expect(store.paywall.isPro)","","    mock.finish()","}"]},{"inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" pushes a snapshot through the active stream subscriber, which in this case is the plugin’s "},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" effect. The store’s reducer applies ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"type":"text","text":", the observer tree fires for changed properties, and the assertion sees the new value."}],"type":"paragraph"},{"style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"customerInfoStream()","type":"codeVoice"},{"type":"text","text":" replaces its continuation on every call. If your test requests the stream more than once (rare — "},{"type":"codeVoice","code":"observeCustomerInfo"},{"type":"text","text":" is dispatched once), only the most recent subscriber receives "},{"type":"codeVoice","code":"send(_:)"},{"text":" updates.","type":"text"}]}],"type":"aside","name":"Note"},{"anchor":"Step-4-Driving-transitions-in-a-preview","text":"Step 4: Driving transitions in a preview","level":2,"type":"heading"},{"inlineContent":[{"text":"Previews can drive transitions too — useful for verifying paywall sheet copy across states without running the app:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["#Preview(\"Purchase flow\") {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    return ContentView()","        .environment(store)","        .task {","            store.send(.paywall(.observeCustomerInfo))","            try? await Task.sleep(for: .seconds(2))","            mock.send(EntitlementSnapshot(isPro: true))","        }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The preview starts in the free state, runs the gated UI for two seconds, then transitions to pro — letting you eyeball both copy paths in one preview pane."}],"type":"paragraph"},{"level":2,"anchor":"Step-5-Tear-the-stream-down","text":"Step 5: Tear the stream down","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"type":"codeVoice","code":"finish()"},{"text":" at the end of a test to terminate the stream cleanly:","type":"text"}]},{"type":"codeListing","code":["mock.finish()"],"syntax":"swift"},{"inlineContent":[{"text":"This causes any pending ","type":"text"},{"type":"codeVoice","code":"for await … in stream"},{"text":" to exit. Without it, the consuming ","type":"text"},{"type":"codeVoice","code":"Task"},{"text":" may stay alive until the test runner reaps it. Tests that own the mock for their full duration can skip this — Swift Testing tears down the task tree when the test exits — but it’s a clean habit.","type":"text"}],"type":"paragraph"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"]}],"sections":[],"abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" to a root view, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":"."}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","role":"article","title":"How to Present the UI","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","title":"SwiduxRevenueCatPaywall","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"abstract":[{"text":"Wire ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" into the ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","title":"How to Implement the Service"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","role":"article","title":"How to Add a Permanent License","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockServiceReference":{"abstract":[{"text":"API reference for ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" — a controllable ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":".","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/mockservicereference","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","title":"Mock Service Reference"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockRevenueCatPaywallService":{"abstract":[{"type":"codeVoice","code":"PaywallService"},{"text":" conformer for previews and tests with a controllable entitlement stream.","type":"text"}],"navigatorTitle":[{"kind":"identifier","text":"MockRevenueCatPaywallService"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/mockrevenuecatpaywallservice","role":"symbol","fragments":[{"kind":"keyword","text":"class"},{"kind":"text","text":" "},{"kind":"identifier","text":"MockRevenueCatPaywallService"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService","title":"MockRevenueCatPaywallService"}}}