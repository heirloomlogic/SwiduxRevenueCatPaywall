{"abstract":[{"type":"text","text":"API reference for the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers — the SwiftUI surface of "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":"."}],"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UI product layers three view modifiers on top of "},{"code":"RevenueCatUI","type":"codeVoice"},{"type":"text","text":". Two primitives present the paywall and customer center directly from a "},{"code":"Binding<Bool>","type":"codeVoice"},{"type":"text","text":"; one convenience modifier composes both, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":". Each presentation modifier attaches to the modified content view directly — there are no "},{"code":"View","type":"codeVoice"},{"type":"text","text":" wrappers and no "},{"code":".background { … }","type":"codeVoice"},{"type":"text","text":" indirection. This shape is what makes the macOS sheet machinery present reliably."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For step-by-step wiring, see "},{"type":"emphasis","inlineContent":[{"text":"How to Present the UI","type":"text"}]},{"type":"text","text":" in the "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" documentation. For the rationale behind platform-specific behavior, see "},{"type":"emphasis","inlineContent":[{"text":"Platform Behavior","type":"text"}]},{"type":"text","text":" in the same catalog."}]},{"type":"heading","text":"Library target","anchor":"Library-target","level":2},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Product: "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Import: "},{"type":"codeVoice","code":"import SwiduxRevenueCatPaywallUI"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}]},{"type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The UI product depends on "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" and "},{"code":"RevenueCatUI","type":"codeVoice"},{"type":"text","text":", both pulled in transitively. Apps that don’t ship paywall UI in the same target (for example, a tests-only target) can depend on the lower-level "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" product alone."}]},{"type":"heading","text":"Modifiers","anchor":"Modifiers","level":2},{"type":"heading","text":"`revenueCatPaywall(isPresented:displayCloseButton:onDismiss:)`","anchor":"revenueCatPaywallisPresenteddisplayCloseButtononDismiss","level":3},{"type":"codeListing","code":["extension View {","    public func revenueCatPaywall(","        isPresented: Binding<Bool>,","        displayCloseButton: Bool = true,","        onDismiss: (() -> Void)? = nil","    ) -> some View","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Attaches "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":" as a platform-appropriate sheet."}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]},{"type":"text","text":" — Presents in a "},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":" so the paywall takes the full screen."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"macOS","type":"text"}]},{"type":"text","text":" — Presents in a "},{"type":"codeVoice","code":"sheet"},{"type":"text","text":" sized to a 400×600 minimum."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pass a real two-way binding; SwiftUI sets it to "},{"code":"false","type":"codeVoice"},{"type":"text","text":" on user dismissal. Build it from "},{"code":"PaywallState.isPresented","type":"codeVoice"},{"type":"text","text":" so the "},{"code":"set:","type":"codeVoice"},{"type":"text","text":" closure dispatches "},{"code":".paywall(.dismiss)","type":"codeVoice"},{"type":"text","text":" and the plugin clears its presentation state."}]},{"type":"heading","text":"Parameters","anchor":"Parameters","level":4},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"isPresented"},{"type":"text","text":" — Two-way binding to the paywall’s visibility flag."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"displayCloseButton"},{"type":"text","text":" — Whether "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" shows a close button. Defaults to "},{"type":"codeVoice","code":"true"},{"type":"text","text":". Neither the iOS "},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":" nor the macOS "},{"type":"codeVoice","code":"sheet"},{"type":"text","text":" offers any other dismissal affordance, so pass "},{"type":"codeVoice","code":"false"},{"type":"text","text":" only for a hard paywall the user must purchase through."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"onDismiss"},{"text":" — Optional callback fired after dismissal.","type":"text"}]}]}]},{"type":"heading","text":"`revenueCatCustomerCenter(isPresented:onDismiss:)`","anchor":"revenueCatCustomerCenterisPresentedonDismiss","level":3},{"type":"codeListing","code":["extension View {","    public func revenueCatCustomerCenter(","        isPresented: Binding<Bool>,","        onDismiss: (() -> Void)? = nil","    ) -> some View","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Attaches the customer center as a platform-appropriate sheet."}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"iOS"}],"type":"strong"},{"text":" — Presents ","type":"text"},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"text":" in a ","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"strong"},{"text":" — Opens ","type":"text"},{"code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions","type":"codeVoice"},{"text":" via ","type":"text"},{"code":"NSWorkspace.shared.open","type":"codeVoice"},{"text":" (falling back to the ","type":"text"},{"code":"https:\/\/apps.apple.com\/account\/subscriptions","type":"codeVoice"},{"text":" web URL if nothing on the system handles the ","type":"text"},{"code":"itms-apps","type":"codeVoice"},{"text":" scheme), immediately clears the binding, and fires ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":". RevenueCatUI does not ship a customer center on macOS.","type":"text"}]}]}]},{"type":"heading","text":"Parameters","anchor":"Parameters","level":4},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"isPresented","type":"codeVoice"},{"text":" — Two-way binding to the customer center’s visibility flag.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"onDismiss","type":"codeVoice"},{"text":" — Optional callback fired after dismissal (or, on macOS, after the App Store URL is opened).","type":"text"}]}]}]},{"type":"heading","text":"`revenueCatPaywall(state:displayCloseButton:send:)`","anchor":"revenueCatPaywallstatedisplayCloseButtonsend","level":3},{"type":"codeListing","code":["extension View {","    public func revenueCatPaywall(","        state: PaywallState,","        displayCloseButton: Bool = true,","        send: @escaping (PaywallAction) -> Void","    ) -> some View","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Convenience modifier that attaches both "},{"code":"revenueCatPaywall(isPresented:displayCloseButton:onDismiss:)","type":"codeVoice"},{"type":"text","text":" and "},{"code":"revenueCatCustomerCenter(isPresented:onDismiss:)","type":"codeVoice"},{"type":"text","text":" and dispatches the matching dismiss action when each sheet closes."}]},{"type":"heading","text":"Parameters","anchor":"Parameters","level":4},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"state","type":"codeVoice"},{"text":" — The paywall slice from your store, typically ","type":"text"},{"code":"store.paywall","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"displayCloseButton","type":"codeVoice"},{"text":" — Whether ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" shows a close button. Defaults to ","type":"text"},{"code":"true","type":"codeVoice"},{"text":"; see the primitive modifier above.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"send","type":"codeVoice"},{"text":" — A closure that lifts a ","type":"text"},{"code":"PaywallAction","type":"codeVoice"},{"text":" into your root action and dispatches it through the store. Typically ","type":"text"},{"code":"{ store.send(.paywall($0)) }","type":"codeVoice"},{"text":".","type":"text"}]}]}]},{"type":"heading","text":"Equivalent manual wiring","anchor":"Equivalent-manual-wiring","level":4},{"type":"codeListing","code":["ContentView()","    .revenueCatPaywall(","        isPresented: Binding(","            get: { store.paywall.isPresented },","            set: { if !$0 { store.send(.paywall(.dismiss)) } }","        )","    )","    .revenueCatCustomerCenter(","        isPresented: Binding(","            get: { store.paywall.isCustomerCenterPresented },","            set: { if !$0 { store.send(.paywall(.dismissCustomerCenter)) } }","        )","    )"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use the convenience modifier when both sheets are needed; use the primitives when only one is needed or when you want to interleave other modifiers between them."}]}]}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"]},{"title":"Reference","anchor":"Reference","generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference"]}],"kind":"article","variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/uicomponentsreference"],"traits":[{"interfaceLanguage":"swift"}]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"metadata":{"title":"UI Components Reference","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","role":"article"},"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","kind":"symbol","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","