{"kind":"article","metadata":{"roleHeading":"Article","title":"How to Present the UI","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"seeAlsoSections":[{"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"],"abstract":[{"type":"text","text":"The matching API reference for the views described here lives in the "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" documentation."}],"anchor":"Related-Documentation"},{"title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"generated":true,"anchor":"How-to-Guides"}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" ships three view modifiers that wrap RevenueCatUI’s surfaces with platform-aware presentation. Each is bound to ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":": presentation flags drive visibility, and the bindings dispatch matching paywall actions back through the store on dismissal. There is no local sheet state.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For platform behavior details (iOS ","type":"text"},{"type":"codeVoice","code":"fullScreenCover"},{"text":" vs macOS sheet sizing, App Store deep link on macOS), see ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"text":".","type":"text"}]},{"level":2,"type":"heading","text":"Before you start","anchor":"Before-you-start"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide assumes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have completed "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference","isActive":true},{"type":"text","text":". The plugin is registered and "},{"type":"codeVoice","code":"observeCustomerInfo"},{"type":"text","text":" runs on launch."}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Your app target depends on the "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" product:"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"]},{"type":"heading","level":2,"text":"Step 1: Attach both sheets to a root view","anchor":"Step-1-Attach-both-sheets-to-a-root-view"},{"type":"paragraph","inlineContent":[{"text":"The simplest wiring uses the ","type":"text"},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"text":" modifier — one call, both sheets, both dismissals:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The closure receives a ","type":"text"},{"code":"PaywallAction","type":"codeVoice"},{"text":" (","type":"text"},{"code":".dismiss","type":"codeVoice"},{"text":" or ","type":"text"},{"code":".dismissCustomerCenter","type":"codeVoice"},{"text":") and lifts it into your root action. Place the modifier on the topmost view that should host both sheets.","type":"text"}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both paywall modifiers also accept "},{"type":"codeVoice","code":"displayCloseButton:"},{"type":"text","text":" (default "},{"type":"codeVoice","code":"true"},{"text":"). The default presentation has no other way out — see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","type":"reference","isActive":true},{"text":" before turning it off.","type":"text"}]},{"type":"heading","level":2,"text":"Step 2: Trigger the paywall from a feature","anchor":"Step-2-Trigger-the-paywall-from-a-feature"},{"type":"paragraph","inlineContent":[{"text":"Dispatch ","type":"text"},{"code":".request(reason:)","type":"codeVoice"},{"text":" with a short identifier describing why you’re asking. ","type":"text"},{"code":"PaywallState.requestedReason","type":"codeVoice"},{"text":" stores the value so the sheet (or analytics) can tailor its copy:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Export PDF\") {","    store.send(.paywall(.request(reason: \"export-pdf\")))","}"]},{"type":"paragraph","inlineContent":[{"text":"The plugin sets ","type":"text"},{"type":"codeVoice","code":"PaywallState.isPresented = true"},{"text":". The ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" modifier observes the change and presents ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":".","type":"text"}]},{"type":"heading","level":2,"text":"Step 3: Trigger the customer center","anchor":"Step-3-Trigger-the-customer-center"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Existing subscribers manage their subscription through the customer center. Surface a button that dispatches "},{"type":"codeVoice","code":".presentCustomerCenter"},{"type":"text","text":":"}]},{"code":["if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","}"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifier presents "},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"},{"type":"text","text":" on iOS. On macOS it opens the system App Store subscriptions URL and immediately fires "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" (RevenueCatUI does not ship a customer center on macOS — see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"type":"text","text":")."}],"type":"paragraph"},{"text":"Step 4: Manual wiring (optional)","level":2,"anchor":"Step-4-Manual-wiring-optional","type":"heading"},{"inlineContent":[{"text":"If you need only one sheet, or you want to interleave other modifiers between them, attach the primitive modifiers directly. Each takes a real ","type":"text"},{"code":"Binding<Bool>","type":"codeVoice"},{"text":"; build it with a ","type":"text"},{"code":"set:","type":"codeVoice"},{"text":" that dispatches the matching dismiss action when SwiftUI clears the flag:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["ContentView()","    .revenueCatPaywall(","        isPresented: Binding(","            get: { store.paywall.isPresented },","            set: { if !$0 { store.send(.paywall(.dismiss)) } }","        )","    )","    .revenueCatCustomerCenter(","        isPresented: Binding(","            get: { store.paywall.isCustomerCenterPresented },","            set: { if !$0 { store.send(.paywall(.dismissCustomerCenter)) } }","        )","    )"]},{"inlineContent":[{"text":"The convenience modifier ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall(state:send:)"},{"type":"text","text":" is exactly equivalent to this wiring."}],"type":"paragraph"},{"level":2,"text":"Step 5: Restore from inside the paywall","anchor":"Step-5-Restore-from-inside-the-paywall","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevenueCatUI’s "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" provides its own restore button by default. If you need an additional restore affordance elsewhere (a Settings row, for example), dispatch "},{"type":"codeVoice","code":".restorePurchases"},{"type":"text","text":":"}]},{"type":"codeListing","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"syntax":"swift"},{"type":"heading","text":"What happens on dismiss","anchor":"What-happens-on-dismiss","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the paywall, the plugin’s "},{"type":"codeVoice","code":".dismiss"},{"type":"text","text":" action clears "},{"code":"PaywallState.isPresented","type":"codeVoice"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"requestedReason"},{"type":"text","text":", then dispatches "},{"code":".refreshCustomerInfo","type":"codeVoice"},{"type":"text","text":" so the gate is reconciled — the user may have purchased while the sheet was open."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the customer center, the plugin’s "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":" action clears "},{"type":"codeVoice","code":"isCustomerCenterPresented"},{"text":". No refresh is dispatched, since opening the customer center does not change entitlement state by itself; the live ","type":"text"},{"code":"customerInfoStream","type":"codeVoice"},{"text":" from ","type":"text"},{"code":"Step 5","type":"codeVoice"},{"text":" of ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference","isActive":true},{"text":" picks up any subscription change RevenueCat reports asynchronously.","type":"text"}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"abstract":[{"type":"text","text":"Attach the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" and "},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"type":"text","text":" view modifiers from "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" to a root view, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":"."}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"kind":"article","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","title":"How to Implement the Service","abstract":[{"text":"Wire ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","title":"How to Preview and Test","abstract":[{"text":"Drive entitlement state from SwiftUI previews and tests with ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" — no RevenueCat SDK call required."}],"role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"kind":"symbol","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","title":"SwiduxRevenueCatPaywall","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":". Implements "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" against "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/PlatformBehavior":{"title":"Platform Behavior","url":"\/documentation\/swiduxrevenuecatpaywall\/platformbehavior","type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","kind":"article","abstract":[{"type":"text","text":"Why the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifiers present differently on iOS and macOS, and what is hard-coded."}],"role":"article"}}}