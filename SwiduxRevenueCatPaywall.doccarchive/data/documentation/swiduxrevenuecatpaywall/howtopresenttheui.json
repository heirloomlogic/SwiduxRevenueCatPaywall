{"schemaVersion":{"patch":0,"major":0,"minor":3},"abstract":[{"type":"text","text":"Attach "},{"type":"codeVoice","code":"PaywallSheet"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterSheet"},{"type":"text","text":" from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","interfaceLanguage":"swift"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui"]}],"metadata":{"title":"How to Present the UI","role":"article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article"},"kind":"article","primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" ships two SwiftUI views and a convenience modifier that wrap RevenueCatUI’s surfaces with platform-aware presentation. Each is bound to "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":": presentation flags drive visibility, dismissal closures dispatch matching paywall actions back through the store. There is no local sheet state."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For platform behavior details (iOS "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" vs macOS sheet sizing, App Store deep link on macOS), see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"type":"text","text":"."}]},{"level":2,"type":"heading","anchor":"Before-you-start","text":"Before you start"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide assumes:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"You have completed ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"text":". The plugin is registered and ","type":"text"},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" runs on launch.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Your app target depends on the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" product:"}],"type":"paragraph"}]}]},{"syntax":"swift","type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"]},{"level":2,"type":"heading","anchor":"Step-1-Attach-both-sheets-to-a-root-view","text":"Step 1: Attach both sheets to a root view"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The simplest wiring uses the "},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"type":"text","text":" modifier — one call, both sheets, both dismissals:"}]},{"syntax":"swift","type":"codeListing","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The closure receives a "},{"code":"PaywallAction","type":"codeVoice"},{"type":"text","text":" ("},{"code":".dismiss","type":"codeVoice"},{"type":"text","text":" or "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":") and lifts it into your root action. Place the modifier on the topmost view that should host both sheets."}]},{"level":2,"type":"heading","anchor":"Step-2-Trigger-the-paywall-from-a-feature","text":"Step 2: Trigger the paywall from a feature"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Dispatch "},{"code":".request(reason:)","type":"codeVoice"},{"type":"text","text":" with a short identifier describing why you’re asking. "},{"code":"PaywallState.requestedReason","type":"codeVoice"},{"type":"text","text":" stores the value so the sheet (or analytics) can tailor its copy:"}]},{"syntax":"swift","type":"codeListing","code":["Button(\"Export PDF\") {","    store.send(.paywall(.request(reason: \"export-pdf\")))","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin sets "},{"code":"PaywallState.isPresented = true","type":"codeVoice"},{"type":"text","text":". "},{"code":"PaywallSheet","type":"codeVoice"},{"type":"text","text":" observes the change and presents "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":"."}]},{"level":2,"type":"heading","anchor":"Step-3-Trigger-the-customer-center","text":"Step 3: Trigger the customer center"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Existing subscribers manage their subscription through the customer center. Surface a button that dispatches "},{"code":".presentCustomerCenter","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","}"]},{"type":"paragraph","inlineContent":[{"code":"CustomerCenterSheet","type":"codeVoice"},{"type":"text","text":" presents "},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"},{"type":"text","text":" on iOS. On macOS it opens the system App Store subscriptions URL and immediately fires "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" (RevenueCatUI does not ship a customer center on macOS — see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},{"type":"text","text":")."}]},{"level":2,"type":"heading","anchor":"Step-4-Manual-wiring-optional","text":"Step 4: Manual wiring (optional)"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you need only one sheet, or you want to interleave other modifiers between them, attach each manually:"}]},{"syntax":"swift","type":"codeListing","code":["ContentView()","    .background(","        PaywallSheet(","            isPresented: store.paywall.isPresented,","            onDismiss: { store.send(.paywall(.dismiss)) }","        )","    )","    .background(","        CustomerCenterSheet(","            isPresented: store.paywall.isCustomerCenterPresented,","            onDismiss: { store.send(.paywall(.dismissCustomerCenter)) }","        )","    )"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The modifier form is exactly equivalent to this wiring."}]},{"level":2,"type":"heading","anchor":"Step-5-Restore-from-inside-the-paywall","text":"Step 5: Restore from inside the paywall"},{"type":"paragraph","inlineContent":[{"type":"text","text":"RevenueCatUI’s "},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" provides its own restore button by default. If you need an additional restore affordance elsewhere (a Settings row, for example), dispatch "},{"code":".restorePurchases","type":"codeVoice"},{"type":"text","text":":"}]},{"syntax":"swift","type":"codeListing","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"]},{"level":2,"type":"heading","anchor":"What-happens-on-dismiss","text":"What happens on dismiss"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the paywall, the plugin’s "},{"code":".dismiss","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"PaywallState.isPresented","type":"codeVoice"},{"type":"text","text":" and "},{"code":"requestedReason","type":"codeVoice"},{"type":"text","text":", then dispatches "},{"code":".refreshCustomerInfo","type":"codeVoice"},{"type":"text","text":" so the gate is reconciled — the user may have purchased while the sheet was open."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When the user dismisses the customer center, the plugin’s "},{"code":".dismissCustomerCenter","type":"codeVoice"},{"type":"text","text":" action clears "},{"code":"isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":". No refresh is dispatched, since opening the customer center does not change entitlement state by itself; the live "},{"code":"customerInfoStream","type":"codeVoice"},{"type":"text","text":" from "},{"code":"Step 5","type":"codeVoice"},{"type":"text","text":" of "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":" picks up any subscription change RevenueCat reports asynchronously."}]}]}],"sections":[],"seeAlsoSections":[{"abstract":[{"type":"text","text":"The matching API reference for the views described here lives in the "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" documentation."}],"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"],"anchor":"Related-Documentation"},{"anchor":"How-to-Guides","title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"generated":true}],"r