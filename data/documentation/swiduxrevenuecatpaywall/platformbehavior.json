{"kind":"article","seeAlsoSections":[{"abstract":[{"type":"text","text":"The "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" documentation provides the matching API reference for the views described here."}],"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"anchor":"Related-Documentation"},{"title":"Explanation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"generated":true,"anchor":"Explanation"}],"metadata":{"role":"article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","title":"Platform Behavior"},"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","interfaceLanguage":"swift"},"schemaVersion":{"minor":3,"patch":0,"major":0},"abstract":[{"type":"text","text":"Why "},{"type":"codeVoice","code":"PaywallSheet"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterSheet"},{"type":"text","text":" present differently on iOS and macOS, and what is hard-coded."}],"sections":[],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"text","text":"The bundled UI is intentionally opinionated. Each view picks the platform-appropriate presentation so consumers don’t have to repeat the conditional compilation themselves, and so the dispatch flow stays symmetric across platforms — the same "},{"code":".paywall(.dismiss)","type":"codeVoice"},{"type":"text","text":" action fires from a "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" on iOS and from a sheet on macOS."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This article explains the reasoning behind those choices and what is fixed versus configurable."}],"type":"paragraph"},{"anchor":"PaywallSheet","level":2,"type":"heading","text":"PaywallSheet"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Presentation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"fullScreenCover"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"A subscription paywall is a primary moment, not an interrupt. "},{"type":"codeVoice","code":"fullScreenCover"},{"type":"text","text":" keeps the UI immersive, prevents accidental gesture-dismiss, and matches App Store conventions."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"macOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"sheet"},{"type":"text","text":" with "},{"type":"codeVoice","code":"frame(minWidth: 400, minHeight: 600)"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Mac sheets do not expand to fill the parent window. Without an explicit minimum size the paywall would render too small to legibly show plan options. The 400×600 minimum is roughly the size RevenueCatUI’s templates assume."}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"The minimum frame is hard-coded; it is not exposed as a parameter. If your paywall layout needs more room on macOS, wrap "},{"code":"PaywallSheet","type":"codeVoice"},{"type":"text","text":" in a parent that imposes a larger frame, or use "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":" directly inside a custom "},{"code":"sheet","type":"codeVoice"},{"type":"text","text":" modifier."}],"type":"paragraph"},{"anchor":"CustomerCenterSheet","level":2,"type":"heading","text":"CustomerCenterSheet"},{"header":"row","rows":[[[{"inlineContent":[{"type":"text","text":"Platform"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Presentation"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"iOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"sheet"},{"type":"text","text":" with "},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"RevenueCatUI ships a customer center on iOS only. A non-fullscreen "},{"type":"codeVoice","code":"sheet"},{"type":"text","text":" is appropriate because customer-center actions are administrative, not part of a purchase flow."}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"macOS"}]}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Opens "},{"type":"codeVoice","code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions"},{"type":"text","text":" and immediately fires "},{"type":"codeVoice","code":"onDismiss"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"RevenueCatUI does not ship a customer center on macOS, and the system has no equivalent in-app surface. The App Store subscription management page is what users expect on the Mac, so the sheet hands off to it and clears its own presentation state immediately."}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"The macOS branch dispatches "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" synchronously after "},{"code":"NSWorkspace.shared.open","type":"codeVoice"},{"type":"text","text":" so "},{"code":"PaywallState.isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":" does not get stuck "},{"code":"true","type":"codeVoice"},{"type":"text","text":". The user returns from App Store to find the app’s UI in its idle state."}],"type":"paragraph"},{"anchor":"Why-no-platform-override-hooks","level":2,"type":"heading","text":"Why no platform-override hooks"},{"inlineContent":[{"type":"text","text":"Both views are deliberately stateless and parameter-light: an "},{"code":"isPresented: Bool","type":"codeVoice"},{"type":"text","text":" and an "},{"code":"onDismiss: () -> Void","type":"codeVoice"},{"type":"text","text":". There is no "},{"code":"paywallStyle:","type":"codeVoice"},{"type":"text","text":" or "},{"code":"presentationKind:","type":"codeVoice"},{"type":"text","text":" parameter."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reasoning: any consumer that needs to deviate from the chosen presentation already has the underlying RevenueCatUI types ("},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":", "},{"code":"CustomerCenterView","type":"codeVoice"},{"type":"text","text":") and SwiftUI’s full presentation surface ("},{"code":"sheet","type":"codeVoice"},{"type":"text","text":", "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":", "},{"code":"popover","type":"codeVoice"},{"type":"text","text":", custom containers). The bundled views exist to handle the 95% case in one line — when the 5% case applies, drop down to RevenueCatUI directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This package does not try to be the complete paywall-UI library. It is the "},{"inlineContent":[{"type":"text","text":"integration layer"}],"type":"emphasis"},{"type":"text","text":" that makes the common case trivial."}],"type":"paragraph"},{"anchor":"What-is-configurable","level":2,"type":"heading","text":"What is configurable"},{"inlineContent":[{"type":"text","text":"The configurable surface lives in "},{"code":"RevenueCatUI","type":"codeVoice"},{"type":"text","text":" and on the paywall plugin:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Paywall content, copy, and template","type":"text"}]},{"type":"text","text":" — configured in the RevenueCat dashboard. "},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"type":"text","text":" renders whichever offering and template the dashboard returns."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Customer-center labels, sections, and actions","type":"text"}]},{"type":"text","text":" — configured in the RevenueCat dashboard. "},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"},{"type":"text","text":" renders whichever configuration the dashboard returns."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Presentation triggering","type":"text"}]},{"type":"text","text":" — driven by the plugin via "},{"type":"codeVoice","code":"PaywallState.isPresented"},{"type":"text","text":" and "},{"type":"codeVoice","code":"isCustomerCenterPresented"},{"type":"text","text":". Your code chooses "},{"type":"emphasis","inlineContent":[{"text":"when","type":"text"}]},{"type":"text","text":" to set them via "},{"type":"codeVoice","code":".request(reason:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":".presentCustomerCenter"},{"type":"text","text":" actions."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Dismiss behavior","type":"text"}]},{"type":"text","text":" — your "},{"type":"codeVoice","code":"onDismiss"},{"type":"text","text":" closures dispatch the matching paywall actions. Replace them if you need analytics hooks or cleanup beyond the default flow."}]}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/platformbehavior"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"kind":"symbol","url":"\/documentation\/swiduxrevenuecatpaywall","type":"topic","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection","title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","type":"topic","abstract":[{"type":"text","text":"How RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":" translates to Swidux’s "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","role":"article","title":"Entitlement Mapping"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","type":"topic","abstract":[{"text":"Attach ","type":"text"},{"type":"codeVoice","code":"PaywallSheet"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterSheet"},{"type":"text","text":" from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","role":"article","title":"How to Present the UI"}}}