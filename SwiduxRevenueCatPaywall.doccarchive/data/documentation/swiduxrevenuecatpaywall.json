{"schemaVersion":{"patch":0,"minor":3,"major":0},"sections":[],"abstract":[{"type":"text","text":"RevenueCat adapter for Swidux’s "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":". Implements "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" against "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" for drop-in "},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":" and "},{"code":"CustomerCenterView","type":"codeVoice"},{"type":"text","text":" presentation."}],"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"text":" is the adapter between RevenueCat’s SDK and Swidux’s purchase-agnostic paywall plugin. The plugin owns paywall state (presentation flags, current entitlement, async progress); this package translates RevenueCat’s ","type":"text"},{"code":"CustomerInfo","type":"codeVoice"},{"text":" into the ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":" the plugin expects, and surfaces the live ","type":"text"},{"code":"customerInfoStream","type":"codeVoice"},{"text":" so entitlement changes propagate without polling.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"Two products ship together:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"strong"},{"text":" — ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" (the live ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" conformer) and ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" (a controllable preview \/ test conformer).","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"}],"type":"strong"},{"text":" — ","type":"text"},{"type":"codeVoice","code":"PaywallSheet"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterSheet"},{"text":", drop-in SwiftUI views that wrap RevenueCatUI with platform-aware presentation, plus a ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall(state:send:)"},{"text":" view modifier that composes both.","type":"text"}]}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The flow:","type":"text"}],"type":"paragraph"},{"code":["View → store.send(.paywall(.request(reason:)))","  → PaywallPlugin sets isPresented = true","  → PaywallSheet observes the change, presents RevenueCatUI.PaywallView","  → user purchases → Purchases.shared.customerInfoStream yields a new CustomerInfo","  → RevenueCatPaywallService maps it to EntitlementSnapshot","  → PaywallPlugin reduces .customerInfoUpdated, sets isPro = true","  → store.paywall.isGateSatisfied flips, gated UI unlocks"],"syntax":null,"type":"codeListing"},{"inlineContent":[{"text":"The plugin and the adapter stay decoupled: the plugin doesn’t know about RevenueCat, and the adapter doesn’t know about your action tree.","type":"text"}],"type":"paragraph"}]}],"topicSections":[{"anchor":"Quickstart","title":"Quickstart","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted"]},{"anchor":"How-to-Guides","title":"How-to Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]},