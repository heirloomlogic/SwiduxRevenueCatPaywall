{"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"metadata":{"role":"article","title":"Service Reference","roleHeading":"Article","modules":[{"name":"SwiduxRevenueCatPaywall"}]},"abstract":[{"type":"text","text":"API reference for "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" — the RevenueCat-backed ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer that the paywall plugin consumes.","type":"text"}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService"]},{"title":"Reference","anchor":"Reference","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"],"generated":true}],"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" adapts "},{"code":"RevenueCat.Purchases","type":"codeVoice"},{"type":"text","text":" to the "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" protocol that "},{"code":"SwiduxPaywall.PaywallPlugin","type":"codeVoice"},{"type":"text","text":" requires. It does one job: translate "},{"code":"CustomerInfo","type":"codeVoice"},{"type":"text","text":" into "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"type":"text","text":" (defined by "},{"code":"SwiduxPaywall","type":"codeVoice"},{"type":"text","text":") so the plugin can drive its state. Configuration of the RevenueCat SDK itself remains the caller’s responsibility."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For a step-by-step integration walkthrough, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":". For the entitlement-mapping rules, see "},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Library target","anchor":"Library-target"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"text":"Product: ","type":"text"},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"paragraph"}]}]},{"inlineContent":[{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),"]},{"level":2,"type":"heading","text":"Types","anchor":"Types"},{"level":3,"type":"heading","text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService``","anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallRevenueCatPaywallService"},{"syntax":"swift","type":"codeListing","code":["public struct RevenueCatPaywallService: PaywallService {","    public init(","        entitlementID: String,","        permanentLicenseEntitlementID: String? = nil","    )","","    public func customerInfo() async throws -> EntitlementSnapshot","    public func customerInfoStream() -> AsyncStream<EntitlementSnapshot>","    public func restorePurchases() async throws -> EntitlementSnapshot","}"]},{"inlineContent":[{"type":"text","text":"Value type. Holds two "},{"code":"String","type":"codeVoice"},{"type":"text","text":" identifiers and forwards every call to "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":". Safe to construct freely; cheap to pass into "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":4,"type":"heading","text":"Initializer","anchor":"Initializer"},{"syntax":"swift","type":"codeListing","code":["public init(","    entitlementID: String,","    permanentLicenseEntitlementID: String? = nil",")"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" — RevenueCat entitlement identifier that grants pro access. Surfaces as ","type":"text"},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"text":" when active.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"permanentLicenseEntitlementID","type":"codeVoice"},{"text":" — Optional secondary identifier for a lifetime \/ permanent entitlement. Surfaces as ","type":"text"},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"text":" when active. Pass ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if the app has no separate lifetime SKU.","type":"text"}],"type":"paragraph"}]}]},{"style":"important","content":[{"type":"paragraph","inlineContent":[{"text":"Call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:)","type":"reference"},{"text":" before constructing the service. The service does not configure RevenueCat itself, and ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":" traps if used unconfigured.","type":"text"}]}],"type":"aside","name":"Important"},{"level":4,"type":"heading","text":"`customerInfo() async throws -> EntitlementSnapshot`","anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot"},{"inlineContent":[{"type":"text","text":"One-shot fetch. Calls "},{"code":"Purchases.shared.customerInfo()","type":"codeVoice"},{"type":"text","text":" and maps the result."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"Throws whatever the RevenueCat SDK throws ("},{"code":"ErrorCode.networkError","type":"codeVoice"},{"type":"text","text":", "},{"code":".offlineConnectionError","type":"codeVoice"},{"type":"text","text":", etc.). The plugin catches the error and dispatches "},{"code":".refreshFailed(message)","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"},{"level":4,"type":"heading","text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E"},{"inlineContent":[{"type":"text","text":"Long-lived stream. Wraps "},{"code":"Purchases.shared.customerInfoStream","type":"codeVoice"},{"type":"text","text":" and yields a new "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"type":"text","text":" for every change RevenueCat reports — purchase, refund, family-share update, sandbox renewal."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The stream finishes when the underlying RevenueCat stream finishes. The plugin’s "},{"code":".observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" effect normally keeps it alive for the duration of the session; cancel by cancelling the consuming "},{"code":"Task","type":"codeVoice"},{"type":"text","text":", which terminates the stream and tears down the bridge."}],"type":"paragraph"},{"level":4,"type":"heading","text":"`restorePurchases() async throws -> EntitlementSnapshot`","anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot"},{"inlineContent":[{"type":"text","text":"Calls "},{"code":"Purchases.shared.restorePurchases()","type":"codeVoice"},{"type":"text","text":" and maps the result. Throws whatever the SDK throws on error."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The plugin’s "},{"code":".restorePurchases","type":"codeVoice"},{"type":"text","text":" action wraps this call and dispatches "},{"code":".customerInfoUpdated","type":"codeVoice"},{"type":"text","text":" on success or "},{"code":".refreshFailed","type":"codeVoice"},{"type":"text","text":" on error."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Entitlement mapping","anchor":"Entitlement-mapping"},{"inlineContent":[{"type":"text","text":"For every "},{"code":"CustomerInfo","type":"codeVoice"},{"type":"text","text":" the service receives:"}],"type":"paragraph"},{"header":"row","type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"text":"Configuration","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"isPro","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" active","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"(next column)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" inactive or missing","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"(next column)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"permanentLicenseEntitlementID == nil","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"text":"—","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"permanentLicenseEntitlementID","type":"codeVoice"},{"text":" active","type":"text"}]}],[{"type":"paragraph","