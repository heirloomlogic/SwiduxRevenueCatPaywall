{"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"minor":3,"patch":0},"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"],"anchor":"Related-Documentation","title":"Related Documentation"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"],"generated":true,"anchor":"How-to-Guides","title":"How-to Guides"}],"abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"metadata":{"roleHeading":"Article","title":"How to Add a Permanent License","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article"},"primaryContentSections":[{"kind":"content","content":[{"level":2,"anchor":"Overview","type":"heading","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Many apps offer two ways to buy: a recurring pro subscription and a one-time lifetime purchase. RevenueCat models both as entitlements; "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" checks each independently and surfaces them as the two flags on "},{"type":"codeVoice","code":"EntitlementSnapshot"},{"type":"text","text":":"}]},{"items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"isPro"},{"type":"text","text":" — active subscription."}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"},{"text":" — active lifetime entitlement.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The paywall plugin’s "},{"code":"isGateSatisfied","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"isPro || hasPermanentLicense","type":"codeVoice"},{"text":", so feature code keeps a single check while UI can branch on the underlying flags when it needs to.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the entitlement-mapping rules and edge cases, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"type":"heading","text":"Before you start","anchor":"Before-you-start","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide assumes:"}]},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have completed "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"type":"text","text":"."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You have configured ","type":"text"},{"inlineContent":[{"type":"text","text":"two"}],"type":"strong"},{"text":" entitlements in the RevenueCat dashboard — typically ","type":"text"},{"code":"pro","type":"codeVoice"},{"text":" for the subscription and ","type":"text"},{"code":"lifetime","type":"codeVoice"},{"type":"text","text":" for the one-time purchase. The identifiers are arbitrary; only the strings need to match what you pass into the service."}]}]}]},{"type":"heading","text":"Step 1: Pass the second identifier","anchor":"Step-1-Pass-the-second-identifier","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Replace the single-entitlement init with the two-arg form:"}]},{"type":"codeListing","code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(","    entitlementID: \"pro\",","    permanentLicenseEntitlementID: \"lifetime\"",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Both entitlements are now checked on every "},{"code":"customerInfo()","type":"codeVoice"},{"type":"text","text":", "},{"code":"customerInfoStream()","type":"codeVoice"},{"type":"text","text":" yield, and "},{"code":"restorePurchases()","type":"codeVoice"},{"type":"text","text":" call. The active state of "},{"code":"pro","type":"codeVoice"},{"type":"text","text":" flows into "},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"type":"text","text":"; the active state of "},{"code":"lifetime","type":"codeVoice"},{"type":"text","text":" flows into "},{"code":"hasPermanentLicense","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The two flags are independent. A user with both active gets both flags set; a user with only one active gets only that flag set."}]},{"type":"heading","level":2,"anchor":"Step-2-Wire-the-service-into-the-plugin","text":"Step 2: Wire the service into the plugin"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Same as the single-entitlement case — the plugin doesn’t need to know about the second identifier:"}]},{"type":"codeListing","syntax":"swift","code":["plugins.register(","    PaywallPlugin<AppState, AppAction>(","        state: \\.paywall,","        action: AppAction.paywall,","        extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","        service: RevenueCatPaywallService(","            entitlementID: \"pro\",","            permanentLicenseEntitlementID: \"lifetime\"","        )","    )",")"]},{"type":"heading","level":2,"anchor":"Step-3-Decide-whether-feature-code-needs-to-branch","text":"Step 3: Decide whether feature code needs to branch"},{"type":"paragraph","inlineContent":[{"text":"For most gated features, keep using ","type":"text"},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if store.paywall.isGateSatisfied { … }"]},{"type":"paragraph","inlineContent":[{"text":"This stays correct whether the user has a subscription or a lifetime license, and works identically in apps that don’t sell a lifetime SKU.","type":"text"}]},{"type":"heading","level":2,"anchor":"Step-4-Branch-in-UI-when-copy-must-differ","text":"Step 4: Branch in UI when copy must differ"},{"type":"paragraph","inlineContent":[{"text":"If the paywall sheet should be hidden for lifetime customers (so they’re not pestered to subscribe), or if the customer-center entry should be relabeled, branch on the underlying flag:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if store.paywall.hasPermanentLicense {","    Text(\"Lifetime member — thank you!\")","} else if store.paywall.isPro {","    Button(\"Manage Subscription\") {","        store.send(.paywall(.presentCustomerCenter))","    }","} else {","    Button(\"Upgrade\") {","        store.send(.paywall(.request(reason: \"upgrade-prompt\")))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Lifetime users typically have nothing to manage in App Store \/ Settings. Hiding the customer-center button for them avoids dead-end taps."}]},{"anchor":"When-to-skip-the-second-identifier","type":"heading","level":2,"text":"When to skip the second identifier"},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" (or omit the parameter) if your app has no lifetime SKU:","type":"text"}]},{"type":"codeListing","code":["RevenueCatPaywallService(entitlementID: \"pro\")"],"syntax":"swift"},{"inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"},{"text":" then stays ","type":"text"},{"code":"false","type":"codeVoice"},{"type":"text","text":" regardless of any entitlements RevenueCat reports — even if the dashboard accidentally has a "},{"type":"codeVoice","code":"lifetime"},{"type":"text","text":" entitlement that the service is not configured to check. See the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Lifetime entitlement is ignored when no permanent-license ID is configured"}]},{"text":" test case for the precise behavior.","type":"text"}],"type":"paragraph"}]}],"kind":"article","hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"title":"How to Present the UI","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","abstract":[{"text":"Attach the ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"text":" view modifiers from ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"code":"PaywallState","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"type":"topic","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","role":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK