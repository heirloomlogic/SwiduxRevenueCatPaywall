{"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","text":"Overview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The bundled UI is intentionally opinionated. Each modifier picks the platform-appropriate presentation so consumers don’t have to repeat the conditional compilation themselves, and so the dispatch flow stays symmetric across platforms — the same "},{"code":".paywall(.dismiss)","type":"codeVoice"},{"type":"text","text":" action fires from a "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":" on iOS and from a sheet on macOS."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This article explains the reasoning behind those choices and what is fixed versus configurable."}],"type":"paragraph"},{"anchor":"revenueCatPaywall","text":"revenueCatPaywall","level":2,"type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Platform","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Presentation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Reason","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"fullScreenCover","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"A subscription paywall is a primary moment, not an interrupt. ","type":"text"},{"code":"fullScreenCover","type":"codeVoice"},{"text":" keeps the UI immersive, prevents accidental gesture-dismiss, and matches App Store conventions.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"macOS","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"sheet","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"frame(minWidth: 400, minHeight: 600)","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Mac sheets do not expand to fill the parent window. Without an explicit minimum size the paywall would render too small to legibly show plan options. The 400×600 minimum is roughly the size RevenueCatUI’s templates assume.","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"The minimum frame is hard-coded; it is not exposed as a parameter. If your paywall layout needs more room on macOS, wrap the modified view in a parent that imposes a larger frame, or use "},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"type":"text","text":" directly inside a custom "},{"code":"sheet","type":"codeVoice"},{"type":"text","text":" modifier."}],"type":"paragraph"},{"anchor":"revenueCatCustomerCenter","text":"revenueCatCustomerCenter","level":2,"type":"heading"},{"header":"row","rows":[[[{"inlineContent":[{"text":"Platform","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Presentation","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Reason","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"iOS","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"code":"sheet","type":"codeVoice"},{"text":" with ","type":"text"},{"code":"RevenueCatUI.CustomerCenterView","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RevenueCatUI ships a customer center on iOS only. A non-fullscreen ","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":" is appropriate because customer-center actions are administrative, not part of a purchase flow.","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"strong","inlineContent":[{"text":"macOS","type":"text"}]}],"type":"paragraph"}],[{"inlineContent":[{"text":"Opens ","type":"text"},{"code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions","type":"codeVoice"},{"text":" and immediately fires ","type":"text"},{"code":"onDismiss","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"RevenueCatUI does not ship a customer center on macOS, and the system has no equivalent in-app surface. The App Store subscription management page is what users expect on the Mac, so the sheet hands off to it and clears its own presentation state immediately.","type":"text"}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"type":"text","text":"The macOS branch clears the binding and fires "},{"code":"onDismiss","type":"codeVoice"},{"type":"text","text":" synchronously after "},{"code":"NSWorkspace.shared.open","type":"codeVoice"},{"type":"text","text":" so "},{"code":"PaywallState.isCustomerCenterPresented","type":"codeVoice"},{"type":"text","text":" does not get stuck "},{"code":"true","type":"codeVoice"},{"type":"text","text":". The user returns from App Store to find the app’s UI in its idle state."}],"type":"paragraph"},{"anchor":"Why-no-platform-override-hooks","text":"Why no platform-override hooks","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Both modifiers are deliberately parameter-light: an "},{"code":"isPresented: Binding<Bool>","type":"codeVoice"},{"type":"text","text":" and an optional "},{"code":"onDismiss: () -> Void","type":"codeVoice"},{"type":"text","text":". There is no "},{"code":"paywallStyle:","type":"codeVoice"},{"type":"text","text":" or "},{"code":"presentationKind:","type":"codeVoice"},{"type":"text","text":" parameter."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The reasoning: any consumer that needs to deviate from the chosen presentation already has the underlying RevenueCatUI types ("},{"code":"PaywallView","type":"codeVoice"},{"type":"text","text":", "},{"code":"CustomerCenterView","type":"codeVoice"},{"type":"text","text":") and SwiftUI’s full presentation surface ("},{"code":"sheet","type":"codeVoice"},{"type":"text","text":", "},{"code":"fullScreenCover","type":"codeVoice"},{"type":"text","text":", "},{"code":"popover","type":"codeVoice"},{"type":"text","text":", custom containers). The bundled modifiers exist to handle the 95% case in one line — when the 5% case applies, drop down to RevenueCatUI directly."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This package does not try to be the complete paywall-UI library. It is the "},{"inlineContent":[{"text":"integration layer","type":"text"}],"type":"emphasis"},{"type":"text","text":" that makes the common case trivial."}],"type":"paragraph"},{"anchor":"What-is-configurable","text":"What is configurable","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"The configurable surface lives in "},{"code":"RevenueCatUI","type":"codeVoice"},{"type":"text","text":" and on the paywall plugin:"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Paywall content, copy, and template","type":"text"}]},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":" renders whichever offering and template the dashboard returns.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Customer-center labels, sections, and actions","type":"text"}]},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"},{"text":" renders whichever configuration the dashboard returns.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Presentation triggering","type":"text"}]},{"text":" — driven by the plugin via ","type":"text"},{"type":"codeVoice","code":"PaywallState.isPresented"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"isCustomerCenterPresented"},{"text":". Your code chooses ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"when","type":"text"}]},{"text":" to set them via ","type":"text"},{"type":"codeVoice","code":".request(reason:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":".presentCustomerCenter"},{"text":" actions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Dismiss behavior","type":"text"}]},{"text":" — your ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" closures dispatch the matching paywall actions. Replace them if you need analytics hooks or cleanup beyond the default flow.","type":"text"}]}]}],"type":"unorderedList"}],"kind":"content"}],"abstract":[{"text":"Why the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" modifiers present differently on iOS and macOS, and what is hard-coded.","type":"text"}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/platformbehavior"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"metadata":{"title":"Platform Behavior","roleHeading":"Article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article"},"schemaVersion":{"major":0,"minor":3,"patch":0},"kind":"article","seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"title":"Related Documentation","anchor":"Related-Documentation","abstract":[{"text":"The ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" documentation provides the matching API reference for the modifiers described here.","type":"text"}]},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"title":"Explanation","generated":true,"anchor":"Explanation"}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","role":"article","title":"Entitlement Mapping","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers from "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","role":"article","title":"How to Present the UI","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"}}}