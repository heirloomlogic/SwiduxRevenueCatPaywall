{"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/GettingStarted","interfaceLanguage":"swift"},"schemaVersion":{"major":0,"patch":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"This guide walks through the four steps to integrate "},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" into a Swidux app: add the package, configure RevenueCat, register the plugin, and attach the UI. It is the shortest path from a wired Swidux app to a working paywall. For deeper coverage of any step, follow the linked how-tos."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"This package assumes you already use Swidux. If you don’t, work through Swidux’s own getting-started guide first."}],"type":"paragraph"},{"anchor":"Add-the-Package","type":"heading","text":"Add the Package","level":2},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Xcode:"}],"type":"strong"},{"type":"text","text":" File > Add Package Dependencies, paste "},{"code":"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":". Add the products you need:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"},{"type":"text","text":" — the "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" implementation and mock."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" — adds the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" and "},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"type":"text","text":" view modifiers (depends on RevenueCatUI)."}]}]}]},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Package.swift:"}],"type":"strong"}],"type":"paragraph"},{"type":"codeListing","code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),"],"syntax":"swift"},{"type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift"},{"anchor":"Configure-RevenueCat-at-launch","type":"heading","text":"Configure RevenueCat at launch","level":2},{"inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" calls into "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":". Configure the SDK before constructing the store:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"syntax":"swift"},{"anchor":"Register-the-paywall-plugin","type":"heading","text":"Register the paywall plugin","level":2},{"inlineContent":[{"type":"text","text":"Pass "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" to "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":" in your "},{"code":"Store.configured()","type":"codeVoice"},{"type":"text","text":" factory:"}],"type":"paragraph"},{"type":"codeListing","code":["import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Start the entitlement stream on the root view so the gate reflects RevenueCat’s state from launch:"}],"type":"paragraph"},{"type":"codeListing","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Gate features by reading "},{"code":"store.paywall.isGateSatisfied","type":"codeVoice"},{"type":"text","text":". See "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true},{"type":"text","text":" for the full plugin lifecycle."}],"type":"paragraph"},{"anchor":"Attach-the-UI","type":"heading","text":"Attach the UI","level":2},{"inlineContent":[{"type":"text","text":"Attach the "},{"code":"revenueCatPaywall","type":"codeVoice"},{"type":"text","text":" modifier to a root view, driven by paywall state:"}],"type":"paragraph"},{"type":"codeListing","code":["import SwiduxRevenueCatPaywallUI","","struct RootView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        ContentView()","            .revenueCatPaywall(state: store.paywall) { action in","                store.send(.paywall(action))","            }","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"Trigger the paywall from a gated feature with "},{"code":".paywall(.request(reason:))","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true},{"type":"text","text":" for manual wiring with the primitive modifiers, customer-center triggering, and dismiss semantics."}],"type":"paragraph"},{"anchor":"Next-Steps","type":"heading","text":"Next Steps","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"reference"},{"type":"text","text":" — Detailed walkthrough of the service lifecycle and error handling."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","type":"reference"},{"type":"text","text":" — Add a lifetime entitlement alongside the subscription."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"reference"},{"type":"text","text":" — Drive entitlement state from previews and tests."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","type":"reference"},{"type":"text","text":" — Wire the bundled view modifiers."}]}]