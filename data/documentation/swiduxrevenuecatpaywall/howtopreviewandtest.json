{"seeAlsoSections":[{"anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"title":"Related Documentation"},{"anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"title":"How-to Guides","generated":true}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Preview and Test","roleHeading":"Article","role":"article"},"primaryContentSections":[{"content":[{"level":2,"type":"heading","text":"Overview","anchor":"Overview"},{"inlineContent":[{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" is a ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer that returns a configured snapshot from ","type":"text"},{"code":"customerInfo()","type":"codeVoice"},{"text":" \/ ","type":"text"},{"code":"restorePurchases()","type":"codeVoice"},{"text":" and exposes a streaming continuation through ","type":"text"},{"code":"send(_:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"finish()","type":"codeVoice"},{"text":". Plug it into the same ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":" you use in production. Drive entitlement transitions from your test or preview body.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"For the API reference, see ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","type":"reference"},{"text":".","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Why a different mock from SwiduxPaywall’s","anchor":"Why-a-different-mock-from-SwiduxPaywalls"},{"inlineContent":[{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" ships its own ","type":"text"},{"code":"MockPaywallService","type":"codeVoice"},{"text":" whose stream finishes after the initial yield. That works for static “Pro” and “Free” previews but cannot model purchase, refund, or family-share transitions as a sequence. ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" keeps the stream open until you call ","type":"text"},{"code":"finish()","type":"codeVoice"},{"text":", which lets a single test verify the store reacts correctly to an ","type":"text"},{"inlineContent":[{"type":"text","text":"order"}],"type":"emphasis"},{"text":" of snapshots.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"When you only need a static state (one snapshot, one render pass), either mock works. When you need a sequence, use this one.","type":"text"}],"type":"paragraph"},{"level":2,"type":"heading","text":"Step 1: Make the service injectable","anchor":"Step-1-Make-the-service-injectable"},{"inlineContent":[{"text":"Plumb the service through your ","type":"text"},{"code":"Store.configured()","type":"codeVoice"},{"text":" factory so previews and tests can override it:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["extension Store where State == AppState, Action == AppAction {","    static func configured(","        paywallService: any PaywallService = RevenueCatPaywallService(entitlementID: \"pro\")","    ) -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: paywallService","            )","        )","        return Store(initialState: AppState(), reducer: AppReducer().reduce, plugins: plugins)","    }","}"]},{"inlineContent":[{"type":"text","text":"The default keeps the live RevenueCat path for app launch. Previews and tests pass an override."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Step 2: Static previews — pick a state","anchor":"Step-2-Static-previews-pick-a-state"},{"inlineContent":[{"type":"text","text":"Use the configured-state form when one snapshot is enough:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["#Preview(\"Free\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService()","    )","    return ContentView().environment(store)","}","","#Preview(\"Pro\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(isPro: true)","    )","    return ContentView().environment(store)","}","","#Preview(\"Lifetime\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(hasPermanentLicense: true)","    )","    return ContentView().environment(store)","}"]},{"inlineContent":[{"type":"text","text":"Each preview gets its own store; the mock’s initial snapshot flows through "},{"type":"codeVoice","code":".observeCustomerInfo"},{"type":"text","text":" and updates the gate before the first render."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Step 3: Driving transitions in a test","anchor":"Step-3-Driving-transitions-in-a-test"},{"inlineContent":[{"type":"text","text":"When the test cares about a "},{"inlineContent":[{"type":"text","text":"sequence"}],"type":"emphasis"},{"text":" of states — for example, the gate flipping from ","type":"text"},{"code":"false","type":"codeVoice"},{"text":" to ","type":"text"},{"type":"codeVoice","code":"true"},{"type":"text","text":" after a purchase — use the streaming form:"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["@Test(\"Store updates when entitlement transitions to pro\")","func storeReactsToProPurchase() async {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    store.send(.paywall(.observeCustomerInfo))","    await Task.yield()","    #expect(store.paywall.isPro == false)","","    mock.send(EntitlementSnapshot(isPro: true))","    await Task.yield()","    #expect(store.paywall.isPro)","","    mock.finish()","}"]},{"inlineContent":[{"type":"text","text":"Each "},{"code":"send(_:)","type":"codeVoice"},{"type":"text","text":" pushes a snapshot through the active stream subscriber, which in this case is the plugin’s "},{"code":"observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" effect. The store’s reducer applies "},{"code":".customerInfoUpdated","type":"codeVoice"},{"type":"text","text":", the observer tree fires for changed properties, and the assertion sees the new value."}],"type":"paragraph"},{"style":"note","type":"aside","name":"Note","content":[{"inlineContent":[{"text":"","type":"text"},{"code":"customerInfoStream()","type":"codeVoice"},{"text":" replaces its continuation on every call. If your test requests the stream more than once (rare — ","type":"text"},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" is dispatched once), only the most recent subscriber receives ","type":"text"},{"code":"send(_:)","type":"codeVoice"},{"type":"text","text":" updates."}],"type":"paragraph"}]},{"text":"Step 4: Driving transitions in a preview","anchor":"Step-4-Driving-transitions-in-a-preview","level":2,"type":"heading"},{"inlineContent":[{"type":"text","text":"Previews can drive transitions too — useful for verifying paywall sheet copy across states without running the app:"}],"type":"paragraph"},{"syntax":"swift","code":["#Preview(\"Purchase flow\") {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    return ContentView()","        .environment(store)","        .task {","            store.send(.paywall(.observeCustomerInfo))","            try? await Task.sleep(for: .seconds(2))","            mock.send(EntitlementSnapshot(isPro: true))","        }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The preview starts in the free state, runs the gated UI for two seconds, then transitions to pro — letting you eyeball both copy paths in one preview pane."}],"type":"paragraph"},{"level":2,"type":"heading","text":"Step 5: Tear the stream down","anchor":"Step-5-Tear-the-stream-down"},{"inlineContent":[{"type":"text","text":"Call "},{"code":"finish()","type":"codeVoice"},{"text":" at the end of a test to terminate the stream cleanly:","type":"text"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["mock.finish()"]},{"inlineContent":[{"type":"text","text":"This causes any pending "},{"code":"for await … in stream","type":"codeVoice"},{"type":"text","text":" to exit. Without it, the consuming "},{"code":"Task","type":"codeVoice"},{"text":" may stay alive until the test runner reaps it. Tests that own the mock for their full duration can skip this — Swift Testing tears down the task tree when the test exits — but it’s a clean habit.","type":"text"}],"type":"paragraph"}],"kind":"content"}],"abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"},"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","title":"How to Add a Permanent License","role":"article","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"type":"topic","title":"SwiduxRevenueCatPaywall","url":"\/documentation\/swiduxrevenuecatpaywall","kind":"symbol","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"How to Present the UI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockServiceReference":{"type":"topic","title":"Mock Service Reference","role":"article","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — a controllable "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer for previews and tests that does not touch "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/mockservicereference"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockRevenueCatPaywallService":{"abstract":[{"code":"PaywallService","type":"codeVoice"},{"text":" conformer for previews and tests with a controllable entitlement stream.","type":"text"}],"type":"topic","title":"MockRevenueCatPaywallService","url":"\/documentation\/swiduxrevenuecatpaywall\/mockrevenuecatpaywallservice","kind":"symbol","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MockRevenueCatPaywallService","kind":"identifier"}],"navigatorTitle":[{"text":"MockRevenueCatPaywallService","kind":"identifier"}],"role":"symbol"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","abstract":[{"type":"text","text":"Wire "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","type":"topic","title":"How to Implement the Service","kind":"article"}}}