,{"text":"UserDefaults","kind":"typeIdentifier","preciseIdentifier":"c:objc(cs)NSUserDefaults"},{"text":"?, ","kind":"text"},{"text":"logLevel","kind":"externalParam"},{"text":": ","kind":"text"},{"text":"RevenueCatPaywall","kind":"typeIdentifier","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O"},{"text":".","kind":"text"},{"text":"LogLevel","kind":"typeIdentifier","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O8LogLevelO"},{"text":")","kind":"text"}],"role":"symbol"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"Entitlement Mapping","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","role":"article"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"type":"topic","title":"How to Present the UI","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","role":"article"}}}