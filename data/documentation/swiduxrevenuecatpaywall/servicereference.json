 its state. Configuration of the RevenueCat SDK itself remains the caller’s responsibility."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For a step-by-step integration walkthrough, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},{"type":"text","text":". For the entitlement-mapping rules, see "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Library target","anchor":"Library-target"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Product: ","type":"text"},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywall","type":"codeVoice"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"type":"codeListing","code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),"],"syntax":"swift"},{"type":"heading","level":2,"text":"Types","anchor":"Types"},{"type":"heading","level":3,"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService``","anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallRevenueCatPaywallService"},{"type":"codeListing","code":["public struct RevenueCatPaywallService: PaywallService {","    public init(","        entitlementID: String,","        permanentLicenseEntitlementID: String? = nil","    )","","    public func customerInfo() async throws -> EntitlementSnapshot","    public func customerInfoStream() -> AsyncStream<EntitlementSnapshot>","    public func restorePurchases() async throws -> EntitlementSnapshot","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Value type. Holds two "},{"type":"codeVoice","code":"String"},{"type":"text","text":" identifiers and forwards every call to "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":". Safe to construct freely; cheap to pass into "},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":"."}]},{"type":"heading","level":4,"text":"Initializer","anchor":"Initializer"},{"type":"codeListing","code":["public init(","    entitlementID: String,","    permanentLicenseEntitlementID: String? = nil",")"],"syntax":"swift"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" — RevenueCat entitlement identifier that grants pro access. Surfaces as ","type":"text"},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"text":" when active.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"permanentLicenseEntitlementID","type":"codeVoice"},{"text":" — Optional secondary identifier for a lifetime \/ permanent entitlement. Surfaces as ","type":"text"},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"text":" when active. Pass ","type":"text"},{"code":"nil","type":"codeVoice"},{"text":" if the app has no separate lifetime SKU.","type":"text"}]}]}]},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":"Purchases.configure(withAPIKey:)"},{"type":"text","text":" before constructing the service. The service does not configure RevenueCat itself, and "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":" traps if used unconfigured."}]}],"style":"important","name":"Important"},{"type":"heading","level":4,"text":"`customerInfo() async throws -> EntitlementSnapshot`","anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot"},{"type":"paragraph","inlineContent":[{"type":"text","text":"One-shot fetch.