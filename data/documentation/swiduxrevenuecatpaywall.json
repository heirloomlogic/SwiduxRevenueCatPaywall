"type":"text"},{"code":"revenueCatPaywall(isPresented:)","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter(isPresented:)","type":"codeVoice"},{"text":", drop-in SwiftUI view modifiers that wrap RevenueCatUI with platform-aware presentation, plus a ","type":"text"},{"code":"revenueCatPaywall(state:send:)","type":"codeVoice"},{"text":" convenience that composes both.","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The flow:"}]},{"code":["View → store.send(.paywall(.request(reason:)))","  → PaywallPlugin sets isPresented = true","  → revenueCatPaywall observes the change, presents RevenueCatUI.PaywallView","  → user purchases → Purchases.shared.customerInfoStream yields a new CustomerInfo","  → RevenueCatPaywallService maps it to EntitlementSnapshot","  → PaywallPlugin reduces .customerInfoUpdated, sets isPro = true","  → store.paywall.isGateSatisfied flips, gated UI unlocks"],"syntax":null,"type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin and the adapter stay decoupled: the plugin doesn’t know about RevenueCat, and the adapter doesn’t know about your action tree."}]}]}],"kind":"symbol","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall"]}],"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[[]]},"metadata":{"role":"collection","title":"SwiduxRevenueCatPaywall","modules":[{"name":"SwiduxRevenueCatPaywall"}],"symbolKind":"module","externalID":"SwiduxRevenueCatPaywall","roleHeading":"Framework"},"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","abstract":[{"text":