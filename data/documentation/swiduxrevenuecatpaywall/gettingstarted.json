eVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"type":"text","text":" view modifiers (depends on RevenueCatUI)."}],"type":"paragraph"}]}]},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Package.swift:"}]}],"type":"paragraph"},{"code":[".package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),"],"type":"codeListing","syntax":"swift"},{"code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),",".product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),"],"type":"codeListing","syntax":"swift"},{"anchor":"Configure-the-paywall-at-launch","level":2,"type":"heading","text":"Configure the paywall at launch"},{"type":"paragraph","inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" calls into ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":" under the hood. Configure the paywall before constructing the store:","type":"text"}]},{"type":"codeListing","code":["\/\/ MyApp.swift","import SwiduxRevenueCatPaywall","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        RevenueCatPaywall.configure(apiKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Pass ","type":"text"},{"code":"appUserID","type":"codeVoice"},{"text":", ","type":"text"},{"code":"userDefaults","type":"codeVoice"},{"type":"text","text":" (for app-group sharing with widgets), or "},{"code":"logLevel","type":"codeVoice"},{"text":" if you need them — see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefault