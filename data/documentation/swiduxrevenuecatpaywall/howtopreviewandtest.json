{"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"title":"Related Documentation","anchor":"Related-Documentation"},{"generated":true,"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"title":"How-to Guides","anchor":"How-to-Guides"}],"primaryContentSections":[{"content":[{"anchor":"Overview","level":2,"type":"heading","text":"Overview"},{"inlineContent":[{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" is a "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that returns a configured snapshot from "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":" and exposes a streaming continuation through "},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" and "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":". Plug it into the same "},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":" you use in production. Drive entitlement transitions from your test or preview body."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"For the API reference, see "},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"anchor":"Why-a-different-mock-from-SwiduxPaywalls","level":2,"type":"heading","text":"Why a different mock from SwiduxPaywall’s"},{"inlineContent":[{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" ships its own "},{"type":"codeVoice","code":"MockPaywallService"},{"type":"text","text":" whose stream finishes after the initial yield. That works for static “Pro” and “Free” previews but cannot model purchase, refund, or family-share transitions as a sequence. "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" keeps the stream open until you call "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":", which lets a single test verify the store reacts correctly to an "},{"type":"emphasis","inlineContent":[{"type":"text","text":"order"}]},{"type":"text","text":" of snapshots."}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"When you only need a static state (one snapshot, one render pass), either mock works. When you need a sequence, use this one."}],"type":"paragraph"},{"anchor":"Step-1-Make-the-service-injectable","level":2,"type":"heading","text":"Step 1: Make the service injectable"},{"inlineContent":[{"type":"text","text":"Plumb the service through your "},{"type":"codeVoice","code":"Store.configured()"},{"type":"text","text":" factory so previews and tests can override it:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["extension Store where State == AppState, Action == AppAction {","    static func configured(","        paywallService: any PaywallService = RevenueCatPaywallService(entitlementID: \"pro\")","    ) -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: paywallService","            )","        )","        return Store(initialState: AppState(), reducer: AppReducer().reduce, plugins: plugins)","    }","}"]},{"inlineContent":[{"type":"text","text":"The default keeps the live RevenueCat path for app launch. Previews and tests pass an override."}],"type":"paragraph"},{"anchor":"Step-2-Static-previews-pick-a-state","level":2,"type":"heading","text":"Step 2: Static previews — pick a state"},{"inlineContent":[{"type":"text","text":"Use the configured-state form when one snapshot is enough:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["#Preview(\"Free\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService()","    )","    return ContentView().environment(store)","}","","#Preview(\"Pro\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(isPro: true)","    )","    return ContentView().environment(store)","}","","#Preview(\"Lifetime\") {","    let store = AppStore.configured(","        paywallService: MockRevenueCatPaywallService(hasPermanentLicense: true)","    )","    return ContentView().environment(store)","}"]},{"inlineContent":[{"type":"text","text":"Each preview gets its own store; the mock’s initial snapshot flows through "},{"type":"codeVoice","code":".observeCustomerInfo"},{"type":"text","text":" and updates the gate before the first render."}],"type":"paragraph"},{"anchor":"Step-3-Driving-transitions-in-a-test","level":2,"type":"heading","text":"Step 3: Driving transitions in a test"},{"inlineContent":[{"type":"text","text":"When the test cares about a "},{"type":"emphasis","inlineContent":[{"type":"text","text":"sequence"}]},{"type":"text","text":" of states — for example, the gate flipping from "},{"type":"codeVoice","code":"false"},{"type":"text","text":" to "},{"type":"codeVoice","code":"true"},{"type":"text","text":" after a purchase — use the streaming form:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["@Test(\"Store updates when entitlement transitions to pro\")","func storeReactsToProPurchase() async {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    store.send(.paywall(.observeCustomerInfo))","    await Task.yield()","    #expect(store.paywall.isPro == false)","","    mock.send(EntitlementSnapshot(isPro: true))","    await Task.yield()","    #expect(store.paywall.isPro)","","    mock.finish()","}"]},{"inlineContent":[{"type":"text","text":"Each "},{"type":"codeVoice","code":"send(_:)"},{"type":"text","text":" pushes a snapshot through the active stream subscriber, which in this case is the plugin’s "},{"type":"codeVoice","code":"observeCustomerInfo"},{"type":"text","text":" effect. The store’s reducer applies "},{"type":"codeVoice","code":".customerInfoUpdated"},{"type":"text","text":", the observer tree fires for changed properties, and the assertion sees the new value."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"type":"paragraph","inlineContent":[{"text":"","type":"text"},{"code":"customerInfoStream()","type":"codeVoice"},{"text":" replaces its continuation on every call. If your test requests the stream more than once (rare — ","type":"text"},{"code":"observeCustomerInfo","type":"codeVoice"},{"text":" is dispatched once), only the most recent subscriber receives ","type":"text"},{"code":"send(_:)","type":"codeVoice"},{"text":" updates.","type":"text"}]}]},{"anchor":"Step-4-Driving-transitions-in-a-preview","level":2,"type":"heading","text":"Step 4: Driving transitions in a preview"},{"inlineContent":[{"type":"text","text":"Previews can drive transitions too — useful for verifying paywall sheet copy across states without running the app:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["#Preview(\"Purchase flow\") {","    let mock = MockRevenueCatPaywallService(isPro: false)","    let store = AppStore.configured(paywallService: mock)","","    return ContentView()","        .environment(store)","        .task {","            store.send(.paywall(.observeCustomerInfo))","            try? await Task.sleep(for: .seconds(2))","            mock.send(EntitlementSnapshot(isPro: true))","        }","}"]},{"inlineContent":[{"type":"text","text":"The preview starts in the free state, runs the gated UI for two seconds, then transitions to pro — letting you eyeball both copy paths in one preview pane."}],"type":"paragraph"},{"anchor":"Step-5-Tear-the-stream-down","level":2,"type":"heading","text":"Step 5: Tear the stream down"},{"inlineContent":[{"type":"text","text":"Call "},{"type":"codeVoice","code":"finish()"},{"type":"text","text":" at the end of a test to terminate the stream cleanly:"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["mock.finish()"]},{"inlineContent":[{"type":"text","text":"This causes any pending "},{"type":"codeVoice","code":"for await … in stream"},{"type":"text","text":" to exit. Without it, the consuming "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" may stay alive until the test runner reaps it. Tests that own the mock for their full duration can skip this — Swift Testing tears down the task tree when the test exits — but it’s a clean habit."}],"type":"paragraph"}],"kind":"content"}],"metadata":{"role":"article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"roleHeading":"Article","title":"How to Preview and Test"},"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" — no RevenueCat SDK call required."}],"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","interfaceLanguage":"swift"},"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockRevenueCatPaywallService":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService","type":"topic","kind":"symbol","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"MockRevenueCatPaywallService","kind":"identifier"}],"navigatorTitle":[{"text":"MockRevenueCatPaywallService","kind":"identifier"}],"abstract":[{"type":"codeVoice","code":"PaywallService"},{"text":" conformer for previews and tests with a controllable entitlement stream.","type":"text"}],"role":"symbol","title":"MockRevenueCatPaywallService","url":"\/documentation\/swiduxrevenuecatpaywall\/mockrevenuecatpaywallservice"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","type":"topic","kind":"article","abstract":[{"text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin.","type":"text"}],"role":"article","title":"How to Add a Permanent License","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"type":"topic","abstract":[{"text":"Wire ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" into the ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","role":"article","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","title":"How to Implement the Service"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"kind":"symbol","url":"\/documentation\/swiduxrevenuecatpaywall","type":"topic","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection","title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/MockServiceReference":{"kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/mockservicereference","type":"topic","abstract":[{"text":"API reference for ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — a controllable ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":".","type":"text"}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","role":"article","title":"Mock Service Reference"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","type":"topic","abstract":[{"text":"Attach ","type":"text"},{"type":"codeVoice","code":"PaywallSheet"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"CustomerCenterSheet"},{"type":"text","text":" from "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" to a root view, driven by "},{"type":"codeVoice","code":"PaywallState"},{"type":"text","text":"."}],"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","role":"article","title":"How to Present the UI"}}}