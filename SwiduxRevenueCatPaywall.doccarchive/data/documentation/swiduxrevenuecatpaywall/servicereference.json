:"Initializer","type":"heading","text":"Initializer","level":4},{"type":"codeListing","syntax":"swift","code":["public init(","    entitlementID: String,","    permanentLicenseEntitlementID: String? = nil",")"]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"codeVoice","code":"entitlementID"},{"type":"text","text":" — RevenueCat entitlement identifier that grants pro access. Surfaces as "},{"type":"codeVoice","code":"EntitlementSnapshot.isPro"},{"type":"text","text":" when active."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID"},{"type":"text","text":" — Optional secondary identifier for a lifetime \/ permanent entitlement. Surfaces as "},{"type":"codeVoice","code":"EntitlementSnapshot.hasPermanentLicense"},{"type":"text","text":" when active. Pass "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the app has no separate lifetime SKU."}],"type":"paragraph"}]}]},{"type":"aside","style":"important","name":"Important","content":[{"inlineContent":[{"type":"text","text":"Call "},{"code":"Purchases.configure(withAPIKey:)","type":"codeVoice"},{"type":"text","text":" before constructing the service. The service does not configure RevenueCat itself, and "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":" traps if used unconfigured."}],"type":"paragraph"}]},{"anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","type":"heading","text":"`customerInfo() async throws -> EntitlementSnapshot`","level":4},{"type":"paragraph","inlineContent":[{"text":"One-shot fetch. Calls ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.customerInfo()"},{"text":" and maps the result.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Throws whatever the RevenueCat SDK throws (","type":"text"},{"type":"codeVoice","code":"ErrorCode.networkError"},{"text":", ","type":"text"},{"type":"codeVoice","code":".offlineConnectionError"},{"text":", etc.). The plugin catches the error and dispatches ","type":"text"},{"type":"codeVoice","code":".refreshFailed(message)"},{"text":".","type":"text"}]},{"anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E","type":"heading","text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","level":4},{"type":"paragraph","inlineContent":[{"text":"Long-lived stream. Wraps ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.customerInfoStream"},{"text":" and yields a new ","type":"text"},{"type":"codeVoice","code":"EntitlementSnapshot"},{"text":" for every change RevenueCat reports — purchase, refund, family-share update, sandbox renewal.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The stream finishes when the underlying RevenueCat stream finishes. The plugin’s ","type":"text"},{"type":"codeVoice","code":".observeCustomerInfo"},{"text":" effect normally keeps it alive for the duration of the session; cancel by cancelling the consuming ","type":"text"},{"type":"codeVoice","code":"Task"},{"text":", which terminates the stream and tears down the bridge.","type":"text"}]},{"anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot","type":"heading","text":"`restorePurchases() async throws -> EntitlementSnapshot`","level":4},{"type":"paragraph","inlineContent":[{"text":"Calls ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.restorePurchases()"},{"text":" and maps the result. Throws whatever the SDK throws on error.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"The plugin’s ","type":"text"},{"type":"codeVoice","code":".restorePurchases"},{"text":" action wraps this call and dispatches ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" on success or ","type":"text"},{"type":"codeVoice","code":".refreshFailed"},{"text":" on error.","type":"text"}]},{"anchor":"Entitlement-mapping","type":"heading","text":"Entitlement mapping","level":2},{"type":"paragraph","inlineContent":[{