{"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","interfaceLanguage":"swift"},"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense"]},{"title":"Explanation","generated":true,"anchor":"Explanation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior"]}],"schemaVersion":{"patch":0,"major":0,"minor":3},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" exists to do one thing: turn a "},{"code":"RevenueCat.CustomerInfo","type":"codeVoice"},{"type":"text","text":" into an "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"type":"text","text":" the paywall plugin can consume. The mapping is small, deterministic, and ID-driven. This article spells it out so you can predict — without reading the source — what flag values a given dashboard configuration produces."}]},{"type":"heading","anchor":"The-mapping-rule","level":2,"text":"The mapping rule"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For every "},{"code":"CustomerInfo","type":"codeVoice"},{"type":"text","text":" the service receives, two flags are computed:"}]},{"type":"codeListing","syntax":null,"code":["isPro              = entitlements[entitlementID]?.isActive == true","hasPermanentLicense = permanentLicenseEntitlementID","                       .flatMap { entitlements[$0]?.isActive } == true"]},{"type":"paragraph","inlineContent":[{"text":"In prose:","type":"text"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A flag is "},{"type":"codeVoice","code":"true"},{"type":"text","text":" only if the relevant identifier was configured "},{"type":"strong","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" the entitlement at that identifier is present "},{"type":"strong","inlineContent":[{"type":"text","text":"and"}]},{"type":"text","text":" active."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Missing entitlements behave identically to inactive entitlements. "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" is never a third state."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"The permanent-license identifier is independent. If it is "},{"code":"nil","type":"codeVoice"},{"type":"text","text":", "},{"code":"hasPermanentLicense","type":"codeVoice"},{"type":"text","text":" is always "},{"type":"codeVoice","code":"false"},{"type":"text","text":" regardless of what’s in "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":"."}],"type":"paragraph"}]}]},{"type":"heading","text":"Truth table","anchor":"Truth-table","level":2},{"type":"table","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Configuration"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlements[\"pro\"]?.isActive"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlements[\"lifetime\"]?.isActive"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Result"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: nil"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(any)"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = true"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = false"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: nil"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" or absent"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(any)"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = false"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = false"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: \"lifetime\""}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" or absent"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = false"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = true"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: \"lifetime\""}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = true"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = true"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: \"lifetime\""}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" or absent"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" or absent"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = false"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = false"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID: \"pro\""},{"type":"text","text":", "},{"type":"codeVoice","code":"permanentLicenseEntitlementID: \"lifetime\""}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"true"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"},{"type":"text","text":" or absent"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isPro = true"},{"type":"text","text":", "},{"type":"codeVoice","code":"hasPermanentLicense = false"}]}]]],"header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every row above maps to a test case in "},{"type":"codeVoice","code":"RevenueCatPaywallServiceTests"},{"type":"text","text":" — the mapping is the package’s contract."}]},{"type":"heading","anchor":"Why-missing-==-inactive","level":2,"text":"Why missing == inactive"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Treating “absent” the same as “inactive” simplifies the mental model: feature code never has to handle a third state where the gate is “indeterminate.” A missing entitlement always denies access. This matches what users expect — a user who never bought the SKU sees the paywall, the same as a user whose subscription lapsed."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The cost is that a misconfigured dashboard (entitlement renamed, identifier typo in your service init) silently denies access rather than throwing. Catch this with an integration test that asserts the live service produces an active entitlement for a known sandbox account, or with a launch-time sanity log when "},{"type":"codeVoice","code":"isPro"},{"type":"text","text":" stays "},{"type":"codeVoice","code":"false"},{"type":"text","text":" longer than expected."}]},{"type":"heading","anchor":"Why-two-flags-instead-of-one","level":2,"text":"Why two flags instead of one"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin could expose a single "},{"type":"codeVoice","code":"isEntitled"},{"type":"text","text":" flag. It exposes two so UI can branch on the "},{"type":"emphasis","inlineContent":[{"type":"text","text":"source"}]},{"type":"text","text":" of entitlement:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"A subscriber sees a "},{"inlineContent":[{"type":"text","text":"Manage Subscription"}],"type":"emphasis"},{"type":"text","text":" button leading to the customer center."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A lifetime user sees no manage button — there’s nothing to manage on a one-time purchase."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"Marketing copy can thank lifetime users explicitly without having to check the underlying SKU."}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"PaywallState.isGateSatisfied"},{"type":"text","text":" is "},{"type":"codeVoice","code":"isPro || hasPermanentLicense"},{"type":"text","text":". Feature gating uses that single read; UI personalization branches on the underlying flags."}]},{"type":"heading","anchor":"Stream-semantics","level":2,"text":"Stream semantics"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The mapping rule applies identically whether the snapshot comes from "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":", "},{"type":"codeVoice","code":"customerInfoStream()"},{"type":"text","text":", or "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":". The service does not preserve any state across calls — every snapshot is computed afresh from the "},{"type":"codeVoice","code":"CustomerInfo"},{"type":"text","text":" in hand. This means:"}]},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"Two consecutive identical "},{"code":"CustomerInfo","type":"codeVoice"},{"type":"text","text":" values produce two identical snapshots. The plugin’s "},{"code":".customerInfoUpdated","type":"codeVoice"},{"type":"text","text":" reducer no-ops cleanly when the snapshot is unchanged."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A subscription expiring server-side surfaces as a snapshot with "},{"code":"isPro = false","type":"codeVoice"},{"type":"text","text":" on the next stream yield. Your gate flips closed automatically."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A restore that recovers a lifetime purchase surfaces as "},{"code":"hasPermanentLicense = true","type":"codeVoice"},{"type":"text","text":" on the next call, even if the user’s subscription was never restored."}],"type":"paragraph"}]}]}],"kind":"content"}],"sections":[],"kind":"article","abstract":[{"type":"text","text":"How RevenueCat’s "},{"type":"codeVoice","code":"CustomerInfo.entitlements"},{"type":"text","text":" translates to Swidux’s "},{"code":"EntitlementSnapshot","type":"codeVoice"},{"type":"text","text":"."}],"metadata":{"roleHeading":"Article","modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article","title":"Entitlement Mapping"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","kind":"article","title":"Service Reference","abstract":[{"type":"text","text":"API reference for "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" — the RevenueCat-backed "},{"type":"codeVoice","code":"PaywallService"},{"type":"text","text":" conformer that the paywall plugin consumes."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","kind":"symbol","title":"SwiduxRevenueCatPaywall","abstract":[{"type":"text","text":"RevenueCat adapter for Swidux’s "},{"code":"PaywallPlugin","type":"codeVoice"},{"type":"text","text":". Implements "},{"code":"PaywallService","type":"codeVoice"},{"type":"text","text":" against "},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":", ships a controllable mock for previews and tests, and pairs with "},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" for drop-in "},{"type":"codeVoice","code":"PaywallView"},{"type":"text","text":" and "},{"type":"codeVoice","code":"CustomerCenterView"},{"text":" presentation.","type":"text"}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/PlatformBehavior":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/platformbehavior","kind":"article","title":"Platform Behavior","abstract":[{"type":"text","text":"Why the "},{"type":"codeVoice","code":"revenueCatPaywall"},{"type":"text","text":" and "},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" modifiers present differently on iOS and macOS, and what is hard-coded."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToImplementService":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice","kind":"article","title":"How to Implement the Service","abstract":[{"type":"text","text":"Wire "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"type":"topic"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","kind":"article","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"type":"topic"}}}