ementSnapshot)","    public func finish()","}"],"type":"codeListing"},{"inlineContent":[{"text":"Reference type. Internal state is guarded by an ","type":"text"},{"type":"codeVoice","code":"NSLock"},{"text":"; ","type":"text"},{"type":"codeVoice","code":"@unchecked Sendable"},{"text":" because the protected mutable state lives behind that lock.","type":"text"}],"type":"paragraph"},{"anchor":"Initializer","text":"Initializer","level":4,"type":"heading"},{"syntax":"swift","code":["public init(isPro: Bool = false, hasPermanentLicense: Bool = false)"],"type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"code":"isPro","type":"codeVoice"},{"type":"text","text":" — Initial value for "},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"},{"type":"text","text":" — Initial value for "},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"type":"text","text":"."}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"text":"The values supplied here become the initial snapshot returned by ","type":"text"},{"type":"codeVoice","code":"customerInfo()"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"restorePurchases()"},{"text":" and the first value yielded by ","type":"text"},{"type":"codeVoice","code":"customerInfoStream()"},{"text":".","type":"text"}],"type":"paragraph"},{"anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","text":"`customerInfo() async throws -> EntitlementSnapshot`","level":4,"type":"heading"},{"inlineContent":[{"text":"Returns the snapshot supplied at init. Updates pushed via ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)"},{"text":" do ","type":"text"},{"type":"strong","inlineContent":[{"text":"not","type":"text"}]},{"text":" change the