{"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"type":"paragraph","inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" adapts "},{"type":"codeVoice","code":"RevenueCat.Purchases"},{"text":" to the ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" protocol that ","type":"text"},{"type":"codeVoice","code":"SwiduxPaywall.PaywallPlugin"},{"text":" requires. It does one job: translate ","type":"text"},{"type":"codeVoice","code":"CustomerInfo"},{"text":" into ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":" (defined by ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"type":"text","text":") so the plugin can drive its state. Configuration of the RevenueCat SDK itself remains the caller’s responsibility."}]},{"inlineContent":[{"type":"text","text":"For a step-by-step integration walkthrough, see "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService","isActive":true,"type":"reference"},{"text":". For the entitlement-mapping rules, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"Library target","type":"heading","level":2,"anchor":"Library-target"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Product: ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywall"}]}]},{"content":[{"inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywall","type":"codeVoice"}],"type":"paragraph"}]}]},{"inlineContent":[{"code":"Package.swift","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":[".product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),"],"type":"codeListing","syntax":"swift"},{"text":"Types","level":2,"anchor":"Types","type":"heading"},{"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywallService``","level":3,"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallRevenueCatPaywallService","type":"heading"},{"code":["public struct RevenueCatPaywallService: PaywallService {","    public init(","        entitlementID: String,","        permanentLicenseEntitlementID: String? = nil","    )","","    public func customerInfo() async throws -> EntitlementSnapshot","    public func customerInfoStream() -> AsyncStream<EntitlementSnapshot>","    public func restorePurchases() async throws -> EntitlementSnapshot","}"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"Value type. Holds two ","type":"text"},{"code":"String","type":"codeVoice"},{"text":" identifiers and forwards every call to ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":". Cheap to construct and pass into ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":" — after ","type":"text"},{"code":"RevenueCatPaywall.configure","type":"codeVoice"},{"text":" has run. For production, wrap it in SwiduxPaywall’s ","type":"text"},{"code":"ResilientPaywallService","type":"codeVoice"},{"text":" so a transient read failure at launch never gates a paid user as free.","type":"text"}]},{"anchor":"Initializer","text":"Initializer","type":"heading","level":4},{"code":["public init(","    entitlementID: String,","    permanentLicenseEntitlementID: String? = nil",")"],"syntax":"swift","type":"codeListing"},{"items":[{"content":[{"inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"type":"text","text":" — RevenueCat entitlement identifier that grants pro access. Surfaces as "},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"text":" when active.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"permanentLicenseEntitlementID","type":"codeVoice"},{"text":" — Optional secondary identifier for a lifetime \/ permanent entitlement. Surfaces as ","type":"text"},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"type":"text","text":" when active. Pass "},{"type":"codeVoice","code":"nil"},{"type":"text","text":" if the app has no separate lifetime SKU."}]}]}],"type":"unorderedList"},{"style":"important","name":"Important","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Call "},{"type":"reference","isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)"},{"text":" before constructing the service. The initializer preconditions on the SDK being configured — failing fast with a named fix instead of letting ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":" trap opaquely at first use. Previews and tests should construct "},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" instead.","type":"text"}]}],"type":"aside"},{"text":"`customerInfo() async throws -> EntitlementSnapshot`","level":4,"anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","type":"heading"},{"inlineContent":[{"type":"text","text":"One-shot fetch. Calls "},{"type":"codeVoice","code":"Purchases.shared.customerInfo()"},{"type":"text","text":" and maps the result."}],"type":"paragraph"},{"inlineContent":[{"text":"Throws whatever the RevenueCat SDK throws (","type":"text"},{"code":"ErrorCode.networkError","type":"codeVoice"},{"text":", ","type":"text"},{"code":".offlineConnectionError","type":"codeVoice"},{"type":"text","text":", etc.). The plugin catches the error and dispatches "},{"type":"codeVoice","code":".refreshFailed(message)"},{"type":"text","text":"."}],"type":"paragraph"},{"text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","level":4,"type":"heading","anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E"},{"inlineContent":[{"type":"text","text":"Long-lived stream. Wraps "},{"type":"codeVoice","code":"Purchases.shared.customerInfoStream"},{"text":" and yields a new ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":" for every change RevenueCat reports — purchase, refund, family-share update, sandbox renewal.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"type":"text","text":"The stream finishes when the underlying RevenueCat stream finishes. The plugin’s "},{"code":".observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" effect normally keeps it alive for the duration of the session; cancel by cancelling the consuming "},{"code":"Task","type":"codeVoice"},{"text":", which terminates the stream and tears down the bridge.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The stream buffers only the newest snapshot: each yield is a complete entitlement state, so a slow consumer sees the latest value rather than replaying stale intermediate states.","type":"text"}],"type":"paragraph"},{"type":"heading","level":4,"text":"`restorePurchases() async throws -> EntitlementSnapshot`","anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Calls "},{"code":"Purchases.shared.restorePurchases()","type":"codeVoice"},{"type":"text","text":" and maps the result. Throws whatever the SDK throws on error."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The plugin’s "},{"type":"codeVoice","code":".restorePurchases"},{"text":" action wraps this call and dispatches ","type":"text"},{"code":".customerInfoUpdated","type":"codeVoice"},{"text":" on success or ","type":"text"},{"code":".refreshFailed","type":"codeVoice"},{"text":" on error.","type":"text"}]},{"type":"heading","anchor":"Entitlement-mapping","level":2,"text":"Entitlement mapping"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For every "},{"type":"codeVoice","code":"CustomerInfo"},{"type":"text","text":" the service receives:"}]},{"type":"table","rows":[[[{"inlineContent":[{"type":"text","text":"Configuration"}],"type":"paragraph"}],[{"inlineContent":[{"code":"isPro","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"}],"type":"paragraph"}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"entitlementID"},{"text":" active","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"code":"true","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"(next column)"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"entitlementID","type":"codeVoice"},{"text":" inactive or missing","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"false"}]}],[{"type":"paragraph","inlineContent":[{"text":"(next column)","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"code":"permanentLicenseEntitlementID == nil","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"—"}]}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID"},{"type":"text","text":" active"}]}],[{"inlineContent":[{"text":"—","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"true"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"codeVoice","code":"permanentLicenseEntitlementID"},{"text":" inactive or missing","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"—","type":"text"}],"type":"paragraph"}],[{"type":"paragraph","inlineContent":[{"code":"false","type":"codeVoice"}]}]]],"header":"row"},{"inlineContent":[{"type":"text","text":"Both flags are checked independently against the same "},{"type":"codeVoice",