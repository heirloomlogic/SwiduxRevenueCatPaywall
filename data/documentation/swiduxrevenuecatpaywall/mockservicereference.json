{"abstract":[{"text":"API reference for ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — a controllable ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer for previews and tests that does not touch ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":".","type":"text"}],"sections":[],"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockServiceReference","interfaceLanguage":"swift"},"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","level":2,"text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"type":"text","text":" returns a configured snapshot from "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" and "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":", and exposes a streaming continuation through "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true,"type":"reference"},{"type":"text","text":" and "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()","isActive":true,"type":"reference"},{"type":"text","text":" so tests can simulate entitlement transitions over time."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"This mock differs from "},{"type":"codeVoice","code":"MockPaywallService"},{"type":"text","text":" in SwiduxPaywall: that mock’s stream finishes after the initial yield, which is fine for static previews but cannot model purchase, refund, or family-share updates as a sequence. This mock keeps the stream live until you tear it down."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For preview and test patterns built on this type, see "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","isActive":true,"type":"reference"},{"type":"text","text":"."}]},{"anchor":"Library-target","level":2,"text":"Library target","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Product: ","type":"text"},{"code":"SwiduxRevenueCatPaywall","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Import: ","type":"text"},{"code":"import SwiduxRevenueCatPaywall","type":"codeVoice"}]}]}],"type":"unorderedList"},{"anchor":"Types","level":2,"text":"Types","type":"heading"},{"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallService","level":3,"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService``","type":"heading"},{"code":["public final class MockRevenueCatPaywallService: PaywallService, @unchecked Sendable {","    public init(isPro: Bool = false, hasPermanentLicense: Bool = false)","","    public func customerInfo() async throws -> EntitlementSnapshot","    public func customerInfoStream() -> AsyncStream<EntitlementSnapshot>","    public func restorePurchases() async throws -> EntitlementSnapshot","","    public func send(_ snapshot: EntitlementSnapshot)","    public func finish()","}"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Reference type. Internal state is guarded by an "},{"type":"codeVoice","code":"NSLock"},{"type":"text","text":"; "},{"type":"codeVoice","code":"@unchecked Sendable"},{"type":"text","text":" because the protected mutable state lives behind that lock."}]},{"anchor":"Initializer","level":4,"text":"Initializer","type":"heading"},{"code":["public init(isPro: Bool = false, hasPermanentLicense: Bool = false)"],"syntax":"swift","type":"codeListing"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"isPro","type":"codeVoice"},{"text":" — Initial value for ","type":"text"},{"code":"EntitlementSnapshot.isPro","type":"codeVoice"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"hasPermanentLicense","type":"codeVoice"},{"text":" — Initial value for ","type":"text"},{"code":"EntitlementSnapshot.hasPermanentLicense","type":"codeVoice"},{"text":".","type":"text"}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The values supplied here become the initial snapshot returned by "},{"type":"codeVoice","code":"customerInfo()"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"restorePurchases()"},{"type":"text","text":" and the first value yielded by "},{"type":"codeVoice","code":"customerInfoStream()"},{"type":"text","text":"."}]},{"anchor":"customerInfo-async-throws-%3E-EntitlementSnapshot","level":4,"text":"`customerInfo() async throws -> EntitlementSnapshot`","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the snapshot supplied at init. Updates pushed via "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true,"type":"reference"},{"type":"text","text":" do "},{"type":"strong","inlineContent":[{"type":"text","text":"not"}]},{"type":"text","text":" change the value returned here. Use this method when a test needs a one-shot fetch independent of the stream."}]},{"anchor":"customerInfoStream-%3E-AsyncStream%3CEntitlementSnapshot%3E","level":4,"text":"`customerInfoStream() -> AsyncStream<EntitlementSnapshot>`","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Yields the initial snapshot, then every value passed to "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true,"type":"reference"},{"type":"text","text":". The stream stays open until "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()","isActive":true,"type":"reference"},{"type":"text","text":" is called."}]},{"name":"Note","style":"note","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Each call to this method replaces the active continuation and finishes the previous stream, so an earlier subscriber’s "},{"type":"codeVoice","code":"for await"},{"type":"text","text":" loop terminates instead of hanging. Only the most recent subscriber receives subsequent "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true},{"type":"text","text":" updates."}]}],"type":"aside"},{"anchor":"restorePurchases-async-throws-%3E-EntitlementSnapshot","level":4,"text":"`restorePurchases() async throws -> EntitlementSnapshot`","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Returns the snapshot supplied at init. Independent of the stream."}]},{"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicesend","level":4,"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)``","type":"heading"},{"code":["public func send(_ snapshot: EntitlementSnapshot)"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Pushes a snapshot to the active stream subscriber. No-op if no stream has been requested yet, or if the active stream has been finished."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use this to simulate purchase, expiration, or family-share updates during a test."}]},{"anchor":"docSwiduxRevenueCatPaywalldocumentationSwiduxRevenueCatPaywallMockRevenueCatPaywallServicefinish","level":4,"text":"``doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/finish()``","type":"heading"},{"code":["public func finish()"],"syntax":"swift","type":"codeListing"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Finishes the active entitlement stream. Iterators terminate cleanly. Subsequent calls to "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService\/send(_:)","isActive":true,"type":"reference"},{"type":"text","text":" are no-ops."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Call this in test teardown or when a preview is done observing entitlement transitions."}]},{"anchor":"Lifecycle-example","level":2,"text":"Lifecycle example","type":"heading"},{"code":["let mock = MockRevenueCatPaywallService(isPro: false)","let stream = mock.customerInfoStream()","","var iterator = stream.makeAsyncIterator()","let initial = await iterator.next()  \/\/ EntitlementSnapshot(isPro: false, ...)","","mock.send(EntitlementSnapshot(isPro: true))","let updated = await iterator.next()  \/\/ EntitlementSnapshot(isPro: true, ...)","","mock.finish()","let terminal = await iterator.next()  \/\/ nil — stream finished"],"syntax":"swift","type":"codeListing"}]}],"seeAlsoSections":[{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/MockRevenueCatPaywallService"],"title":"Related Documentation","anchor":"Related-Documentation"},{"identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/UIComponentsReference"],"title":"Reference","generated":true,"anchor":"Reference"}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/mockservicereference"]}],"schemaVersion":{"minor":3,"major":0