{"sections":[],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"title":"How to Implement the Service","role":"article","roleHeading":"Article"},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"primaryContentSections":[{"content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"This guide takes you from a wired Swidux app with a paywall slice to a live RevenueCat-backed entitlement pipeline. It covers SDK configuration, plugin registration, observation lifecycle, and refresh\/restore flows.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"For the API-level reference of the service, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","isActive":true,"type":"reference"},{"text":". For the entitlement mapping rules, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","isActive":true,"type":"reference"},{"text":". For the upstream plugin contract — actions, state shape, dispatch semantics — see Swidux’s ","type":"text"},{"inlineContent":[{"type":"text","text":"Add a Paywall"}],"type":"emphasis"},{"text":" and ","type":"text"},{"inlineContent":[{"type":"text","text":"SwiduxPaywall Reference"}],"type":"emphasis"},{"text":"; this guide does not repeat that material.","type":"text"}]},{"level":2,"type":"heading","anchor":"Before-you-start","text":"Before you start"},{"type":"paragraph","inlineContent":[{"text":"This guide assumes:","type":"text"}]},{"items":[{"content":[{"inlineContent":[{"text":"You have a wired Swidux app — ","type":"text"},{"code":"AppState","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AppAction","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AppReducer","type":"codeVoice"},{"text":", ","type":"text"},{"code":"AppStore","type":"codeVoice"},{"text":" exist, and the store is in the SwiftUI environment.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"Your ","type":"text"},{"code":"AppState","type":"codeVoice"},{"text":" already has a ","type":"text"},{"code":"paywall: PaywallState","type":"codeVoice"},{"text":" slice and your ","type":"text"},{"code":"AppAction","type":"codeVoice"},{"text":" has a ","type":"text"},{"code":".paywall(PaywallAction)","type":"codeVoice"},{"text":" case. If not, follow Swidux’s ","type":"text"},{"inlineContent":[{"text":"Add a Paywall","type":"text"}],"type":"emphasis"},{"text":" guide first.","type":"text"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"You have a RevenueCat project, an API key, and at least one entitlement identifier configured in the RevenueCat dashboard.","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"},{"level":2,"type":"heading","anchor":"Step-1-Add-the-dependencies","text":"Step 1: Add the dependencies"},{"type":"paragraph","inlineContent":[{"text":"Add both Swift packages to your ","type":"text"},{"type":"codeVoice","code":"Package.swift"},{"text":":","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["dependencies: [","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/Swidux\", branch: \"main\"),","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", branch: \"main\"),","],"]},{"type":"paragraph","inlineContent":[{"text":"Add the products you need to your app target:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":[".target(","    name: \"MyApp\",","    dependencies: [","        .product(name: \"Swidux\", package: \"Swidux\"),","        .product(name: \"SwiduxPaywall\", package: \"Swidux\"),","        .product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),","        .product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),","    ]",")"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" is optional — drop it if you don’t need the bundled sheets.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-2-Configure-RevenueCat-at-launch","text":"Step 2: Configure RevenueCat at launch"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" calls into ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":". Configure the SDK before constructing the store:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ MyApp.swift","import RevenueCat","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        Purchases.configure(withAPIKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"]},{"style":"important","name":"Important","type":"aside","content":[{"inlineContent":[{"type":"text","text":""},{"code":"Purchases.shared","type":"codeVoice"},{"type":"text","text":" traps if used unconfigured. Configure it before anything that constructs "},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":", including SwiftUI previews — guard preview-only code with "},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" instead."}],"type":"paragraph"}]},{"level":2,"type":"heading","anchor":"Step-3-Construct-the-service","text":"Step 3: Construct the service"},{"type":"paragraph","inlineContent":[{"text":"Create the service with the entitlement identifier you set up in the RevenueCat dashboard:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(entitlementID: \"pro\")"]},{"type":"paragraph","inlineContent":[{"text":"If your app sells a separate lifetime SKU alongside a subscription, see ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","isActive":true,"type":"reference"},{"text":" for the dual-entitlement form.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-4-Register-the-paywall-plugin","text":"Step 4: Register the paywall plugin"},{"type":"paragraph","inlineContent":[{"text":"Pass the service to ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":" when wiring the store:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["\/\/ AppStore.swift","import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The plugin owns reducing for ","type":"text"},{"type":"codeVoice","code":".paywall"},{"text":" actions; your root reducer should fall through with ","type":"text"},{"type":"codeVoice","code":"return nil"},{"text":" for that case.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-5-Observe-customer-info-on-launch","text":"Step 5: Observe customer info on launch"},{"type":"paragraph","inlineContent":[{"text":"Start the entitlement stream once, on the root view:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"observeCustomerInfo"},{"text":" returns a long-lived effect that consumes ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.customerInfoStream()"},{"text":". Every snapshot the service yields flows through ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" and updates ","type":"text"},{"type":"codeVoice","code":"store.paywall.isPro"},{"text":" \/ ","type":"text"},{"type":"codeVoice","code":"hasPermanentLicense"},{"text":". The effect lives for the duration of the stream, so the store stays in sync with RevenueCat without polling.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-6-Gate-features","text":"Step 6: Gate features"},{"type":"paragraph","inlineContent":[{"text":"Read ","type":"text"},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"text":" before running gated work. If it’s ","type":"text"},{"type":"codeVoice","code":"false"},{"text":", dispatch ","type":"text"},{"type":"codeVoice","code":".request(reason:)"},{"text":" instead:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"isGateSatisfied"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" when the user holds an active pro subscription ","type":"text"},{"inlineContent":[{"type":"text","text":"or"}],"type":"strong"},{"text":" a permanent license — feature code does not need to know which.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-7-Wire-the-UI","text":"Step 7: Wire the UI"},{"type":"paragraph","inlineContent":[{"text":"To present ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":" and the customer center, attach the bundled sheets to a root view. See ","type":"text"},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true,"type":"reference"},{"text":".","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-8-Restore-purchases","text":"Step 8: Restore purchases"},{"type":"paragraph","inlineContent":[{"text":"Add a restore button to your paywall UI. Reflect ","type":"text"},{"type":"codeVoice","code":"store.paywall.isLoading"},{"text":" to disable it while the call is in flight:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"]},{"type":"paragraph","inlineContent":[{"text":"The plugin calls ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.restorePurchases()"},{"text":", which forwards to ","type":"text"},{"type":"codeVoice","code":"Purchases.shared.restorePurchases()"},{"text":". On success the resulting snapshot flows through ","type":"text"},{"type":"codeVoice","code":".customerInfoUpdated"},{"text":" and updates the gate. On failure, ","type":"text"},{"type":"codeVoice","code":"store.paywall.error"},{"text":" is set.","type":"text"}]},{"level":2,"type":"heading","anchor":"Step-9-Handle-errors","text":"Step 9: Handle errors"},{"type":"paragraph","inlineContent":[{"text":"The service throws whatever ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":" throws — ","type":"text"},{"type":"codeVoice","code":"ErrorCode.networkError"},{"text":", ","type":"text"},{"type":"codeVoice","code":".offlineConnectionError"},{"text":", configuration errors, etc. The plugin catches the error and dispatches ","type":"text"},{"type":"codeVoice","code":".refreshFailed(message)"},{"text":". Read ","type":"text"},{"type":"codeVoice","code":"store.paywall.error"},{"text":" from your paywall view to surface a retry affordance:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["if let error = store.paywall.error {","    Text(error)","        .foregroundStyle(.red)","    Button(\"Retry\") {","        store.send(.paywall(.refreshCustomerInfo))","    }","}"]}],"kind":"content"}],"abstract":[{"type":"text","text":"Wire "},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"type":"text","text":" into the "},{"type":"codeVoice","code":"SwiduxPaywall"},{"type":"text","text":" plugin so the store sees real-time entitlement updates from RevenueCat."}],"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice"],"traits":[{"interfaceLanguage":"swift"}]}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"]},{"title":"How-to Guides","generated":true,"anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"title":"Service Reference","role":"article","kind":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","type":"topic","abstract":[{"text":"API reference for ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" — the RevenueCat-backed ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer that the paywall plugin consumes.","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"abstract":[{"text":"Attach the ","type":"text"},{"type":"codeVoice","code":"revenueCatPaywall"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"revenueCatCustomerCenter"},{"type":"text","text":" view modifiers from "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","role":"article","title":"How to Present the UI","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","role":"article","title":"How to Add a Permanent License","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"title":"How to Preview and Test","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","kind":"article","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","type":"topic","abstract":[{"type":"text","text":"Drive entitlement state from SwiftUI previews and tests with "},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" — no RevenueCat SDK call required."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"type":"codeVoice","code":"PaywallPlugin"},{"text":". Implements ","type":"text"},{"type":"codeVoice","code":"PaywallService"},{"text":" against ","type":"text"},{"type":"codeVoice","code":"Purchases.shared"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"kind":"symbol","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall","role":"collection","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}],"kind":"article","type":"topic","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","role":"article","title":"Entitlement Mapping","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"}}}