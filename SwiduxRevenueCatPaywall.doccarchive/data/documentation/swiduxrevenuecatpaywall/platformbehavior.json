{"primaryContentSections":[{"kind":"content","content":[{"text":"Overview","anchor":"Overview","type":"heading","level":2},{"inlineContent":[{"text":"The bundled UI is intentionally opinionated. Each view picks the platform-appropriate presentation so consumers don’t have to repeat the conditional compilation themselves, and so the dispatch flow stays symmetric across platforms — the same ","type":"text"},{"code":".paywall(.dismiss)","type":"codeVoice"},{"text":" action fires from a ","type":"text"},{"code":"fullScreenCover","type":"codeVoice"},{"text":" on iOS and from a sheet on macOS.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This article explains the reasoning behind those choices and what is fixed versus configurable.","type":"text"}],"type":"paragraph"},{"text":"PaywallSheet","anchor":"PaywallSheet","type":"heading","level":2},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Presentation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Reason","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"iOS"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"fullScreenCover"}]}],[{"type":"paragraph","inlineContent":[{"text":"A subscription paywall is a primary moment, not an interrupt. ","type":"text"},{"type":"codeVoice","code":"fullScreenCover"},{"text":" keeps the UI immersive, prevents accidental gesture-dismiss, and matches App Store conventions.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sheet"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"frame(minWidth: 400, minHeight: 600)"}]}],[{"type":"paragraph","inlineContent":[{"text":"Mac sheets do not expand to fill the parent window. Without an explicit minimum size the paywall would render too small to legibly show plan options. The 400×600 minimum is roughly the size RevenueCatUI’s templates assume.","type":"text"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"text":"The minimum frame is hard-coded; it is not exposed as a parameter. If your paywall layout needs more room on macOS, wrap ","type":"text"},{"code":"PaywallSheet","type":"codeVoice"},{"text":" in a parent that imposes a larger frame, or use ","type":"text"},{"code":"RevenueCatUI.PaywallView","type":"codeVoice"},{"text":" directly inside a custom ","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":" modifier.","type":"text"}],"type":"paragraph"},{"text":"CustomerCenterSheet","anchor":"CustomerCenterSheet","type":"heading","level":2},{"rows":[[[{"type":"paragraph","inlineContent":[{"text":"Platform","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Presentation","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Reason","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"iOS"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"sheet"},{"text":" with ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"}]}],[{"type":"paragraph","inlineContent":[{"text":"RevenueCatUI ships a customer center on iOS only. A non-fullscreen ","type":"text"},{"type":"codeVoice","code":"sheet"},{"text":" is appropriate because customer-center actions are administrative, not part of a purchase flow.","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"macOS"}],"type":"strong"}]}],[{"type":"paragraph","inlineContent":[{"text":"Opens ","type":"text"},{"type":"codeVoice","code":"itms-apps:\/\/apps.apple.com\/account\/subscriptions"},{"text":" and immediately fires ","type":"text"},{"type":"codeVoice","code":"onDismiss"}]}],[{"type":"paragraph","inlineContent":[{"text":"RevenueCatUI does not ship a customer center on macOS, and the system has no equivalent in-app surface. The App Store subscription management page is what users expect on the Mac, so the sheet hands off to it and clears its own presentation state immediately.","type":"text"}]}]]],"header":"row","type":"table"},{"inlineContent":[{"text":"The macOS branch dispatches ","type":"text"},{"code":"onDismiss","type":"codeVoice"},{"text":" synchronously after ","type":"text"},{"code":"NSWorkspace.shared.open","type":"codeVoice"},{"text":" so ","type":"text"},{"code":"PaywallState.isCustomerCenterPresented","type":"codeVoice"},{"text":" does not get stuck ","type":"text"},{"code":"true","type":"codeVoice"},{"text":". The user returns from App Store to find the app’s UI in its idle state.","type":"text"}],"type":"paragraph"},{"text":"Why no platform-override hooks","anchor":"Why-no-platform-override-hooks","type":"heading","level":2},{"inlineContent":[{"text":"Both views are deliberately stateless and parameter-light: an ","type":"text"},{"code":"isPresented: Bool","type":"codeVoice"},{"text":" and an ","type":"text"},{"code":"onDismiss: () -> Void","type":"codeVoice"},{"text":". There is no ","type":"text"},{"code":"paywallStyle:","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"presentationKind:","type":"codeVoice"},{"text":" parameter.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"The reasoning: any consumer that needs to deviate from the chosen presentation already has the underlying RevenueCatUI types (","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":", ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":") and SwiftUI’s full presentation surface (","type":"text"},{"code":"sheet","type":"codeVoice"},{"text":", ","type":"text"},{"code":"fullScreenCover","type":"codeVoice"},{"text":", ","type":"text"},{"code":"popover","type":"codeVoice"},{"text":", custom containers). The bundled views exist to handle the 95% case in one line — when the 5% case applies, drop down to RevenueCatUI directly.","type":"text"}],"type":"paragraph"},{"inlineContent":[{"text":"This package does not try to be the complete paywall-UI library. It is the ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"integration layer","type":"text"}]},{"text":" that makes the common case trivial.","type":"text"}],"type":"paragraph"},{"text":"What is configurable","anchor":"What-is-configurable","type":"heading","level":2},{"inlineContent":[{"text":"The configurable surface lives in ","type":"text"},{"code":"RevenueCatUI","type":"codeVoice"},{"text":" and on the paywall plugin:","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Paywall content, copy, and template","type":"text"}],"type":"strong"},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"text":" renders whichever offering and template the dashboard returns.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Customer-center labels, sections, and actions","type":"text"}],"type":"strong"},{"text":" — configured in the RevenueCat dashboard. ","type":"text"},{"type":"codeVoice","code":"RevenueCatUI.CustomerCenterView"},{"text":" renders whichever configuration the dashboard returns.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Presentation triggering","type":"text"}],"type":"strong"},{"text":" — driven by the plugin via ","type":"text"},{"type":"codeVoice","code":"PaywallState.isPresented"},{"text":" and ","type":"text"},{"type":"codeVoice","code":"isCustomerCenterPresented"},{"text":". Your code chooses ","type":"text"},{"inlineContent":[{"text":"when","type":"text"}],"type":"emphasis"},{"text":" to set them via ","type":"text"},{"type":"codeVoice","code":".request(reason:)"},{"text":" and ","type":"text"},{"type":"codeVoice","code":".presentCustomerCenter"},{"text":" actions.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Dismiss behavior","type":"text"}],"type":"strong"},{"text":" — your ","type":"text"},{"type":"codeVoice","code":"onDismiss"},{"text":" closures dispatch the matching paywall actions. Replace them if you need analytics hooks or cleanup beyond the default flow.","type":"text"}]}]}],"type":"unorderedList"}]}],"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"sections":[],"kind":"article","abstract":[{"type":"text","text":"Why "},{"code":"PaywallSheet","type":"codeVoice"},{"type":"text","text":" and "},{"code":"CustomerCenterSheet","type":"codeVoice"},{"type":"text","text":" present differently on iOS and macOS, and what is hard-coded."}],"seeAlsoSections":[{"abstract":[{"type":"text","text":"The "},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"type":"text","text":" documentation provides the matching API reference for the views described here."}],"title":"Related Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI"],"anchor":"Related-Documentation"},{"anchor":"Explanation","title":"Explanation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"],"generated":true}],"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article","title":"Platform Behavior","roleHeading":"Article"},"identifier":{"url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/PlatformBehavior","interfaceLanguage":"swift"},"schemaVersion":{"patch":0,"minor":3,"major":0},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/swiduxrevenuecatpaywall\/platformbehavior"]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"role":"article","kind":"art