{"hierarchy":{"paths":[["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall"]]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToImplementService"},"kind":"article","schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"Wire ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":" into the ","type":"text"},{"code":"SwiduxPaywall","type":"codeVoice"},{"text":" plugin so the store sees real-time entitlement updates from RevenueCat.","type":"text"}],"seeAlsoSections":[{"title":"Related Documentation","anchor":"Related-Documentation","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping"]},{"generated":true,"title":"How-to Guides","anchor":"How-to-Guides","identifiers":["doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide takes you from a wired Swidux app with a paywall slice to a live RevenueCat-backed entitlement pipeline. It covers SDK configuration, plugin registration, observation lifecycle, and refresh\/restore flows."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For the API-level reference of the service, see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","isActive":true},{"type":"text","text":". For the entitlement mapping rules, see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","isActive":true},{"type":"text","text":". For the upstream plugin contract — actions, state shape, dispatch semantics — see Swidux’s "},{"type":"emphasis","inlineContent":[{"type":"text","text":"Add a Paywall"}]},{"type":"text","text":" and "},{"type":"emphasis","inlineContent":[{"type":"text","text":"SwiduxPaywall Reference"}]},{"type":"text","text":"; this guide does not repeat that material."}]},{"anchor":"Before-you-start","type":"heading","level":2,"text":"Before you start"},{"type":"paragraph","inlineContent":[{"type":"text","text":"This guide assumes:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have a wired Swidux app — "},{"type":"codeVoice","code":"AppState"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppAction"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppReducer"},{"type":"text","text":", "},{"type":"codeVoice","code":"AppStore"},{"type":"text","text":" exist, and the store is in the SwiftUI environment."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Your "},{"type":"codeVoice","code":"AppState"},{"type":"text","text":" already has a "},{"type":"codeVoice","code":"paywall: PaywallState"},{"type":"text","text":" slice and your "},{"type":"codeVoice","code":"AppAction"},{"type":"text","text":" has a "},{"type":"codeVoice","code":".paywall(PaywallAction)"},{"type":"text","text":" case. If not, follow Swidux’s "},{"type":"emphasis","inlineContent":[{"text":"Add a Paywall","type":"text"}]},{"type":"text","text":" guide first."}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"You have a RevenueCat project, an API key, and at least one entitlement identifier configured in the RevenueCat dashboard."}]}]}],"type":"unorderedList"},{"anchor":"Step-1-Add-the-dependencies","type":"heading","level":2,"text":"Step 1: Add the dependencies"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add both Swift packages to your "},{"type":"codeVoice","code":"Package.swift"},{"type":"text","text":":"}]},{"code":["dependencies: [","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/Swidux\", from: \"1.3.0\"),","    .package(url: \"https:\/\/github.com\/HeirloomLogic\/SwiduxRevenueCatPaywall\", from: \"1.0.0\"),","],"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the products you need to your app target:"}]},{"type":"codeListing","code":[".target(","    name: \"MyApp\",","    dependencies: [","        .product(name: \"Swidux\", package: \"Swidux\"),","        .product(name: \"SwiduxPaywall\", package: \"Swidux\"),","        .product(name: \"SwiduxRevenueCatPaywall\", package: \"SwiduxRevenueCatPaywall\"),","        .product(name: \"SwiduxRevenueCatPaywallUI\", package: \"SwiduxRevenueCatPaywall\"),","    ]",")"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"SwiduxRevenueCatPaywallUI"},{"type":"text","text":" is optional — drop it if you don’t need the bundled sheets."}]},{"type":"heading","text":"Step 2: Configure the paywall at launch","level":2,"anchor":"Step-2-Configure-the-paywall-at-launch"},{"type":"paragraph","inlineContent":[{"code":"RevenueCatPaywallService","type":"codeVoice"},{"type":"text","text":" calls into "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":" under the hood. Configure the paywall before constructing the store:"}]},{"code":["\/\/ MyApp.swift","import SwiduxRevenueCatPaywall","import SwiftUI","","@main","struct MyApp: App {","    @State private var store: AppStore","","    init() {","        RevenueCatPaywall.configure(apiKey: \"your_revenuecat_api_key\")","        _store = State(wrappedValue: AppStore.configured())","    }","","    var body: some Scene {","        WindowGroup { ContentView().environment(store) }","    }","}"],"type":"codeListing","syntax":"swift"},{"type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":""},{"code":"Purchases.shared","type":"codeVoice"},{"text":" traps if used unconfigured. Call ","type":"text"},{"isActive":true,"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)","type":"reference"},{"text":" before anything that constructs ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService"},{"text":", including SwiftUI previews — guard preview-only code with ","type":"text"},{"type":"codeVoice","code":"MockRevenueCatPaywallService"},{"text":" instead.","type":"text"}]}],"name":"Important","style":"important"},{"level":2,"anchor":"Step-3-Construct-the-service","text":"Step 3: Construct the service","type":"heading"},{"inlineContent":[{"type":"text","text":"Create the service with the entitlement identifier you set up in the RevenueCat dashboard:"}],"type":"paragraph"},{"type":"codeListing","code":["import SwiduxRevenueCatPaywall","","let service = RevenueCatPaywallService(entitlementID: \"pro\")"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"If your app sells a separate lifetime SKU alongside a subscription, see "},{"type":"reference","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","isActive":true},{"type":"text","text":" for the dual-entitlement form."}],"type":"paragraph"},{"anchor":"Step-4-Register-the-paywall-plugin","type":"heading","text":"Step 4: Register the paywall plugin","level":2},{"inlineContent":[{"type":"text","text":"Pass the service to "},{"type":"codeVoice","code":"PaywallPlugin"},{"type":"text","text":" when wiring the store:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ AppStore.swift","import Swidux","import SwiduxPaywall","import SwiduxRevenueCatPaywall","","extension Store where State == AppState, Action == AppAction {","    static func configured() -> AppStore {","        let plugins = PluginHost<AppState, AppAction>()","","        plugins.register(","            PaywallPlugin<AppState, AppAction>(","                state: \\.paywall,","                action: AppAction.paywall,","                extractAction: { if case .paywall(let a) = $0 { return a }; return nil },","                service: RevenueCatPaywallService(entitlementID: \"pro\")","            )","        )","","        return Store(","            initialState: AppState(),","            reducer: AppReducer().reduce,","            plugins: plugins","        )","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The plugin owns reducing for ","type":"text"},{"type":"codeVoice","code":".paywall"},{"type":"text","text":" actions; your root reducer should fall through with "},{"type":"codeVoice","code":"return nil"},{"type":"text","text":" for that case."}]},{"level":2,"anchor":"Step-5-Observe-customer-info-on-launch","text":"Step 5: Observe customer info on launch","type":"heading"},{"inlineContent":[{"type":"text","text":"Start the entitlement stream once, on the root view:"}],"type":"paragraph"},{"type":"codeListing","code":["struct ContentView: View {","    @Environment(AppStore.self) private var store","","    var body: some View {","        RootContent()","            .task { store.send(.paywall(.observeCustomerInfo)) }","    }","}"],"syntax":"swift"},{"inlineContent":[{"code":"observeCustomerInfo","type":"codeVoice"},{"type":"text","text":" returns a long-lived effect that consumes "},{"type":"codeVoice","code":"RevenueCatPaywallService.customerInfoStream()"},{"type":"text","text":". Every snapshot the service yields flows through "},{"type":"codeVoice","code":".customerInfoUpdated"},{"type":"text","text":" and updates "},{"type":"codeVoice","code":"store.paywall.isPro"},{"type":"text","text":" \/ "},{"type":"codeVoice","code":"hasPermanentLicense"},{"type":"text","text":". The effect lives for the duration of the stream, so the store stays in sync with RevenueCat without polling."}],"type":"paragraph"},{"level":2,"anchor":"Step-6-Gate-features","text":"Step 6: Gate features","type":"heading"},{"inlineContent":[{"type":"text","text":"Read "},{"type":"codeVoice","code":"store.paywall.isGateSatisfied"},{"type":"text","text":" before running gated work. If it’s "},{"code":"false","type":"codeVoice"},{"type":"text","text":", dispatch "},{"type":"codeVoice","code":".request(reason:)"},{"type":"text","text":" instead:"}],"type":"paragraph"},{"syntax":"swift","code":["Button(\"Export PDF\") {","    if store.paywall.isGateSatisfied {","        store.send(.export(.exportPDF))","    } else {","        store.send(.paywall(.request(reason: \"export-pdf\")))","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"codeVoice","code":"isGateSatisfied"},{"text":" returns ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" when the user holds an active pro subscription ","type":"text"},{"inlineContent":[{"type":"text","text":"or"}],"type":"strong"},{"text":" a permanent license — feature code does not need to know which.","type":"text"}],"type":"paragraph"},{"type":"heading","text":"Step 7: Wire the UI","level":2,"anchor":"Step-7-Wire-the-UI"},{"inlineContent":[{"type":"text","text":"To present "},{"type":"codeVoice","code":"RevenueCatUI.PaywallView"},{"type":"text","text":" and the customer center, attach the bundled sheets to a root view. See "},{"identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","isActive":true,"type":"reference"},{"type":"text","text":"."}],"type":"paragraph"},{"level":2,"anchor":"Step-8-Restore-purchases","text":"Step 8: Restore purchases","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add a restore button to your paywall UI. Reflect "},{"code":"store.paywall.isLoading","type":"codeVoice"},{"type":"text","text":" to disable it while the call is in flight:"}]},{"type":"codeListing","code":["Button(\"Restore Purchases\") {","    store.send(.paywall(.restorePurchases))","}",".disabled(store.paywall.isLoading)"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"The plugin calls ","type":"text"},{"type":"codeVoice","code":"RevenueCatPaywallService.restorePurchases()"},{"type":"text","text":", which forwards to "},{"type":"codeVoice","code":"Purchases.shared.restorePurchases()"},{"type":"text","text":". On success the resulting snapshot flows through "},{"code":".customerInfoUpdated","type":"codeVoice"},{"type":"text","text":" and updates the gate. On failure, "},{"type":"codeVoice","code":"store.paywall.error"},{"type":"text","text":" is set."}]},{"level":2,"anchor":"Step-9-Handle-errors","text":"Step 9: Handle errors","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The service throws whatever "},{"type":"codeVoice","code":"Purchases.shared"},{"type":"text","text":" throws — "},{"type":"codeVoice","code":"ErrorCode.networkError"},{"type":"text","text":", "},{"type":"codeVoice","code":".offlineConnectionError"},{"type":"text","text":", configuration errors, etc. The plugin catches the error and dispatches "},{"type":"codeVoice","code":".refreshFailed(message)"},{"type":"text","text":". Read "},{"type":"codeVoice","code":"store.paywall.error"},{"type":"text","text":" from your paywall view to surface a retry affordance:"}]},{"code":["if let error = store.paywall.error {","    Text(error)","        .foregroundStyle(.red)","    Button(\"Retry\") {","        store.send(.paywall(.refreshCustomerInfo))","    }","}"],"type":"codeListing","syntax":"swift"}]}],"metadata":{"modules":[{"name":"SwiduxRevenueCatPaywall"}],"role":"article","title":"How to Implement the Service","roleHeading":"Article"},"variants":[{"paths":["\/documentation\/swiduxrevenuecatpaywall\/howtoimplementservice"],"traits":[{"interfaceLanguage":"swift"}]}],"references":{"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToAddAPermanentLicense":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToAddAPermanentLicense","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtoaddapermanentlicense","title":"How to Add a Permanent License","abstract":[{"type":"text","text":"Sell a lifetime entitlement alongside a subscription and surface both flags through the paywall plugin."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/RevenueCatPaywall/configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/RevenueCatPaywall\/configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)","fragments":[{"kind":"keyword","text":"static"},{"kind":"text","text":" "},{"kind":"keyword","text":"func"},{"kind":"text","text":" "},{"kind":"identifier","text":"configure"},{"kind":"text","text":"("},{"kind":"externalParam","text":"apiKey"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":", "},{"kind":"externalParam","text":"appUserID"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"String","preciseIdentifier":"s:SS"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"userDefaults"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"UserDefaults","preciseIdentifier":"c:objc(cs)NSUserDefaults"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"logLevel"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"RevenueCatPaywall","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"LogLevel","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O8LogLevelO"},{"kind":"text","text":", "},{"kind":"externalParam","text":"entitlementVerification"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"RevenueCatPaywall","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"EntitlementVerification","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O23EntitlementVerificationO"},{"kind":"text","text":", "},{"kind":"externalParam","text":"purchasesAreCompletedBy"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"RevenueCatPaywall","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"PurchasesCompletedBy","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O20PurchasesCompletedByO"},{"kind":"text","text":"?, "},{"kind":"externalParam","text":"storeKitVersion"},{"kind":"text","text":": "},{"kind":"typeIdentifier","text":"RevenueCatPaywall","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O"},{"kind":"text","text":"."},{"kind":"typeIdentifier","text":"StoreKitVersion","preciseIdentifier":"s:23SwiduxRevenueCatPaywall0bcD0O15StoreKitVersionO"},{"kind":"text","text":"?)"}],"kind":"symbol","role":"symbol","url":"\/documentation\/swiduxrevenuecatpaywall\/revenuecatpaywall\/configure(apikey:appuserid:userdefaults:loglevel:entitlementverification:purchasesarecompletedby:storekitversion:)","title":"configure(apiKey:appUserID:userDefaults:logLevel:entitlementVerification:purchasesAreCompletedBy:storeKitVersion:)","abstract":[{"type":"text","text":"Configures the underlying purchase provider."}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/ServiceReference":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/ServiceReference","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/servicereference","title":"Service Reference","abstract":[{"text":"API reference for ","type":"text"},{"code":"RevenueCatPaywallService","type":"codeVoice"},{"text":" — the RevenueCat-backed ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" conformer that the paywall plugin consumes.","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPreviewAndTest":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPreviewAndTest","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopreviewandtest","title":"How to Preview and Test","abstract":[{"text":"Drive entitlement state from SwiftUI previews and tests with ","type":"text"},{"code":"MockRevenueCatPaywallService","type":"codeVoice"},{"text":" — no RevenueCat SDK call required.","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall":{"type":"topic","role":"collection","url":"\/documentation\/swiduxrevenuecatpaywall","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall","kind":"symbol","abstract":[{"text":"RevenueCat adapter for Swidux’s ","type":"text"},{"code":"PaywallPlugin","type":"codeVoice"},{"text":". Implements ","type":"text"},{"code":"PaywallService","type":"codeVoice"},{"text":" against ","type":"text"},{"code":"Purchases.shared","type":"codeVoice"},{"text":", ships a controllable mock for previews and tests, and pairs with ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" for drop-in ","type":"text"},{"code":"PaywallView","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"CustomerCenterView","type":"codeVoice"},{"text":" presentation.","type":"text"}],"title":"SwiduxRevenueCatPaywall"},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/EntitlementMapping":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/EntitlementMapping","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/entitlementmapping","title":"Entitlement Mapping","abstract":[{"text":"How RevenueCat’s ","type":"text"},{"code":"CustomerInfo.entitlements","type":"codeVoice"},{"text":" translates to Swidux’s ","type":"text"},{"code":"EntitlementSnapshot","type":"codeVoice"},{"text":".","type":"text"}]},"doc://SwiduxRevenueCatPaywall/documentation/SwiduxRevenueCatPaywall/HowToPresentTheUI":{"type":"topic","identifier":"doc:\/\/SwiduxRevenueCatPaywall\/documentation\/SwiduxRevenueCatPaywall\/HowToPresentTheUI","kind":"article","role":"article","url":"\/documentation\/swiduxrevenuecatpaywall\/howtopresenttheui","title":"How to Present the UI","abstract":[{"text":"Attach the ","type":"text"},{"code":"revenueCatPaywall","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"revenueCatCustomerCenter","type":"codeVoice"},{"text":" view modifiers from ","type":"text"},{"code":"SwiduxRevenueCatPaywallUI","type":"codeVoice"},{"text":" to a root view, driven by ","type":"text"},{"code":"PaywallState","type":"codeVoice"},{"text":".","type":"text"}]}}}